<!doctype html>
<html class="no-js" lang="{{ request.locale.iso_code }}">
  <head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="theme-color" content="#F8C8DC">
    <link rel="canonical" href="{{ canonical_url }}">
    
    <title>{{ page_title }}</title>

    {{ content_for_header }}

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;700&family=Playfair+Display:wght@400;600;700&display=swap" rel="stylesheet">

    <!-- Styles -->
    {{ 'base.css' | asset_url | stylesheet_tag }}

    <!-- Confetti Library -->
    <script src="https://cdn.jsdelivr.net/npm/canvas-confetti@1.6.0/dist/confetti.browser.min.js"></script>
  </head>

  <body>
    <!-- Cart Drawer (Fixed position) -->
    {% section 'cart-drawer' %}

    {% section 'header' %}

    <main id="MainContent" class="content-for-layout focus-none" role="main" tabindex="-1">
      {{ content_for_layout }}
    </main>

    {% section 'footer' %}

    <script>
      // 1. Reveal Animations
      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) entry.target.classList.add('reveal');
        });
      }, { threshold: 0.1 });
      document.querySelectorAll('.animate-reveal').forEach(el => observer.observe(el));

      // 2. Confetti Celebration
      function celebrate() {
        const colors = ['#F8C8DC', '#CDE7F0', '#DFF5E1', '#FFF1B8'];
        confetti({
          particleCount: 100,
          spread: 70,
          origin: { y: 0.6 },
          colors: colors,
          ticks: 200,
          gravity: 1.2,
          scalar: 0.8
        });
      }

      // 3. Global Add to Cart interceptor
      document.addEventListener('click', (e) => {
        if (e.target.closest('.product-card__atc') || e.target.closest('[type="submit"][name="add"]')) {
          // If it's an add to cart button
          if(window.openCart) {
            window.openCart();
            celebrate(); // 🌈 Burst of pastel confetti!
          }
        }
      });
    </script>
  </body>
</html>
