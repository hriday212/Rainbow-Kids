<!doctype html>
<html class="no-js" lang="{{ request.locale.iso_code }}">
  <head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="theme-color" content="#F8C8DC">
    <link rel="canonical" href="{{ canonical_url }}">
    
    <title>{{ page_title }}</title>

    {{ content_for_header }}

    <!-- Elite Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Bodoni+Moda:ital,wght@0,400..900;1,400..900&family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">

    <!-- Styles -->
    {{ 'base.css' | asset_url | stylesheet_tag }}
    <link rel="stylesheet" href="https://unpkg.com/aos@next/dist/aos.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css" />

    <!-- Libraries -->
    <script src="https://cdn.jsdelivr.net/npm/canvas-confetti@1.6.0/dist/confetti.browser.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"></script>
    <script src="https://unpkg.com/aos@next/dist/aos.js"></script>
    <script src="{{ 'cart-logic.js' | asset_url }}" defer></script>
  </head>

  <body>
    {% section 'announcement-bar' %}
    
    <!-- Cart Drawer -->
    {% section 'cart-drawer' %}

    {% section 'header' %}

    <main id="MainContent" class="content-for-layout focus-none" role="main" tabindex="-1">
      {{ content_for_layout }}
    </main>

    {% section 'footer' %}
    {% section 'cookie-banner' %}
    {% section 'discount-spinner' %}

    <script>
      // Initialize AOS (Animations)
      document.addEventListener('DOMContentLoaded', function() {
        AOS.init({
          duration: 1000,
          once: true,
          easing: 'ease-in-out',
          offset: 100
        });
      });

      // Confetti Celebration
      function celebrate() {
        const colors = ['#F8C8DC', '#CDE7F0', '#DFF5E1', '#FFF1B8'];
        confetti({ particleCount: 100, spread: 70, origin: { y: 0.6 }, colors: colors });
      }

      // Global Add to Cart interceptor
      document.addEventListener('click', (e) => {
        const atcBtn = e.target.closest('.product-card__atc');
        if (atcBtn) {
          e.preventDefault();
          const variantId = atcBtn.dataset.variantId || null;
          if (variantId && window.cartLogic) {
            window.cartLogic.addItem(variantId);
          } else if (window.openCart) {
            window.openCart();
            celebrate();
          }
        }
      });
    </script>
  </body>
</html>
