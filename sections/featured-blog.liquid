<style>
  .featured-blog { padding: 100px 0; background: #fff; }
  .blog-header { text-align: center; margin-bottom: 60px; }
  .blog-subtitle { font-size: 0.75rem; font-weight: 800; text-transform: uppercase; letter-spacing: 0.2em; color: var(--color-primary); margin-bottom: 15px; display: block; }
  .blog-title { font-family: var(--font-heading); font-size: 3.5rem; color: #1a1a1a; margin: 0; }
  
  .blog-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 30px; }
  .blog-card { text-decoration: none; display: block; opacity: 1 !important; visibility: visible !important; }
  .blog-card__img { aspect-ratio: 16/10; border-radius: 20px; overflow: hidden; background: #f4f4f4; margin-bottom: 20px; position: relative; }
  .blog-card__img img { width: 100%; height: 100%; object-fit: cover; }
  
  .blog-card__tag { position: absolute; top: 15px; left: 15px; background: #fff; padding: 6px 15px; border-radius: 50px; font-size: 0.65rem; font-weight: 800; text-transform: uppercase; letter-spacing: 0.1em; color: #1a1a1a; }
  .blog-card__date { font-size: 0.75rem; color: #aaa; text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 10px; display: block; }
  .blog-card__title { font-family: var(--font-heading); font-size: 1.4rem; color: #1a1a1a; margin-bottom: 15px; line-height: 1.3; }
  .blog-card__link { font-size: 0.75rem; font-weight: 800; text-transform: uppercase; letter-spacing: 0.15em; color: var(--color-primary); border-bottom: 2px solid var(--color-primary); padding-bottom: 4px; display: inline-block; }

  @media (max-width: 1024px) { .blog-grid { grid-template-columns: 1fr; } }
</style>

<section class="featured-blog">
  <div class="container">
    <div class="blog-header">
      <span class="blog-subtitle">{{ section.settings.subtitle | default: "Inside the Hub" }}</span>
      <h2 class="blog-title">{{ section.settings.title | default: "Latest Stories" }}</h2>
    </div>

    <div class="blog-grid">
      {%- assign blog = blogs[section.settings.blog] -%}
      {%- if blog.articles.size > 0 -%}
        {%- for article in blog.articles limit: 3 -%}
          <a href="{{ article.url }}" class="blog-card">
            <div class="blog-card__img">
              {%- if article.image -%}
                <img src="{{ article.image | image_url: width: 800 }}" alt="{{ article.title }}">
              {%- else -%}
                <div style="width:100%; height:100%; display:flex; align-items:center; justify-content:center; color:#ccc;">{{ 'lifestyle-1' | placeholder_svg_tag }}</div>
              {%- endif -%}
              <span class="blog-card__tag">Parenting</span>
            </div>
            <span class="blog-card__date">{{ article.published_at | date: "%b %d, %Y" }}</span>
            <h3 class="blog-card__title">{{ article.title }}</h3>
            <span class="blog-card__link">Read More</span>
          </a>
        {%- endfor -%}
      {%- else -%}
        {%- for i in (1..3) -%}
          <div class="blog-card">
            <div class="blog-card__img">
              <div style="width:100%; height:100%; display:flex; align-items:center; justify-content:center; background:#f9f9f9; color:#ccc;">{{ 'lifestyle-' | append: i | placeholder_svg_tag }}</div>
              <span class="blog-card__tag">Boutique Life</span>
            </div>
            <span class="blog-card__date">May 01, 2026</span>
            <h3 class="blog-card__title">The Ultimate Guide to Bamboo Sleep Bags for New Moms</h3>
            <span class="blog-card__link">Read More</span>
          </div>
        {%- endfor -%}
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{ "name": "Featured Blog", "settings": [ { "type": "text", "id": "subtitle", "label": "Subtitle", "default": "Inside the Hub" }, { "type": "text", "id": "title", "label": "Heading", "default": "Latest Stories" }, { "type": "blog", "id": "blog", "label": "Select Blog" } ], "presets": [{ "name": "Boutique Latest News" }] }
{% endschema %}
