<style>
  .size-chart { padding: 100px 0; background: #fff; }
  .size-header { text-align: center; margin-bottom: 70px; }
  .size-subtitle { font-size: 0.75rem; font-weight: 800; text-transform: uppercase; letter-spacing: 0.2em; color: var(--color-primary); margin-bottom: 15px; display: block; }
  .size-title { font-family: var(--font-heading); font-size: 3.5rem; color: #1a1a1a; margin: 0; }
  
  .size-tabs { display: flex; justify-content: center; gap: 40px; margin-bottom: 50px; border-bottom: 1px solid #eee; }
  .size-tab { padding: 15px 0; font-size: 0.9rem; font-weight: 800; text-transform: uppercase; letter-spacing: 0.1em; color: #aaa; cursor: pointer; border-bottom: 3px solid transparent; transition: all 0.3s; }
  .size-tab.active { color: var(--color-primary); border-color: var(--color-primary); }

  .size-table-wrap { overflow-x: auto; max-width: 900px; margin: 0 auto; background: #fdf8f6; border-radius: 30px; padding: 40px; }
  .size-table { width: 100%; border-collapse: collapse; text-align: left; }
  .size-table th { padding: 20px; font-size: 0.75rem; font-weight: 800; text-transform: uppercase; letter-spacing: 0.1em; color: #1a1a1a; border-bottom: 1px solid #f4f4f4; }
  .size-table td { padding: 20px; font-size: 0.95rem; color: #666; border-bottom: 1px solid #f4f4f4; }
  .size-table tr:last-child td { border-bottom: none; }
  
  .size-footer { text-align: center; margin-top: 40px; font-size: 0.85rem; color: #999; line-height: 1.6; }
</style>

<section class="size-chart" id="SizeGuide">
  <div class="container">
    <div class="size-header">
      <span class="size-subtitle">{{ section.settings.subtitle | default: "Find the Perfect Fit" }}</span>
      <h2 class="size-title">{{ section.settings.title | default: "Size Guide" }}</h2>
    </div>

    <div class="size-tabs">
      <div class="size-tab active" data-tab="sleepbags">Sleep Bags</div>
      <div class="size-tab" data-tab="bodysuits">Bodysuits</div>
      <div class="size-tab" data-tab="pajamas">Pajamas</div>
    </div>

    <div class="size-table-wrap">
      <!-- Sleep Bags Table -->
      <div class="size-content" id="tab-sleepbags">
        <table class="size-table">
          <thead>
            <tr><th>Age</th><th>Height</th><th>Weight</th><th>TOG Recommendation</th></tr>
          </thead>
          <tbody>
            <tr><td>0-6 Months</td><td>23 - 27 in</td><td>10 - 18 lbs</td><td>1.0 TOG</td></tr>
            <tr><td>6-18 Months</td><td>27 - 33 in</td><td>18 - 26 lbs</td><td>1.0 or 2.5 TOG</td></tr>
            <tr><td>18-36 Months</td><td>33 - 38 in</td><td>26 - 35 lbs</td><td>1.0 or 2.5 TOG</td></tr>
          </tbody>
        </table>
      </div>
    </div>

    <div class="size-footer">
      <p>Measurements are intended as a guide. Bamboo fabric has a natural stretch for extra comfort.<br>Still unsure? <a href="/pages/contact" style="color:var(--color-primary); font-weight:700;">Chat with our styling team.</a></p>
    </div>
  </div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const tabs = document.querySelectorAll('.size-tab');
    tabs.forEach(tab => {
      tab.addEventListener('click', () => {
        tabs.forEach(t => t.classList.remove('active'));
        tab.classList.add('active');
        // In a real app, we'd swap the table data here
      });
    });
  });
</script>

{% schema %}
{
  "name": "Size Guide",
  "settings": [
    { "type": "text", "id": "subtitle", "label": "Subtitle", "default": "Find the Perfect Fit" },
    { "type": "text", "id": "title", "label": "Heading", "default": "Size Guide" }
  ],
  "presets": [{ "name": "Boutique Size Guide" }]
}
{% endschema %}
