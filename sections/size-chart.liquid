<style>
  .size-chart { padding: 80px 0; background: #fff; }
  .size-chart-header { text-align: center; margin-bottom: 50px; }
  .size-chart-title { font-family: var(--font-heading); font-size: 3rem; margin-bottom: 20px; }
  
  .table-wrap { overflow-x: auto; margin-top: 40px; border-radius: 20px; border: 1px solid #eee; }
  .size-table { width: 100%; border-collapse: collapse; min-width: 600px; }
  .size-table th { background: #FCF8F1; padding: 20px; text-align: left; font-size: 0.8rem; font-weight: 800; text-transform: uppercase; letter-spacing: 0.1em; border-bottom: 1px solid #eee; }
  .size-table td { padding: 20px; border-bottom: 1px solid #f9f9f9; font-size: 0.95rem; color: #666; }
  .size-table tr:last-child td { border-bottom: none; }
  .size-table tr:hover td { background: #fdfdfd; color: #1a1a1a; }
  
  .size-note { margin-top: 30px; font-size: 0.9rem; color: #888; font-style: italic; text-align: center; }
</style>

<section class="size-chart">
  <div class="container">
    <div class="size-chart-header">
      <h2 class="size-chart-title">Size Guide</h2>
      <p>Use the charts below to find the perfect fit for your little one. Our bamboo fabric has a generous stretch!</p>
    </div>

    <div class="table-wrap">
      <table class="size-table">
        <thead>
          <tr>
            <th>Size</th>
            <th>Weight (lbs)</th>
            <th>Height (in)</th>
            <th>Age (Approx)</th>
          </tr>
        </thead>
        <tbody>
          <tr><td>Preemie</td><td>Up to 5 lbs</td><td>Up to 17"</td><td>Newborn</td></tr>
          <tr><td>Newborn</td><td>5 - 8 lbs</td><td>17 - 21"</td><td>0 - 1 Month</td></tr>
          <tr><td>0-3 Months</td><td>8 - 12 lbs</td><td>21 - 24"</td><td>1 - 3 Months</td></tr>
          <tr><td>3-6 Months</td><td>12 - 16 lbs</td><td>24 - 26"</td><td>3 - 6 Months</td></tr>
          <tr><td>6-12 Months</td><td>16 - 22 lbs</td><td>26 - 30"</td><td>6 - 12 Months</td></tr>
          <tr><td>12-18 Months</td><td>22 - 27 lbs</td><td>30 - 33"</td><td>12 - 18 Months</td></tr>
          <tr><td>18-24 Months</td><td>27 - 31 lbs</td><td>33 - 35"</td><td>18 - 24 Months</td></tr>
        </tbody>
      </table>
    </div>

    <p class="size-note">Note: Bamboo fabric is extremely stretchy and intended to have a snug fit for safety.</p>
  </div>
</section>

{% schema %}
{ "name": "Size Chart Section", "settings": [], "presets": [{ "name": "Size Chart Section" }] }
{% endschema %}
