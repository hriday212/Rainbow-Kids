<style>
  .cart-drawer { position: fixed; top: 0; right: 0; width: 450px; height: 100%; background: #fff; z-index: 10001; box-shadow: -10px 0 40px rgba(0,0,0,0.1); transform: translateX(100%); transition: transform 0.5s cubic-bezier(0.19, 1, 0.22, 1); display: flex; flex-direction: column; }
  .cart-drawer.active { transform: translateX(0); }
  .cart-drawer__overlay { position: fixed; inset: 0; background: rgba(0,0,0,0.3); backdrop-filter: blur(5px); z-index: 10000; opacity: 0; pointer-events: none; transition: opacity 0.4s; }
  .cart-drawer__overlay.active { opacity: 1; pointer-events: all; }

  .cart-drawer__header { padding: 30px; border-bottom: 1px solid #f4f4f4; display: flex; justify-content: space-between; align-items: center; }
  .cart-drawer__title { font-family: var(--font-heading); font-size: 1.8rem; margin: 0; font-weight: 400; }
  .cart-drawer__close { background: none; border: none; font-size: 2rem; cursor: pointer; color: #ccc; }

  .cart-drawer__content { flex: 1; overflow-y: auto; padding: 30px; }
  
  /* Shipping Bar */
  .shipping-bar { background: #FCF8F1; padding: 20px; border-radius: 12px; margin-bottom: 30px; }
  .shipping-bar__msg { font-size: 0.85rem; font-weight: 700; color: #1a1a1a; margin-bottom: 12px; display: block; text-align: center; }
  .shipping-bar__track { width: 100%; height: 6px; background: #eee; border-radius: 3px; overflow: hidden; }
  .shipping-bar__progress { width: 0%; height: 100%; background: #1a1a1a; transition: width 1s cubic-bezier(0.19, 1, 0.22, 1); }

  .cart-drawer__footer { padding: 30px; border-top: 1px solid #f4f4f4; background: #fdfdfd; }
  .cart-drawer__subtotal { display: flex; justify-content: space-between; font-weight: 700; margin-bottom: 12px; font-size: 1.1rem; color: #1a1a1a; }
  .cart-drawer__checkout { width: 100%; padding: 20px; background: #1a1a1a; color: #fff; border-radius: 12px; font-weight: 800; text-transform: uppercase; letter-spacing: 0.15em; border: none; cursor: pointer; transition: all 0.3s; font-size: 0.85rem; }
  .cart-drawer__checkout:hover { background: #333; transform: translateY(-2px); box-shadow: 0 10px 30px rgba(0,0,0,0.1); }
  
  /* Upsell Styling */
  .cart-upsell { padding: 24px; border-top: 1px solid #f9f9f9; background: #fafafa; }
  .cart-upsell__title { font-size: 0.75rem; font-weight: 800; text-transform: uppercase; letter-spacing: 0.1em; color: #888; margin-bottom: 15px; }
  .upsell-card { display: flex; align-items: center; gap: 15px; background: #fff; padding: 12px; border-radius: 8px; border: 1px solid #eee; }
  .upsell-card__img { width: 60px; height: 60px; border-radius: 4px; overflow: hidden; flex-shrink: 0; }
  .upsell-card__img img { width: 100%; height: 100%; object-fit: cover; }
  .upsell-card__info { flex: 1; }
  .upsell-card__name { font-size: 0.85rem; font-weight: 700; color: #1a1a1a; margin: 0 0 5px; }
  .upsell-card__add { background: none; border: none; font-size: 0.75rem; font-weight: 800; color: #1a1a1a; text-decoration: underline; cursor: pointer; padding: 0; }
</style>

<div class="cart-drawer__overlay" id="CartOverlay"></div>
<div class="cart-drawer" id="CartDrawer">
  <div class="cart-drawer__header">
    <h2 class="cart-drawer__title">Your Bag</h2>
    <button class="cart-drawer__close" id="CartClose">&times;</button>
  </div>

  <div class="cart-drawer__content">
    <div class="shipping-bar">
      <span class="shipping-bar__msg" id="ShippingMessage">Spend more for FREE Shipping</span>
      <div class="shipping-bar__track">
        <div class="shipping-bar__progress" id="ShippingProgress"></div>
      </div>
    </div>

    <div id="CartContent" class="cart-drawer__items">
      <!-- Items loaded via Ajax (cart-logic.js) -->
    </div>
  </div>

  <!-- Complete the Look (Upsell) -->
  {%- assign upsell = section.settings.upsell_product -%}
  {%- if upsell != blank -%}
    <div class="cart-upsell">
      <h3 class="cart-upsell__title">{{ section.settings.upsell_title }}</h3>
      <div class="cart-upsell__list">
        <div class="upsell-card">
          <div class="upsell-card__img"><img src="{{ upsell.featured_image | image_url: width: 100 }}"></div>
          <div class="upsell-card__info">
            <p class="upsell-card__name">{{ upsell.title }}</p>
            <button class="upsell-card__add js-add-to-cart" data-variant-id="{{ upsell.selected_or_first_available_variant.id }}">+ Add {{ upsell.price | money }}</button>
          </div>
        </div>
      </div>
    </div>
  {%- endif -%}

  <div class="cart-drawer__footer">
    <div class="cart-drawer__subtotal">
      <span>Subtotal</span>
      <span id="CartSubtotal">$0.00</span>
    </div>
    <form action="/checkout" method="post">
      <button type="submit" class="cart-drawer__checkout">Checkout Now</button>
    </form>
  </div>
</div>

{% schema %}
{
  "name": "Cart Drawer",
  "settings": [
    { "type": "number", "id": "shipping_threshold", "label": "Free Shipping Threshold ($)", "default": 100 },
    { "type": "text", "id": "upsell_title", "label": "Upsell Title", "default": "Complete the look" },
    { "type": "product", "id": "upsell_product", "label": "Upsell Product" }
  ]
}
{% endschema %}
