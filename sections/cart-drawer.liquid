<style>
  .cart-drawer { position: fixed; inset: 0; z-index: 2000; visibility: hidden; opacity: 0; transition: all 0.4s var(--ease-smooth); }
  .cart-drawer.active { visibility: visible; opacity: 1; }
  
  .cart-drawer__overlay { position: absolute; inset: 0; background: rgba(0,0,0,0.3); backdrop-filter: blur(5px); }
  
  .cart-drawer__content { position: absolute; top: 0; right: -500px; width: 450px; height: 100%; background: #fff; transition: all 0.4s var(--ease-smooth); display: flex; flex-direction: column; }
  .cart-drawer.active .cart-drawer__content { right: 0; }
  
  .cart-drawer__header { padding: 30px; border-bottom: 1px solid #f4f4f4; display: flex; justify-content: space-between; align-items: center; }
  .cart-drawer__title { font-family: var(--font-heading); font-size: 1.5rem; margin: 0; }
  .cart-drawer__close { background: none; border: none; cursor: pointer; color: #1a1a1a; }
  .cart-drawer__close svg { width: 24px; height: 24px; }
  
  .cart-drawer__body { flex: 1; padding: 30px; overflow-y: auto; display: flex; flex-direction: column; }
  .cart-empty { text-align: center; margin: auto; }
  .cart-empty__icon { color: #f4f4f4; margin-bottom: 20px; }
  .cart-empty__icon svg { width: 80px; height: 80px; }
  .cart-empty__title { font-family: var(--font-heading); font-size: 1.4rem; color: #1a1a1a; margin-bottom: 15px; }
  
  .cart-drawer__footer { padding: 30px; border-top: 1px solid #f4f4f4; background: #fafafa; }
  .cart-total { display: flex; justify-content: space-between; margin-bottom: 25px; font-weight: 800; font-size: 1.1rem; }
  
  .checkout-btn { width: 100%; padding: 20px; background: var(--color-primary); color: #fff; border: none; border-radius: 50px; font-weight: 800; text-transform: uppercase; letter-spacing: 0.2em; font-size: 0.8rem; cursor: pointer; transition: all 0.3s; }
  .checkout-btn:hover { background: #ff7b52; transform: translateY(-3px); }

  @media (max-width: 480px) { .cart-drawer__content { width: 100%; } }
</style>

<div class="cart-drawer" id="CartDrawer">
  <div class="cart-drawer__overlay" onclick="toggleCart()"></div>
  <div class="cart-drawer__content">
    <div class="cart-drawer__header">
      <h2 class="cart-drawer__title">Your Boutique Bag</h2>
      <button class="cart-drawer__close" onclick="toggleCart()">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" /></svg>
      </button>
    </div>
    
    <div class="cart-drawer__body">
      {%- if cart.item_count == 0 -%}
        <div class="cart-empty">
          <div class="cart-empty__icon">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 10.5V6a3.75 3.75 0 1 0-7.5 0v4.5m11.356-1.993 1.263 12c.07.665-.45 1.243-1.119 1.243H4.25a1.125 1.125 0 0 1-1.12-1.243l1.264-12A1.125 1.125 0 0 1 5.513 7.5h12.974c.576 0 1.059.435 1.119 1.007ZM8.625 10.5a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Zm7.5 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Z" /></svg>
          </div>
          <h3 class="cart-empty__title">Your bag is empty</h3>
          <p style="color:#888; font-size:0.95rem; margin-bottom:30px;">Looks like you haven't added any boutique essentials yet.</p>
          <a href="/collections/all" class="boutique-link">Start Shopping</a>
        </div>
      {%- else -%}
        <!-- Cart items logic would go here -->
      {%- endif -%}
    </div>

    {%- if cart.item_count > 0 -%}
    <div class="cart-drawer__footer">
      <div class="cart-total">
        <span>Subtotal</span>
        <span>{{ cart.total_price | money }}</span>
      </div>
      <button class="checkout-btn">Checkout</button>
      <p style="text-align:center; font-size:0.75rem; color:#aaa; margin-top:15px; letter-spacing:0.05em;">TAXES & SHIPPING CALCULATED AT CHECKOUT</p>
    </div>
    {%- endif -%}
  </div>
</div>

<script>
  function toggleCart() {
    const drawer = document.getElementById('CartDrawer');
    drawer.classList.toggle('active');
  }
</script>

{% schema %}
{ "name": "Cart Drawer" }
{% endschema %}
