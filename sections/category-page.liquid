<style>
  .category-page { padding: 0 0 100px; background: #fff; }
  .cat-hero { padding: 80px 0 60px; text-align: center; background: #fdf8f6; margin-bottom: 60px; opacity: 1 !important; visibility: visible !important; }
  .cat-hero__subtitle { font-size: 0.75rem; font-weight: 800; text-transform: uppercase; letter-spacing: 0.2em; color: var(--color-primary); display: block; margin-bottom: 16px; }
  .cat-hero__title { font-family: var(--font-heading); font-size: 4rem; color: #1a1a1a; margin-bottom: 20px; }
  .cat-hero__text { font-size: 1.1rem; color: #888; max-width: 560px; margin: 0 auto 35px; line-height: 1.7; }
  .cat-hero__badges { display: flex; justify-content: center; gap: 12px; flex-wrap: wrap; }
  .cat-badge { padding: 8px 20px; background: #fff; border: 1.5px solid #f0f0f0; border-radius: 50px; font-size: 0.78rem; font-weight: 700; color: #666; display: flex; align-items: center; gap: 8px; }

  .cat-layout { display: grid; grid-template-columns: 260px 1fr; gap: 60px; }
  .cat-sidebar__section { margin-bottom: 36px; padding-bottom: 28px; border-bottom: 1px solid #f0f0f0; }
  .cat-sidebar__title { font-size: 0.7rem; font-weight: 800; text-transform: uppercase; letter-spacing: 0.15em; color: #1a1a1a; margin-bottom: 18px; display: block; }
  .cat-filter-link { display: flex; align-items: center; justify-content: space-between; padding: 9px 0; font-size: 0.92rem; color: #666; text-decoration: none; transition: color 0.2s; border-radius: 6px; }
  .cat-filter-link:hover, .cat-filter-link.active { color: var(--color-primary); font-weight: 700; }
  .cat-filter-link.active::after { content: ''; width: 6px; height: 6px; border-radius: 50%; background: var(--color-primary); display: inline-block; }

  .cat-product-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 28px; }
  .cat-product-card { text-decoration: none; display: block; opacity: 1 !important; visibility: visible !important; }
  .cat-product-card__img { aspect-ratio: 4/5; border-radius: 16px; overflow: hidden; background: #f9f9f9; margin-bottom: 14px; position: relative; }
  .cat-product-card__img img, .cat-product-card__placeholder { width: 100%; height: 100%; object-fit: cover; }
  .cat-product-card__placeholder { display: flex; align-items: center; justify-content: center; background: #f4f4f4; color: #ddd; }
  .cat-product-badge { position: absolute; top: 12px; left: 12px; padding: 4px 12px; border-radius: 50px; font-size: 0.62rem; font-weight: 800; text-transform: uppercase; letter-spacing: 0.05em; }
  .badge--new { background: #B5EAD7; color: #1a1a1a; }
  .badge--sale { background: var(--color-primary); color: #fff; }
  .badge--bestseller { background: #FFD700; color: #1a1a1a; }

  @media (max-width: 1024px) { .cat-layout { grid-template-columns: 1fr; } .cat-product-grid { grid-template-columns: repeat(2, 1fr); } }
</style>

{% assign demo_products = "Bamboo Sleep Bag — Classic,Bamboo Sleep Bag — Floral,Bamboo Zip Pajama Set,Long-Sleeve Bodysuit,Newborn Starter Set,Convertible Sleep Bag" | split: "," %}
{% assign demo_prices = "$59.00,$65.00,$52.00,$38.00,$89.00,$72.00" | split: "," %}
{% assign demo_badges = "new,bestseller,new,,sale," | split: "," %}

<div class="category-page">
  <div class="cat-hero">
    <div class="container">
      <span class="cat-hero__subtitle">{{ section.settings.subtitle | default: "Rainbow Kids Hub" }}</span>
      <h1 class="cat-hero__title">{{ section.settings.title | default: collection.title | default: "Our Collection" }}</h1>
      <p class="cat-hero__text">{{ section.settings.description | default: "Crafted from 100% OEKO-TEX certified bamboo. Buttery soft, breathable, and designed for the dreamiest sleep — for babies, toddlers, and everyone in between." }}</p>
      <div class="cat-hero__badges">
        <span class="cat-badge">🌿 100% Organic Bamboo</span>
        <span class="cat-badge">🛡️ OEKO-TEX Certified</span>
        <span class="cat-badge">🚚 Free Shipping $85+</span>
      </div>
    </div>
  </div>

  <div class="container">
    <div class="cat-layout">
      <aside>
        <div class="cat-sidebar__section">
          <span class="cat-sidebar__title">Categories</span>
          <a href="/pages/sleep-bags" class="cat-filter-link {% if section.settings.active_page == 'sleep-bags' %}active{% endif %}">Sleep Bags</a>
          <a href="/pages/pajamas" class="cat-filter-link {% if section.settings.active_page == 'pajamas' %}active{% endif %}">Pajamas</a>
          <a href="/pages/bodysuits" class="cat-filter-link {% if section.settings.active_page == 'bodysuits' %}active{% endif %}">Bodysuits</a>
          <a href="/pages/newborn" class="cat-filter-link {% if section.settings.active_page == 'newborn' %}active{% endif %}">Newborn</a>
          <a href="/pages/baby" class="cat-filter-link {% if section.settings.active_page == 'baby' %}active{% endif %}">Baby</a>
          <a href="/pages/toddler" class="cat-filter-link {% if section.settings.active_page == 'toddler' %}active{% endif %}">Toddler</a>
        </div>
      </aside>

      <main>
        <div class="cat-product-grid">
          {%- assign target = section.settings.collection | default: collection -%}
          {%- if target.products.size > 0 -%}
            {%- for product in target.products -%}
              <a href="{{ product.url }}" class="cat-product-card">
                <div class="cat-product-card__img">
                  {%- if product.featured_image -%}
                    <img src="{{ product.featured_image | image_url: width: 800 }}" alt="{{ product.title }}">
                  {%- else -%}
                    <div class="cat-product-card__placeholder">{{ 'product-1' | placeholder_svg_tag }}</div>
                  {%- endif -%}
                </div>
                <p style="font-family: var(--font-heading); font-size: 1.05rem; color: #1a1a1a; margin-bottom: 4px;">{{ product.title }}</p>
                <p style="font-weight: 700; color: var(--color-primary); font-size: 0.9rem;">{{ product.price | money }}</p>
              </a>
            {%- endfor -%}
          {%- else -%}
            {%- for i in (1..6) -%}
              {%- assign di = forloop.index0 -%}
              <div class="cat-product-card">
                <div class="cat-product-card__img">
                  <div class="cat-product-card__placeholder">{{ 'product-' | append: i | placeholder_svg_tag }}</div>
                  {%- assign pbadge = demo_badges[di] -%}
                  {%- if pbadge != blank -%}<span class="cat-product-badge badge--{{ pbadge }}">{{ pbadge }}</span>{%- endif -%}
                </div>
                <p style="font-family: var(--font-heading); font-size: 1.05rem; color: #1a1a1a; margin-bottom: 4px;">{{ demo_products[di] }}</p>
                <p style="font-weight: 700; color: var(--color-primary); font-size: 0.9rem;">{{ demo_prices[di] }}</p>
              </div>
            {%- endfor -%}
          {%- endif -%}
        </div>
      </main>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Category Page",
  "settings": [
    { "type": "text", "id": "subtitle", "label": "Subtitle", "default": "Rainbow Kids Hub" },
    { "type": "text", "id": "title", "label": "Page Heading", "default": "Our Collection" },
    { "type": "textarea", "id": "description", "label": "Page Description" },
    { "type": "collection", "id": "collection", "label": "Linked Collection" },
    { "type": "select", "id": "active_page", "label": "Active Sidebar Category", "options": [
        { "value": "none", "label": "None" }, { "value": "sleep-bags", "label": "Sleep Bags" }, { "value": "pajamas", "label": "Pajamas" }, { "value": "bodysuits", "label": "Bodysuits" }, { "value": "newborn", "label": "Newborn" }, { "value": "baby", "label": "Baby" }, { "value": "toddler", "label": "Toddler" }
      ], "default": "none" }
  ]
}
{% endschema %}
