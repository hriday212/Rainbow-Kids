<style>
  .product-page { padding: 60px 0; background: #fff; }
  .product-layout { display: grid; grid-template-columns: 1.2fr 1fr; gap: 80px; }
  
  .product-media { position: sticky; top: 120px; }
  .product-img-wrap { border-radius: 24px; overflow: hidden; background: #f9f9f9; aspect-ratio: 4/5; }
  .product-img { width: 100%; height: 100%; object-fit: cover; }
  
  .product-info { padding: 20px 0; }
  .product-vendor { font-size: 0.75rem; font-weight: 800; text-transform: uppercase; letter-spacing: 0.15em; color: var(--color-primary); margin-bottom: 10px; display: block; }
  .product-title { font-family: var(--font-heading); font-size: 3rem; color: #1a1a1a; margin-bottom: 15px; }
  .product-price { font-size: 1.5rem; font-weight: 700; color: #1a1a1a; margin-bottom: 30px; display: block; }
  
  .product-description { font-size: 1rem; line-height: 1.8; color: #666; margin-bottom: 40px; }
  
  .add-to-cart-btn { width: 100%; padding: 20px; background: var(--color-primary); color: #fff; border: none; border-radius: 50px; font-weight: 800; text-transform: uppercase; letter-spacing: 0.1em; cursor: pointer; transition: all 0.3s; }
  .add-to-cart-btn:hover { transform: scale(1.02); box-shadow: 0 15px 30px rgba(255,140,105,0.2); }

  @media (max-width: 1024px) { .product-layout { grid-template-columns: 1fr; } .product-media { position: relative; top: 0; } }
</style>

<section class="product-page">
  <div class="container">
    <div class="product-layout">
      <!-- Media -->
      <div class="product-media">
        <div class="product-img-wrap">
          {% if product.featured_image != blank %}
            <img src="{{ product.featured_image | image_url: width: 1200 }}" class="product-img">
          {% else %}
            <div class="product-placeholder" style="width:100%; height:100%; display:flex; align-items:center; justify-content:center; background:#f4f4f4; color:#ccc;">
              {{ 'product-1' | placeholder_svg_tag }}
            </div>
          {% endif %}
        </div>
      </div>

      <!-- Info -->
      <div class="product-info">
        <span class="product-vendor">{{ product.vendor | default: "Rainbow Kids Hub" }}</span>
        <h1 class="product-title">{{ product.title | default: "Bamboo Sleep Bag" }}</h1>
        <span class="product-price">{{ product.price | money | default: "$55.00" }}</span>
        
        <div class="product-description">
          {{ product.description | default: "Experience the ultimate in baby comfort with our signature bamboo apparel. Breathable, hypoallergenic, and buttery soft." }}
        </div>

        <button class="add-to-cart-btn">Add to Cart</button>
        
        <div style="margin-top:40px; border-top:1px solid #eee; padding-top:40px;">
          <p style="font-size:0.8rem; font-weight:800; text-transform:uppercase; color:#1a1a1a; margin-bottom:15px;">Shipping & Returns</p>
          <p style="font-size:0.9rem; color:#888;">Free shipping on orders over $85. 30-day easy returns for all unworn items.</p>
        </div>
      </div>
    </div>
  </div>
</section>

{% schema %}
{ "name": "Main Product", "settings": [] }
{% endschema %}
