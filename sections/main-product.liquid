<style>
  .product-section { padding: 60px 0 100px; background: #fff; }
  .product-grid { display: grid; grid-template-columns: 1.1fr 0.9fr; gap: 60px; align-items: start; }
  
  /* Gallery with Wipe Effect */
  .product-gallery { position: sticky; top: 100px; display: flex; flex-direction: column; gap: 20px; }
  
  .product-gallery__main-wrapper { position: relative; aspect-ratio: 4/5; overflow: hidden; border-radius: 12px; background: #FDFBFF; }
  .product-gallery__main-img { width: 100%; height: 100%; object-fit: cover; position: absolute; top: 0; left: 0; }
  
  /* Wipe Animation Layer */
  .wipe-layer {
    position: absolute; inset: 0; z-index: 2;
    clip-path: inset(0 100% 0 0);
    transition: clip-path 0.8s cubic-bezier(0.19, 1, 0.22, 1);
    background: #fff;
  }
  .wipe-layer img { width: 100%; height: 100%; object-fit: cover; }
  .wipe-active .wipe-layer { clip-path: inset(0 0 0 0); }

  .product-gallery__thumbs { display: flex; gap: 12px; overflow-x: auto; padding-bottom: 10px; }
  .product-gallery__thumb { flex-shrink: 0; width: 90px; height: 110px; border-radius: 8px; overflow: hidden; border: 1.5px solid transparent; cursor: pointer; transition: all 0.3s; opacity: 0.7; }
  .product-gallery__thumb--active { border-color: #1a1a1a; opacity: 1; }
  .product-gallery__thumb img { width: 100%; height: 100%; object-fit: cover; }
  
  /* Info Area */
  .product-info { display: flex; flex-direction: column; gap: 24px; padding-top: 10px; }
  .product-breadcrumb { font-size: 0.7rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.15em; color: #aaa; margin-bottom: 10px; }
  .product-breadcrumb a { color: inherit; text-decoration: none; }
  .product-breadcrumb a:hover { color: #000; }

  .product-info__title { font-family: var(--font-heading); font-size: 3rem; font-weight: 400; color: var(--color-text-dark); margin: 0; line-height: 1.1; }
  
  .product-info__rating { display: flex; align-items: center; gap: 10px; }
  .product-info__stars { color: #1a1a1a; display: flex; gap: 2px; }
  .product-info__stars svg { width: 16px; height: 16px; fill: currentColor; }
  .review-count { font-size: 0.85rem; color: #888; font-weight: 500; }

  .product-info__price { font-size: 1.6rem; font-weight: 700; color: var(--color-text-dark); margin: 10px 0; }
  .product-info__price s { opacity: 0.3; margin-right: 15px; font-weight: 400; font-size: 1.2rem; }

  .product-option { display: flex; flex-direction: column; gap: 12px; margin-top: 10px; }
  .product-option__label { font-size: 0.75rem; font-weight: 800; text-transform: uppercase; letter-spacing: 0.1em; color: var(--color-text-dark); }
  .product-option__list { display: flex; flex-wrap: wrap; gap: 12px; }
  
  /* Swatches */
  .swatch { width: 36px; height: 36px; border-radius: 50%; border: 1.5px solid #eee; cursor: pointer; transition: all 0.2s; position: relative; padding: 2px; }
  .swatch__inner { width: 100%; height: 100%; border-radius: 50%; }
  .swatch.active { border-color: #1a1a1a; transform: scale(1.1); }
  
  /* Sizes */
  .size-btn { padding: 12px 28px; border-radius: 8px; border: 1.5px solid #eee; background: #fff; font-size: 0.85rem; font-weight: 700; cursor: pointer; transition: all 0.2s; color: var(--color-text-dark); }
  .size-btn.active { background: #1a1a1a; color: #fff; border-color: #1a1a1a; }
  
  /* TOG Badge */
  .tog-badge { display: inline-flex; align-items: center; gap: 8px; background: #f4f4f4; padding: 10px 20px; border-radius: 8px; font-size: 0.8rem; font-weight: 700; color: #555; align-self: flex-start; }

  .product-form { display: flex; flex-direction: column; gap: 20px; margin-top: 30px; }
  .add-to-bag-btn { width: 100%; padding: 22px; border-radius: 12px; border: none; background: #1a1a1a; color: #fff; font-size: 0.9rem; font-weight: 800; text-transform: uppercase; letter-spacing: 0.15em; cursor: pointer; transition: all 0.3s; }
  .add-to-bag-btn:hover { background: #333; transform: translateY(-2px); box-shadow: 0 15px 35px rgba(0,0,0,0.15); }
  .add-to-bag-btn:disabled { opacity: 0.5; cursor: not-allowed; transform: none; }

  /* Accordions */
  .product-accordions { border-top: 1px solid #eee; margin-top: 40px; }
  .accordion { border-bottom: 1px solid #eee; }
  .accordion__header { padding: 22px 0; display: flex; justify-content: space-between; align-items: center; cursor: pointer; font-weight: 800; text-transform: uppercase; font-size: 0.75rem; letter-spacing: 0.1em; color: var(--color-text-dark); }
  .accordion__icon { font-size: 1.2rem; transition: transform 0.3s; }
  .accordion.active .accordion__icon { transform: rotate(45deg); }
  .accordion__content { padding: 0 0 22px; font-size: 0.95rem; color: #666; line-height: 1.8; display: none; }
  .accordion.active .accordion__content { display: block; }

  @media (max-width: 1024px) {
    .product-grid { grid-template-columns: 1fr; gap: 40px; }
    .product-gallery { position: relative; top: 0; }
    .product-info__title { font-size: 2.5rem; }
  }
</style>

<section class="product-section">
  <div class="container product-grid">
    
    <!-- Gallery -->
    <div class="product-gallery">
      <div class="product-gallery__main-wrapper" id="MainGalleryWrapper">
        <img id="MainImg" src="{{ product.featured_image | image_url: width: 1400 }}" class="product-gallery__main-img" alt="{{ product.title }}">
        <div class="wipe-layer" id="WipeLayer">
          <img src="" id="WipeImg" alt="Wipe Effect">
        </div>
      </div>
      
      {%- if product.images.size > 1 -%}
        <div class="product-gallery__thumbs">
          {%- for image in product.images -%}
            <div class="product-gallery__thumb {% if forloop.first %}product-gallery__thumb--active{% endif %}" 
                 onclick="performWipe('{{ image | image_url: width: 1400 }}', this)">
              <img src="{{ image | image_url: width: 300 }}" alt="{{ image.alt | escape }}">
            </div>
          {%- endfor -%}
        </div>
      {%- endif -%}
    </div>

    <!-- Info -->
    <div class="product-info">
      <nav class="product-breadcrumb">
        <a href="/">Home</a> <span>/</span> 
        <a href="/collections/all">Shop</a> <span>/</span> 
        {{ product.title }}
      </nav>
      
      <h1 class="product-info__title">{{ product.title }}</h1>
      
      <div class="product-info__rating">
        <div class="product-info__stars">
          {%- for i in (1..5) -%}
            <svg viewBox="0 0 20 20"><path d="M10 1l2.6 6.3h6.4l-5.2 4.4 2 6.3-5.8-4-5.8 4 2-6.3-5.2-4.4h6.4z"/></svg>
          {%- endfor -%}
        </div>
        <span class="review-count">27,455 reviews</span>
      </div>
      
      <div class="product-info__price">
        {%- if product.compare_at_price > product.price -%}
          <s>{{ product.compare_at_price | money }}</s>
        {%- endif -%}
        {{ product.price | money }}
      </div>
      
      <div class="tog-badge">
        <span>☁️</span> 1.0 TOG Rating — Ideal for 21-23°C
      </div>

      {%- form 'product', product -%}
        <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">

        {%- for option in product.options_with_values -%}
          <div class="product-option">
            <span class="product-option__label">{{ option.name }}: <span style="font-weight:500; opacity:0.6;">{{ option.selected_value }}</span></span>
            <div class="product-option__list">
              {%- if option.name == 'Color' or option.name == 'Colour' -%}
                {%- for value in option.values -%}
                  <div class="swatch {% if option.selected_value == value %}active{% endif %}" title="{{ value }}">
                    <div class="swatch__inner" style="background-color: {{ value | handleize }};"></div>
                  </div>
                {%- endfor -%}
              {%- else -%}
                {%- for value in option.values -%}
                  <button type="button" class="size-btn {% if option.selected_value == value %}active{% endif %}">{{ value }}</button>
                {%- endfor -%}
              {%- endif -%}
            </div>
          </div>
        {%- endfor -%}

        <div class="product-form">
          <button type="submit" class="add-to-bag-btn" {% unless product.available %}disabled{% endunless %}>
            {%- if product.available -%}Add to Bag{%- else -%}Sold Out{%- endif -%}
          </button>
        </div>
      {%- endform -%}

      <div class="product-accordions">
        <div class="accordion active">
          <div class="accordion__header" onclick="this.parentElement.classList.toggle('active')">Description <span class="accordion__icon">+</span></div>
          <div class="accordion__content">
            {{ product.description }}
          </div>
        </div>
        <div class="accordion">
          <div class="accordion__header" onclick="this.parentElement.classList.toggle('active')">Fabric & Care <span class="accordion__icon">+</span></div>
          <div class="accordion__content">
            Our signature bamboo fabric is soft on baby's skin and gentle on the planet. 97% Bamboo Rayon, 3% Spandex. Machine wash cold on delicate cycle. Tumble dry low or hang dry.
          </div>
        </div>
        <div class="accordion">
          <div class="accordion__header" onclick="this.parentElement.classList.toggle('active')">Shipping & Returns <span class="accordion__icon">+</span></div>
          <div class="accordion__content">
            Free shipping on orders over $100. We offer a 45-day return policy for unwashed and unworn items in original packaging.
          </div>
        </div>
      </div>
    </div>

  </div>
</section>

<script>
  function performWipe(newSrc, thumb) {
    const wrapper = document.getElementById('MainGalleryWrapper');
    const mainImg = document.getElementById('MainImg');
    const wipeImg = document.getElementById('WipeImg');
    const wipeLayer = document.getElementById('WipeLayer');

    if (mainImg.src === newSrc) return;

    // Set new image to the hidden wipe layer
    wipeImg.src = newSrc;
    
    // Reset wipe layer and trigger animation
    wrapper.classList.remove('wipe-active');
    void wrapper.offsetWidth; // Force reflow
    wrapper.classList.add('wipe-active');

    // After animation, update the main image and reset
    setTimeout(() => {
      mainImg.src = newSrc;
      wrapper.classList.remove('wipe-active');
    }, 850);

    // Update thumbs
    document.querySelectorAll('.product-gallery__thumb').forEach(t => t.classList.remove('product-gallery__thumb--active'));
    thumb.classList.add('product-gallery__thumb--active');
  }
</script>

{% schema %}
{
  "name": "Product Information",
  "settings": []
}
{% endschema %}
