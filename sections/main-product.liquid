<style>
  .product-section { padding: 40px 0 100px; background: #fff; }
  .product-grid { display: grid; grid-template-columns: 1.2fr 1fr; gap: 80px; align-items: start; }
  
  /* Gallery */
  .product-gallery { position: sticky; top: 120px; display: flex; flex-direction: column; gap: 12px; }
  .product-gallery__main { border-radius: var(--radius-soft); overflow: hidden; background: #f9f9f9; aspect-ratio: 1/1; }
  .product-gallery__main img { width: 100%; height: 100%; object-fit: cover; }
  .product-gallery__thumbs { display: flex; gap: 10px; overflow-x: auto; }
  .product-gallery__thumb { flex-shrink: 0; width: 80px; height: 80px; border-radius: 8px; overflow: hidden; border: 2px solid transparent; cursor: pointer; }
  .product-gallery__thumb--active { border-color: var(--color-primary); }
  .product-gallery__thumb img { width: 100%; height: 100%; object-fit: cover; }
  
  /* Info */
  .product-info { display: flex; flex-direction: column; gap: 24px; }
  .product-info__title { font-size: 2.8rem; margin: 0; }
  .product-info__stars { color: #FFB800; font-size: 0.9rem; letter-spacing: 2px; }
  .product-info__price { font-size: 1.5rem; font-weight: 700; color: var(--color-text-dark); }
  
  .product-option { display: flex; flex-direction: column; gap: 12px; }
  .product-option__label { font-size: 0.8rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em; }
  .product-option__list { display: flex; flex-wrap: wrap; gap: 10px; }
  
  .swatch { width: 32px; height: 32px; border-radius: 50%; border: 2px solid #fff; box-shadow: 0 0 0 1px #eee; cursor: pointer; transition: transform 0.2s; }
  .swatch.active { box-shadow: 0 0 0 2px var(--color-text-dark); }
  
  .size-btn { padding: 10px 24px; border-radius: var(--radius-pill); border: 1.5px solid #eee; background: #fff; font-size: 0.9rem; font-weight: 600; cursor: pointer; transition: all 0.2s; }
  .size-btn.active { background: var(--color-text-dark); color: #fff; border-color: var(--color-text-dark); }
  
  .product-form { display: flex; flex-direction: column; gap: 20px; margin-top: 20px; }
  .qty-selector { display: flex; align-items: center; border: 1.5px solid #eee; border-radius: var(--radius-pill); width: fit-content; overflow: hidden; }
  .qty-btn { padding: 12px 20px; background: none; border: none; cursor: pointer; font-size: 1.2rem; }
  .qty-input { width: 40px; border: none; text-align: center; font-weight: 700; background: transparent; }

  /* Tabs */
  .product-tabs { border-top: 1px solid #eee; margin-top: 40px; }
  .product-tab { border-bottom: 1px solid #eee; }
  .product-tab__header { padding: 20px 0; display: flex; justify-content: space-between; align-items: center; cursor: pointer; font-weight: 700; text-transform: uppercase; font-size: 0.8rem; letter-spacing: 0.05em; }
  .product-tab__content { padding: 0 0 20px; font-size: 0.95rem; color: var(--color-text-light); line-height: 1.7; display: none; }
  .product-tab.active .product-tab__content { display: block; }

  @media (max-width: 860px) {
    .product-grid { grid-template-columns: 1fr; gap: 40px; }
    .product-gallery { position: relative; top: 0; }
    .product-info__title { font-size: 2.2rem; }
  }
</style>

<section class="product-section">
  <div class="container product-grid">
    
    <!-- Gallery -->
    <div class="product-gallery">
      <div class="product-gallery__main">
        <img id="MainProductImg" src="{{ product.featured_image | image_url: width: 1200 }}" alt="{{ product.title | escape }}">
      </div>
      {%- if product.images.size > 1 -%}
        <div class="product-gallery__thumbs">
          {%- for image in product.images -%}
            <div class="product-gallery__thumb {% if forloop.first %}product-gallery__thumb--active{% endif %}" onclick="updateGallery('{{ image | image_url: width: 1200 }}', this)">
              <img src="{{ image | image_url: width: 200 }}" alt="{{ image.alt | escape }}">
            </div>
          {%- endfor -%}
        </div>
      {%- endif -%}
    </div>

    <!-- Info -->
    <div class="product-info">
      <div class="product-breadcrumb" style="font-size: 0.75rem; color: #999; text-transform: uppercase; letter-spacing: 0.1em;">
        <a href="/">Home</a> / <a href="/collections/all">Shop</a> / {{ product.title }}
      </div>
      
      <h1 class="product-info__title">{{ product.title }}</h1>
      
      <div class="product-info__rating">
        <span class="product-info__stars">★★★★★</span>
        <span style="color:#999; margin-left:8px;">Based on {{ product.id | modulo: 1000 | plus: 500 }} reviews</span>
      </div>
      
      <div class="product-info__price">
        {%- if product.compare_at_price > product.price -%}
          <s style="opacity:0.5; margin-right: 12px;">{{ product.compare_at_price | money }}</s>
        {%- endif -%}
        {{ product.price | money }}
      </div>
      
      {%- form 'product', product -%}
        <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">

        {%- for option in product.options_with_values -%}
          <div class="product-option">
            <span class="product-option__label">{{ option.name }}: <span style="font-weight:400;">{{ option.selected_value }}</span></span>
            <div class="product-option__list">
              {%- if option.name == 'Color' or option.name == 'Colour' -%}
                {%- for value in option.values -%}
                  <div class="swatch {% if option.selected_value == value %}active{% endif %}" title="{{ value }}" style="background-color: {{ value | handleize }};"></div>
                {%- endfor -%}
              {%- else -%}
                {%- for value in option.values -%}
                  <button type="button" class="size-btn {% if option.selected_value == value %}active{% endif %}">{{ value }}</button>
                {%- endfor -%}
              {%- endif -%}
            </div>
          </div>
        {%- endfor -%}

        <div class="product-form">
          <div class="qty-selector">
            <button type="button" class="qty-btn" onclick="updateQty(-1)">−</button>
            <input type="text" id="ProductQty" name="quantity" class="qty-input" value="1" readonly>
            <button type="button" class="qty-btn" onclick="updateQty(1)">+</button>
          </div>
          <button type="submit" class="button" style="width: 100%; padding: 18px;" {% unless product.available %}disabled{% endunless %}>
            {%- if product.available -%}Add to Bag{%- else -%}Sold Out{%- endif -%}
          </button>
        </div>
      {%- endform -%}

      <div class="product-tabs">
        <div class="product-tab active">
          <div class="product-tab__header" onclick="toggleTab(this)">Description <span>+</span></div>
          <div class="product-tab__content">
            {{ product.description }}
          </div>
        </div>
        {%- if product.metafields.custom.fabric_care -%}
          <div class="product-tab">
            <div class="product-tab__header" onclick="toggleTab(this)">Fabric & Care <span>+</span></div>
            <div class="product-tab__content">{{ product.metafields.custom.fabric_care }}</div>
          </div>
        {%- endif -%}
      </div>
    </div>

  </div>
</section>

<script>
  function updateGallery(src, thumb) {
    document.getElementById('MainProductImg').src = src;
    document.querySelectorAll('.product-gallery__thumb').forEach(t => t.classList.remove('product-gallery__thumb--active'));
    thumb.classList.add('product-gallery__thumb--active');
  }
  function updateQty(delta) {
    const input = document.getElementById('ProductQty');
    input.value = Math.max(1, parseInt(input.value) + delta);
  }
  function toggleTab(header) {
    header.parentElement.classList.toggle('active');
  }
</script>

{% schema %}
{
  "name": "Product Information",
  "settings": []
}
{% endschema %}
