<style>
  .testimonials { padding: 100px 0; background: var(--color-background); overflow: hidden; }
  .test-header { text-align: center; margin-bottom: 60px; }
  .test-title { font-family: var(--font-heading); font-size: 3rem; color: #1a1a1a; }
  
  .test-slider { display: flex; gap: 40px; overflow-x: auto; padding: 20px; scroll-snap-type: x mandatory; scrollbar-width: none; }
  .test-slider::-webkit-scrollbar { display: none; }
  
  .test-card { flex: 0 0 400px; background: #fff; padding: 40px; border-radius: 24px; scroll-snap-align: center; box-shadow: 0 10px 40px rgba(0,0,0,0.03); }
  .test-stars { color: #FFB800; font-size: 1.2rem; margin-bottom: 20px; display: block; }
  .test-quote { font-size: 1.1rem; line-height: 1.8; color: #444; margin-bottom: 30px; font-style: italic; }
  .test-author { font-weight: 800; font-size: 0.85rem; text-transform: uppercase; letter-spacing: 0.1em; color: #1a1a1a; }
  .test-status { font-size: 0.75rem; color: #999; display: block; margin-top: 5px; }

  @media (max-width: 768px) { .test-card { flex: 0 0 300px; } }
</style>

<section class="testimonials">
  <div class="container">
    <div class="test-header">
      <h2 class="test-title">{{ section.settings.title | default: "Loved by Parents" }}</h2>
    </div>

    <div class="test-slider">
      {%- for i in (1..5) -%}
        <div class="test-card animate-reveal">
          <span class="test-stars">★★★★★</span>
          <p class="test-quote">"The softest bamboo I've ever felt. My little one sleeps so much better in these bags. The colors are even more beautiful in person!"</p>
          <div class="test-footer">
            <span class="test-author">Sarah M.</span>
            <span class="test-status">Verified Mama</span>
          </div>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Testimonials",
  "settings": [
    { "type": "text", "id": "title", "label": "Heading", "default": "Loved by Parents" }
  ],
  "presets": [
    { "name": "Boutique Testimonials" }
  ]
}
{% endschema %}
