<style>
  .testimonials { padding: 100px 0; background: var(--color-background); overflow: hidden; }
  .testimonials__header { text-align: center; margin-bottom: 80px; }
  
  .testimonials__grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 30px; }
  
  .testimonial-card { background: #fff; padding: 40px; border-radius: 24px; box-shadow: 0 10px 40px rgba(0,0,0,0.03); display: flex; flex-direction: column; gap: 20px; transition: all 0.4s var(--ease-smooth); border: 1px solid #f4f4f4; }
  .testimonial-card:hover { transform: translateY(-12px); box-shadow: 0 20px 60px rgba(0,0,0,0.08); border-color: var(--color-primary); }
  
  .testimonial-card__google { display: flex; align-items: center; gap: 8px; font-size: 0.75rem; font-weight: 800; color: #4285F4; text-transform: uppercase; letter-spacing: 0.08em; }
  .testimonial-card__stars { color: #FFB800; font-size: 0.9rem; letter-spacing: 2px; }
  .testimonial-card__text { font-size: 1.05rem; line-height: 1.8; color: var(--color-text-dark); font-style: italic; }
  .testimonial-card__footer { display: flex; flex-direction: column; gap: 4px; margin-top: auto; }
  .testimonial-card__author { font-weight: 800; font-size: 0.9rem; text-transform: uppercase; letter-spacing: 0.05em; color: var(--color-text-dark); }
  .testimonial-card__date { font-size: 0.75rem; color: #999; }

  .testimonials__footer { text-align: center; margin-top: 60px; }
  .google-review-btn { display: inline-flex; align-items: center; gap: 12px; background: #fff; border: 2.5px solid #eee; padding: 18px 36px; border-radius: var(--radius-pill); font-weight: 800; font-size: 0.9rem; transition: all 0.3s; color: var(--color-text-dark); text-decoration: none; text-transform: uppercase; letter-spacing: 0.1em; }
  .google-review-btn:hover { border-color: #4285F4; color: #4285F4; transform: scale(1.05); }

  @media (max-width: 1024px) { .testimonials__grid { grid-template-columns: 1fr 1fr; } }
  @media (max-width: 768px) { .testimonials__grid { grid-template-columns: 1fr; } }
</style>

<section class="testimonials">
  <div class="container">
    
    <div class="testimonials__header" data-aos="fade-up">
      <span class="section-tag">{{ section.settings.tag | default: 'Social Proof' }}</span>
      <h2 style="font-size: 3.5rem;">{{ section.settings.title | default: 'Trusted by 10,000+ Mamas' }}</h2>
    </div>

    <div class="testimonials__grid">
      {%- if section.blocks.size > 0 -%}
        {%- for block in section.blocks -%}
          <div class="testimonial-card" data-aos="fade-up" data-aos-delay="{{ forloop.index | times: 100 }}" {{ block.shopify_attributes }}>
            <div class="testimonial-card__google">
              <img src="https://upload.wikimedia.org/wikipedia/commons/c/c1/Google_logo_alphanumeric_2015.svg" style="height: 14px;" alt="Google">
              {{ block.settings.label | default: 'Verified Review' }}
            </div>
            <div class="testimonial-card__stars">
              {%- for i in (1..block.settings.stars) -%}★{%- endfor -%}
            </div>
            <p class="testimonial-card__text">"{{ block.settings.text | default: 'Absolutely love the quality of these sleep bags. Highly recommend!' }}"</p>
            <div class="testimonial-card__footer">
              <span class="testimonial-card__author">— {{ block.settings.author | default: 'Happy Parent' }}</span>
              {%- if block.settings.date != blank -%}
                <span class="testimonial-card__date">{{ block.settings.date }}</span>
              {%- endif -%}
            </div>
          </div>
        {%- endfor -%}
      {%- else -%}
        {%- comment -%} Fallback Demo Mode {%- endcomment -%}
        {%- for i in (1..3) -%}
          <div class="testimonial-card">
            <div class="testimonial-card__google">Verified Review</div>
            <div class="testimonial-card__stars">★★★★★</div>
            <p class="testimonial-card__text">"Best baby purchase ever! The fabric is so soft."</p>
            <span class="testimonial-card__author">— Customer {{ i }}</span>
          </div>
        {%- endfor -%}
      {%- endif -%}
    </div>

    <div class="testimonials__footer" data-aos="fade-up">
      <a href="{{ section.settings.google_link | default: 'https://share.google/3KW7AdBGh5ncM2c52' }}" class="google-review-btn" target="_blank">
        <img src="https://upload.wikimedia.org/wikipedia/commons/c/c1/Google_logo_alphanumeric_2015.svg" style="height: 18px;" alt="Google">
        {{ section.settings.button_label | default: 'View all Google Reviews' }}
      </a>
    </div>

  </div>
</section>

{% schema %}
{
  "name": "Testimonials",
  "settings": [
    { "type": "text", "id": "tag", "label": "Eyebrow Label", "default": "Social Proof" },
    { "type": "text", "id": "title", "label": "Heading", "default": "Trusted by 10,000+ Mamas" },
    { "type": "url", "id": "google_link", "label": "Google Maps Review Link" },
    { "type": "text", "id": "button_label", "label": "Button Label", "default": "View all Google Reviews" }
  ],
  "blocks": [
    {
      "type": "testimonial",
      "name": "Testimonial",
      "settings": [
        { "type": "text", "id": "label", "label": "Review Label", "default": "Verified Review" },
        { "type": "range", "id": "stars", "min": 1, "max": 5, "step": 1, "default": 5, "label": "Star Rating" },
        { "type": "textarea", "id": "text", "label": "Review Text" },
        { "type": "text", "id": "author", "label": "Author Name" },
        { "type": "text", "id": "date", "label": "Date (Optional)", "placeholder": "2 days ago" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Verified Testimonials",
      "blocks": [
        { "type": "testimonial" },
        { "type": "testimonial" },
        { "type": "testimonial" }
      ]
    }
  ]
}
{% endschema %}
