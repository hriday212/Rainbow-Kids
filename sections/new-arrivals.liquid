<style>
  .new-arrivals { padding: 120px 0; background: linear-gradient(to right, #CDE7F0, #DFF5E1); position: relative; overflow: hidden; margin: 40px 0; border-radius: 60px; }
  .new-arrivals__header { text-align: center; margin-bottom: 60px; }
  .new-arrivals__title { font-size: 3.5rem; margin-top: 10px; color: var(--color-text-dark); }
  
  .new-arrivals__grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 20px; }
  
  .arrival-card { background: #fff; padding: 20px; border-radius: 32px; text-decoration: none; display: flex; flex-direction: column; align-items: center; text-align: center; transition: all 0.5s var(--ease-smooth); box-shadow: 0 10px 40px rgba(0,0,0,0.05); }
  .arrival-card:hover { transform: translateY(-15px); box-shadow: 0 20px 60px rgba(0,0,0,0.1); }
  
  .arrival-card__image { width: 100%; aspect-ratio: 1/1; border-radius: 20px; overflow: hidden; margin-bottom: 20px; background: #f9f9f9; }
  .arrival-card__image img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.6s; }
  .arrival-card:hover img { transform: scale(1.1); }
  
  .arrival-card__title { font-size: 1.1rem; font-weight: 800; color: var(--color-text-dark); margin-bottom: 8px; }
  .arrival-card__price { font-size: 1rem; color: var(--color-primary); font-weight: 700; filter: brightness(0.8); }

  @media (max-width: 1024px) { .new-arrivals__grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 600px) { .new-arrivals__grid { grid-template-columns: 1fr; } .new-arrivals { border-radius: 0; padding: 80px 0; } }
</style>

<section class="new-arrivals animate-reveal" data-aos="zoom-in">
  <div class="container">
    <div class="new-arrivals__header" data-aos="fade-up">
      <span class="section-tag">Recently trending</span>
      <h2 class="new-arrivals__title">New Arrivals</h2>
    </div>

    <div class="new-arrivals__grid">
      {%- assign collection = collections[section.settings.collection] -%}
      {%- if collection.products.size > 0 -%}
        {%- for product in collection.products limit: 4 -%}
          <a href="{{ product.url }}" class="arrival-card" data-aos="fade-up" data-aos-delay="{{ forloop.index | times: 100 }}">
            <div class="arrival-card__image">
              <img src="{{ product.featured_image | image_url: width: 600 }}" alt="{{ product.title }}">
            </div>
            <h3 class="arrival-card__title">{{ product.title }}</h3>
            <span class="arrival-card__price">{{ product.price | money }}</span>
          </a>
        {%- endfor -%}
      {%- else -%}
        {%- comment -%} Luxury Demo Mode {%- endcomment -%}
        {%- for i in (1..4) -%}
          <div class="arrival-card">
            <div class="arrival-card__image"><img src="https://images.unsplash.com/photo-1522771917710-2ee211117f77?q=80&w=400"></div>
            <h3 class="arrival-card__title">Bamboo Sleep Bag</h3>
            <span class="arrival-card__price">$35.00</span>
          </div>
        {%- endfor -%}
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "New Arrivals Section",
  "settings": [
    { "type": "collection", "id": "collection", "label": "Select Collection" }
  ],
  "presets": [{ "name": "New Arrivals Section" }]
}
{% endschema %}
