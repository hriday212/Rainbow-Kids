<style>
  .new-arrivals { padding: 100px 0; background: #fff; overflow: hidden; }
  .new-arrivals__header { text-align: center; margin-bottom: 60px; }
  .new-arrivals__title { font-family: var(--font-heading); font-size: 3.5rem; color: #1a1a1a; margin-bottom: 15px; font-weight: 400; }
  
  .swiper-container { padding-bottom: 60px !important; }
  .swiper-pagination-bullet-active { background: #1a1a1a !important; }
</style>

<section class="new-arrivals">
  <div class="container">
    <div class="new-arrivals__header animate-reveal">
      <h2 class="new-arrivals__title">{{ section.settings.title }}</h2>
      <a href="{{ section.settings.link }}" class="boutique-link">Shop the Collection</a>
    </div>

    <div class="swiper newArrivalsSwiper">
      <div class="swiper-wrapper">
        {%- assign collection = section.settings.collection -%}
        {%- if collection != blank -%}
          {%- for product in collection.products limit: 10 -%}
            <div class="swiper-slide">
              <a href="{{ product.url }}" class="product-card" style="text-decoration:none; color:inherit;">
                <div class="product-card__image-wrap" style="aspect-ratio:1/1.2; overflow:hidden; border-radius:12px; background:#f9f9f9; margin-bottom:15px;">
                  <img src="{{ product.featured_image | image_url: width: 600 }}" class="product-card__image" style="width:100%; height:100%; object-fit:cover;">
                </div>
                <h3 style="font-family:var(--font-heading); font-size:1.1rem; margin:0 0 5px;">{{ product.title }}</h3>
                <p style="font-weight:700; margin:0;">{{ product.price | money }}</p>
              </a>
            </div>
          {%- endfor -%}
        {%- else -%}
          {%- for i in (1..6) -%}
            <div class="swiper-slide">
              <div class="product-card">
                <div class="product-card__image-wrap" style="aspect-ratio:1/1.2; overflow:hidden; border-radius:12px; background:#f9f9f9; margin-bottom:15px;">
                  <img src="https://images.unsplash.com/photo-1522771917710-2ee211117f77?q=80&w=600" class="product-card__image" style="width:100%; height:100%; object-fit:cover;">
                </div>
                <h3 style="font-family:var(--font-heading); font-size:1.1rem; margin:0 0 5px;">Bamboo Essential Item {{ i }}</h3>
                <p style="font-weight:700; margin:0;">$55.00</p>
              </div>
            </div>
          {%- endfor -%}
        {%- endif -%}
      </div>
      <div class="swiper-pagination"></div>
    </div>
  </div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    new Swiper('.newArrivalsSwiper', {
      slidesPerView: 1.5,
      spaceBetween: 20,
      pagination: { el: '.swiper-pagination', clickable: true },
      breakpoints: {
        768: { slidesPerView: 3, spaceBetween: 30 },
        1024: { slidesPerView: 4, spaceBetween: 40 }
      }
    });
  });
</script>

{% schema %}
{
  "name": "New Arrivals Slider",
  "settings": [
    { "type": "text", "id": "title", "label": "Heading", "default": "New Arrivals" },
    { "type": "collection", "id": "collection", "label": "Collection" },
    { "type": "url", "id": "link", "label": "Shop All Link" }
  ],
  "presets": [
    { "name": "Boutique New Arrivals Slider" }
  ]
}
{% endschema %}
