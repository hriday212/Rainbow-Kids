<style>
  .why-bamboo { padding: 100px 0; background: #fff; }
  .bamboo-header { text-align: center; margin-bottom: 70px; }
  .bamboo-title { font-family: var(--font-heading); font-size: 3.5rem; color: #1a1a1a; margin-bottom: 20px; font-weight: 400; }
  
  .bamboo-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 40px; }
  .bamboo-card { text-align: center; padding: 40px; background: #fdfdfd; border-radius: 30px; border: 1px solid #f4f4f4; transition: all 0.4s cubic-bezier(0.19, 1, 0.22, 1); }
  .bamboo-card:hover { transform: translateY(-10px); box-shadow: 0 20px 50px rgba(0,0,0,0.05); }
  
  .bamboo-icon { font-size: 3rem; margin-bottom: 25px; display: block; }
  .bamboo-card-title { font-size: 1.2rem; font-weight: 800; text-transform: uppercase; letter-spacing: 0.1em; color: #1a1a1a; margin-bottom: 15px; }
  .bamboo-card-text { font-size: 1rem; color: #666; line-height: 1.7; }

  @media (max-width: 1024px) { .bamboo-grid { grid-template-columns: 1fr; } }
</style>

<section class="why-bamboo">
  <div class="container">
    <div class="bamboo-header animate-reveal">
      <h2 class="bamboo-title">{{ section.settings.title }}</h2>
    </div>

    <div class="bamboo-grid">
      {% for block in section.blocks %}
        <div class="bamboo-card animate-reveal" data-aos="fade-up" data-aos-delay="{{ forloop.index | times: 100 }}">
          <span class="bamboo-icon">{{ block.settings.icon }}</span>
          <h3 class="bamboo-card-title">{{ block.settings.title }}</h3>
          <p class="bamboo-card-text">{{ block.settings.text }}</p>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Why Bamboo",
  "settings": [
    { "type": "text", "id": "title", "label": "Section Title", "default": "The Magic of Bamboo" }
  ],
  "blocks": [
    {
      "type": "benefit",
      "name": "Benefit",
      "settings": [
        { "type": "text", "id": "icon", "label": "Emoji Icon", "default": "☁️" },
        { "type": "text", "id": "title", "label": "Benefit Title", "default": "Buttery Soft" },
        { "type": "textarea", "id": "text", "label": "Benefit Text", "default": "Specifically designed for sensitive skin, our fabric is smoother than silk." }
      ]
    }
  ],
  "presets": [
    {
      "name": "Boutique Why Bamboo",
      "blocks": [
        { "type": "benefit", "settings": { "icon": "☁️", "title": "Buttery Soft" } },
        { "type": "benefit", "settings": { "icon": "🌡️", "title": "Thermal Regulating" } },
        { "type": "benefit", "settings": { "icon": "🌿", "title": "Eco-Friendly" } }
      ]
    }
  ]
}
{% endschema %}
