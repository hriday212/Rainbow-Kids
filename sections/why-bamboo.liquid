<style>
  .why-bamboo { padding: 100px 0; background: var(--color-background); }
  .why-bamboo__header { text-align: center; margin-bottom: 70px; }
  .why-bamboo__subtitle { font-size: 0.75rem; font-weight: 800; text-transform: uppercase; letter-spacing: 0.2em; color: var(--color-primary); margin-bottom: 15px; display: block; }
  .why-bamboo__title { font-family: var(--font-heading); font-size: 3rem; color: #1a1a1a; }
  .wb-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 40px; }
  .wb-item { padding: 50px 40px; border-radius: 24px; background: #fff; text-align: center; box-shadow: 0 4px 30px rgba(0,0,0,0.04); transition: transform 0.3s, box-shadow 0.3s; }
  .wb-item:hover { transform: translateY(-8px); box-shadow: 0 20px 60px rgba(0,0,0,0.08); }
  .wb-icon { width: 72px; height: 72px; border-radius: 50%; background: var(--color-background); display: flex; align-items: center; justify-content: center; margin: 0 auto 28px; }
  .wb-title { font-family: var(--font-heading); font-size: 1.6rem; color: #1a1a1a; margin-bottom: 15px; }
  .wb-text { font-size: 0.95rem; color: #888; line-height: 1.7; }
  @media (max-width: 1024px) { .wb-grid { grid-template-columns: 1fr; gap: 24px; } .why-bamboo__title { font-size: 2.2rem; } }
</style>

<section class="why-bamboo">
  <div class="container">
    <div class="why-bamboo__header animate-reveal">
      <span class="why-bamboo__subtitle">{{ section.settings.subtitle | default: "The Rainbow Difference" }}</span>
      <h2 class="why-bamboo__title">{{ section.settings.title | default: "Why Bamboo?" }}</h2>
    </div>

    <div class="wb-grid">
      {%- if section.blocks.size > 0 -%}
        {%- for block in section.blocks -%}
          <div class="wb-item animate-reveal" {{ block.shopify_attributes }}>
            <div class="wb-icon">
              {% render 'boutique-icon', icon: block.settings.icon, size: 36, color: '#FF8C69' %}
            </div>
            <h3 class="wb-title">{{ block.settings.title }}</h3>
            <p class="wb-text">{{ block.settings.text }}</p>
          </div>
        {%- endfor -%}
      {%- else -%}
        <div class="wb-item animate-reveal">
          <div class="wb-icon">{% render 'boutique-icon', icon: 'sun', size: 36, color: '#FF8C69' %}</div>
          <h3 class="wb-title">Thermoregulating</h3>
          <p class="wb-text">Naturally keeps your little one cool in summer and cozy in winter — no overheating, no night wakings.</p>
        </div>
        <div class="wb-item animate-reveal">
          <div class="wb-icon">{% render 'boutique-icon', icon: 'cloud', size: 36, color: '#FF8C69' %}</div>
          <h3 class="wb-title">Buttery Soft</h3>
          <p class="wb-text">Three times softer than cotton. Our bamboo fabric feels like a gentle hug against the most delicate newborn skin.</p>
        </div>
        <div class="wb-item animate-reveal">
          <div class="wb-icon">{% render 'boutique-icon', icon: 'leaf', size: 36, color: '#FF8C69' %}</div>
          <h3 class="wb-title">Sustainably Grown</h3>
          <p class="wb-text">Bamboo grows without pesticides or irrigation. Kind to your baby, and kind to the planet they'll inherit.</p>
        </div>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Why Bamboo",
  "settings": [
    { "type": "text", "id": "subtitle", "label": "Subtitle", "default": "The Rainbow Difference" },
    { "type": "text", "id": "title", "label": "Section Heading", "default": "Why Bamboo?" }
  ],
  "blocks": [
    {
      "type": "benefit",
      "name": "Benefit Card",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "leaf", "label": "Leaf (Organic)" },
            { "value": "truck", "label": "Truck (Shipping)" },
            { "value": "shield", "label": "Shield (Safety)" },
            { "value": "heart", "label": "Heart (Love)" },
            { "value": "star", "label": "Star (Quality)" },
            { "value": "lock", "label": "Lock (Security)" },
            { "value": "sparkle", "label": "Sparkle (Premium)" },
            { "value": "gift", "label": "Gift (Rewards)" },
            { "value": "sun", "label": "Sun (Warmth)" },
            { "value": "moon", "label": "Moon (Sleep)" },
            { "value": "cloud", "label": "Cloud (Softness)" },
            { "value": "smile", "label": "Smile (Happy)" }
          ],
          "default": "leaf"
        },
        { "type": "text", "id": "title", "label": "Title", "default": "Our Benefit" },
        { "type": "textarea", "id": "text", "label": "Description", "default": "Tell customers why bamboo is amazing for their baby." }
      ]
    }
  ],
  "presets": [
    {
      "name": "Boutique Why Bamboo",
      "blocks": [
        { "type": "benefit", "settings": { "icon": "sun", "title": "Thermoregulating", "text": "Naturally keeps your little one cool in summer and cozy in winter." } },
        { "type": "benefit", "settings": { "icon": "cloud", "title": "Buttery Soft", "text": "Three times softer than cotton, perfect for newborn skin." } },
        { "type": "benefit", "settings": { "icon": "leaf", "title": "Sustainably Grown", "text": "Bamboo grows without pesticides or irrigation." } }
      ]
    }
  ]
}
{% endschema %}
