<style>
  .why-bamboo { padding: 100px 0; background: #fff; }
  .wb-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 60px; text-align: center; }
  
  .wb-item { padding: 40px; border-radius: 24px; background: var(--color-background); transition: transform 0.3s; }
  .wb-item:hover { transform: translateY(-10px); }
  
  .wb-icon { font-size: 3rem; margin-bottom: 25px; display: block; }
  .wb-title { font-family: var(--font-heading); font-size: 1.8rem; color: #1a1a1a; margin-bottom: 15px; }
  .wb-text { font-size: 0.95rem; color: #666; line-height: 1.6; }

  @media (max-width: 1024px) { .wb-grid { grid-template-columns: 1fr; gap: 30px; } }
</style>

<section class="why-bamboo">
  <div class="container">
    <div class="wb-grid">
      {%- if section.blocks.size > 0 -%}
        {%- for block in section.blocks -%}
          <div class="wb-item animate-reveal" {{ block.shopify_attributes }}>
            <span class="wb-icon">{{ block.settings.icon | default: "🌿" }}</span>
            <h3 class="wb-title">{{ block.settings.title }}</h3>
            <p class="wb-text">{{ block.settings.text }}</p>
          </div>
        {%- endfor -%}
      {%- else -%}
        {% comment %} Demo Benefits {% endcomment %}
        <div class="wb-item">
          <span class="wb-icon">🌬️</span>
          <h3 class="wb-title">Breathable</h3>
          <p class="wb-text">Naturally thermoregulating to keep your little one cool in summer and warm in winter.</p>
        </div>
        <div class="wb-item">
          <span class="wb-icon">☁️</span>
          <h3 class="wb-title">Buttery Soft</h3>
          <p class="wb-text">Our bamboo fabric is softer than the finest cotton, perfect for sensitive newborn skin.</p>
        </div>
        <div class="wb-item">
          <span class="wb-icon">🌿</span>
          <h3 class="wb-title">Eco-Friendly</h3>
          <p class="wb-text">Sustainably sourced and biodegradable. Kind to your baby, and kind to our planet.</p>
        </div>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Why Bamboo",
  "settings": [],
  "blocks": [
    {
      "type": "benefit",
      "name": "Benefit",
      "settings": [
        { "type": "text", "id": "icon", "label": "Emoji Icon", "default": "🌿" },
        { "type": "text", "id": "title", "label": "Title", "default": "Buttery Soft" },
        { "type": "textarea", "id": "text", "label": "Text", "default": "Naturally soft fabric for your little one." }
      ]
    }
  ],
  "presets": [
    {
      "name": "Boutique Why Bamboo",
      "blocks": [
        { "type": "benefit", "settings": { "icon": "🌬️", "title": "Breathable" } },
        { "type": "benefit", "settings": { "icon": "☁️", "title": "Buttery Soft" } },
        { "type": "benefit", "settings": { "icon": "🌿", "title": "Eco-Friendly" } }
      ]
    }
  ]
}
{% endschema %}
