<style>
  {% include 'static-products' %}
  .marquee-new { padding: 80px 0; background: #fff; overflow-x: auto; scroll-behavior: smooth; -webkit-overflow-scrolling: touch; border-top: 1px solid #f4f4f4; border-bottom: 1px solid #f4f4f4; }
  .marquee-new::-webkit-scrollbar { height: 4px; }
  .marquee-new::-webkit-scrollbar-track { background: #fdfdfd; }
  .marquee-new::-webkit-scrollbar-thumb { background: #eee; border-radius: 10px; }
  
  .marquee-track { display: flex; animation: marquee-scroll 50s linear infinite; gap: 35px; width: max-content; padding: 0 40px; }
  .marquee-track:hover { animation-play-state: paused; }
  
  .marquee-card { width: 320px; flex-shrink: 0; background: #fff; border: 1px solid #eee; border-radius: 20px; padding: 18px; transition: all 0.4s cubic-bezier(0.165, 0.84, 0.44, 1); cursor: grab; text-decoration: none; }
  .marquee-card:active { cursor: grabbing; }
  .marquee-card:hover { border-color: var(--color-primary); transform: translateY(-10px); box-shadow: 0 20px 40px rgba(0,0,0,0.04); }
  
  .marquee-img-wrap { aspect-ratio: 1/1.2; border-radius: 12px; overflow: hidden; background: #fdfdfd; margin-bottom: 25px; }
  .marquee-img-wrap img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.8s ease; }
  .marquee-card:hover .marquee-img-wrap img { transform: scale(1.08); }
  
  .marquee-title { font-family: var(--font-heading); font-size: 1.1rem; font-weight: 700; color: #1a1a1a; display: block; margin-bottom: 8px; text-transform: capitalize; }
  .marquee-price { font-weight: 800; color: var(--color-primary); font-size: 1rem; }

  @keyframes marquee-scroll {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }
</style>

<section class="marquee-new">
  <div class="marquee-track">
    {%- if section.blocks.size > 0 -%}
      {%- for block in section.blocks -%}
        <div class="marquee-card" {{ block.shopify_attributes }}>
          <div class="marquee-img-wrap">
            {% if block.settings.image != blank %}
              <img src="{{ block.settings.image | image_url: width: 600 }}" class="marquee-img">
            {% else %}
              <div class="marquee-placeholder">
                {{ 'product-1' | placeholder_svg_tag }}
              </div>
            {% endif %}
          </div>
          <span class="marquee-title">{{ block.settings.title }}</span>
          <span class="marquee-price">{{ block.settings.price }}</span>
        </div>
      {%- endfor -%}
      {% comment %} Duplicate for infinite scroll {% endcomment %}
      {%- for block in section.blocks -%}
        <div class="marquee-card">
          <div class="marquee-img-wrap">
            {% if block.settings.image != blank %}
              <img src="{{ block.settings.image | image_url: width: 600 }}" class="marquee-img">
            {% else %}
              <div class="marquee-placeholder">
                {{ 'product-1' | placeholder_svg_tag }}
              </div>
            {% endif %}
          </div>
          <span class="marquee-title">{{ block.settings.title }}</span>
          <span class="marquee-price">{{ block.settings.price }}</span>
        </div>
      {%- endfor -%}
    {%- else -%}
      {%- for image_name in static_product_images offset: 24 limit: 6 -%}
        {%- assign di = forloop.index0 | plus: 24 -%}
        <div class="marquee-card">
          <div class="marquee-img-wrap">
            <img src="{{ image_name | asset_url }}" style="width:100%; height:100%; object-fit:cover;" alt="{{ image_name | remove: '.webp' }}">
          </div>
          <span class="marquee-title" style="text-transform: capitalize;">{{ image_name | remove: '.webp' | replace: '-', ' ' }}</span>
          <span class="marquee-price">{{ static_product_prices[di] }}</span>
        </div>
      {%- endfor -%}
      {% comment %} Duplicate Demo for infinite scroll {% endcomment %}
      {%- for image_name in static_product_images offset: 24 limit: 6 -%}
        {%- assign di = forloop.index0 | plus: 24 -%}
        <div class="marquee-card">
          <div class="marquee-img-wrap">
            <img src="{{ image_name | asset_url }}" style="width:100%; height:100%; object-fit:cover;" alt="{{ image_name | remove: '.webp' }}">
          </div>
          <span class="marquee-title" style="text-transform: capitalize;">{{ image_name | remove: '.webp' | replace: '-', ' ' }}</span>
          <span class="marquee-price">{{ static_product_prices[di] }}</span>
        </div>
      {%- endfor -%}
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "New Arrivals Marquee",
  "settings": [],
  "blocks": [
    {
      "type": "product",
      "name": "Product",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Product Image" },
        { "type": "text", "id": "title", "label": "Title", "default": "New Arrival" },
        { "type": "text", "id": "price", "label": "Price", "default": "$45.00" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Boutique Arrivals Strip",
      "blocks": [
        { "type": "product" },
        { "type": "product" },
        { "type": "product" }
      ]
    }
  ]
}
{% endschema %}
