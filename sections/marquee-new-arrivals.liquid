<style>
  .marquee-new { padding: 80px 0; background: #fff; overflow: hidden; }
  .marquee-header { text-align: center; margin-bottom: 50px; }
  .marquee-title { font-family: var(--font-heading); font-size: 3rem; color: #1a1a1a; margin-bottom: 10px; }
  
  .marquee-track-wrap { position: relative; width: 100%; display: flex; overflow: hidden; }
  .marquee-track { display: flex; gap: 40px; animation: marquee-scroll 40s linear infinite; width: max-content; }
  .marquee-track:hover { animation-play-state: paused; }
  
  .marquee-item { width: 250px; flex-shrink: 0; text-decoration: none; color: inherit; }
  .marquee-img-wrap { aspect-ratio: 1/1.2; border-radius: 20px; overflow: hidden; background: #f9f9f9; margin-bottom: 15px; border: 1px solid #f0f0f0; }
  .marquee-img { width: 100%; height: 100%; object-fit: cover; }
  
  .marquee-item-title { font-size: 0.9rem; font-weight: 700; color: #1a1a1a; margin-bottom: 5px; display: block; }
  .marquee-item-price { font-size: 0.85rem; color: var(--color-primary); font-weight: 800; }

  @keyframes marquee-scroll {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }
</style>

<section class="marquee-new">
  <div class="marquee-header">
    <h2 class="marquee-title">{{ section.settings.title | default: "Just Landed" }}</h2>
  </div>

  <div class="marquee-track-wrap">
    <div class="marquee-track">
      {%- for i in (1..2) -%} {% comment %} Duplicate loop for infinite effect {% endcomment %}
        {%- if section.blocks.size > 0 -%}
          {%- for block in section.blocks -%}
            {%- assign product = block.settings.product -%}
            <a href="{{ product.url | default: '#' }}" class="marquee-item">
              <div class="marquee-img-wrap">
                {% if block.settings.image != blank %}
                  <img src="{{ block.settings.image | image_url: width: 600 }}" class="marquee-img">
                {% elsif product.featured_image != blank %}
                  <img src="{{ product.featured_image | image_url: width: 600 }}" class="marquee-img">
                {% else %}
                  <img src="https://images.unsplash.com/photo-1522771917710-2ee211117f77?q=80&w=600" class="marquee-img">
                {% endif %}
              </div>
              <span class="marquee-item-title">{{ block.settings.title | default: product.title | default: "Bamboo Item" }}</span>
              <span class="marquee-item-price">{{ product.price | money | default: "$45.00" }}</span>
            </a>
          {%- endfor -%}
        {%- else -%}
          {%- for i in (1..6) -%}
            <div class="marquee-item">
              <div class="marquee-img-wrap">
                <img src="https://images.unsplash.com/photo-1515488403636-ee00ca9ff67b?q=80&w=600" class="marquee-img">
              </div>
              <span class="marquee-item-title">Boutique New Arrival {{ i }}</span>
              <span class="marquee-item-price">$55.00</span>
            </div>
          {%- endfor -%}
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "New Arrivals Marquee",
  "settings": [
    { "type": "text", "id": "title", "label": "Heading", "default": "Just Landed" }
  ],
  "blocks": [
    {
      "type": "product",
      "name": "Product",
      "settings": [
        { "type": "product", "id": "product", "label": "Product" },
        { "type": "image_picker", "id": "image", "label": "Custom Image (Optional)" },
        { "type": "text", "id": "title", "label": "Custom Title (Optional)" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Boutique New Arrivals Marquee",
      "blocks": [
        { "type": "product" },
        { "type": "product" },
        { "type": "product" },
        { "type": "product" },
        { "type": "product" },
        { "type": "product" }
      ]
    }
  ]
}
{% endschema %}
