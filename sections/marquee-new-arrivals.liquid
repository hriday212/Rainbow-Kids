<style>
  {% include 'static-products' %}
  .marquee-new { padding: 40px 0; background: #fff; overflow: hidden; border-top: 1px solid #f4f4f4; border-bottom: 1px solid #f4f4f4; }
  .marquee-track { display: flex; animation: marquee-scroll 30s linear infinite; gap: 30px; width: max-content; }
  .marquee-track:hover { animation-play-state: paused; }
  
  .marquee-card { width: 250px; flex-shrink: 0; text-decoration: none; }
  .marquee-img-wrap { aspect-ratio: 4/5; border-radius: 12px; overflow: hidden; background: #f4f4f4; margin-bottom: 15px; }
  .marquee-img { width: 100%; height: 100%; object-fit: cover; }
  .marquee-placeholder { width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; background: #f4f4f4; color: #ccc; }
  
  .marquee-title { font-size: 0.9rem; font-weight: 700; color: #1a1a1a; display: block; margin-bottom: 5px; }
  .marquee-price { font-weight: 800; color: var(--color-primary); font-size: 0.85rem; }

  @keyframes marquee-scroll {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }
</style>

<section class="marquee-new">
  <div class="marquee-track">
    {%- if section.blocks.size > 0 -%}
      {%- for block in section.blocks -%}
        <div class="marquee-card" {{ block.shopify_attributes }}>
          <div class="marquee-img-wrap">
            {% if block.settings.image != blank %}
              <img src="{{ block.settings.image | image_url: width: 600 }}" class="marquee-img">
            {% else %}
              <div class="marquee-placeholder">
                {{ 'product-1' | placeholder_svg_tag }}
              </div>
            {% endif %}
          </div>
          <span class="marquee-title">{{ block.settings.title }}</span>
          <span class="marquee-price">{{ block.settings.price }}</span>
        </div>
      {%- endfor -%}
      {% comment %} Duplicate for infinite scroll {% endcomment %}
      {%- for block in section.blocks -%}
        <div class="marquee-card">
          <div class="marquee-img-wrap">
            {% if block.settings.image != blank %}
              <img src="{{ block.settings.image | image_url: width: 600 }}" class="marquee-img">
            {% else %}
              <div class="marquee-placeholder">
                {{ 'product-1' | placeholder_svg_tag }}
              </div>
            {% endif %}
          </div>
          <span class="marquee-title">{{ block.settings.title }}</span>
          <span class="marquee-price">{{ block.settings.price }}</span>
        </div>
      {%- endfor -%}
    {%- else -%}
      {%- for image_name in static_product_images offset: 24 limit: 6 -%}
        {%- assign di = forloop.index0 | plus: 24 -%}
        <div class="marquee-card">
          <div class="marquee-img-wrap">
            <img src="{{ image_name | asset_url }}" style="width:100%; height:100%; object-fit:cover;" alt="{{ image_name | remove: '.webp' }}">
          </div>
          <span class="marquee-title" style="text-transform: capitalize;">{{ image_name | remove: '.webp' | replace: '-', ' ' }}</span>
          <span class="marquee-price">{{ static_product_prices[di] }}</span>
        </div>
      {%- endfor -%}
      {% comment %} Duplicate Demo for infinite scroll {% endcomment %}
      {%- for image_name in static_product_images offset: 24 limit: 6 -%}
        {%- assign di = forloop.index0 | plus: 24 -%}
        <div class="marquee-card">
          <div class="marquee-img-wrap">
            <img src="{{ 'products/' | append: image_name | asset_url }}" style="width:100%; height:100%; object-fit:cover;" alt="{{ image_name | remove: '.webp' }}">
          </div>
          <span class="marquee-title" style="text-transform: capitalize;">{{ image_name | remove: '.webp' | replace: '-', ' ' }}</span>
          <span class="marquee-price">{{ static_product_prices[di] }}</span>
        </div>
      {%- endfor -%}
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "New Arrivals Marquee",
  "settings": [],
  "blocks": [
    {
      "type": "product",
      "name": "Product",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Product Image" },
        { "type": "text", "id": "title", "label": "Title", "default": "New Arrival" },
        { "type": "text", "id": "price", "label": "Price", "default": "$45.00" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Boutique Arrivals Strip",
      "blocks": [
        { "type": "product" },
        { "type": "product" },
        { "type": "product" }
      ]
    }
  ]
}
{% endschema %}
