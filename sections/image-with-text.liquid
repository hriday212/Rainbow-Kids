<style>
  .iwt { padding: 100px 0; background: #fff; overflow: hidden; }
  .iwt__grid { display: grid; grid-template-columns: 1fr 1fr; gap: 80px; align-items: center; }
  
  .iwt__image { position: relative; border-radius: var(--radius-soft); overflow: hidden; aspect-ratio: 4/5; box-shadow: 0 20px 60px rgba(0,0,0,0.05); }
  .iwt__image img { width: 100%; height: 100%; object-fit: cover; }
  
  .iwt__content { display: flex; flex-direction: column; gap: 24px; }
  .iwt__title { font-size: clamp(2.5rem, 4vw, 3.5rem); line-height: 1.1; margin: 0; color: var(--color-text-dark); }
  .iwt__text { font-size: 1.1rem; color: var(--color-text-light); line-height: 1.7; }
  
  .iwt__checklist { list-style: none; padding: 0; display: flex; flex-direction: column; gap: 16px; }
  .iwt__check-item { display: flex; align-items: center; gap: 12px; font-weight: 600; font-size: 0.95rem; }
  .iwt__check-item span { color: var(--color-primary); filter: brightness(0.8); }

  @media (max-width: 850px) {
    .iwt__grid { grid-template-columns: 1fr; gap: 40px; }
    .iwt__content { text-align: center; align-items: center; }
  }
</style>

<section class="iwt animate-reveal">
  <div class="container iwt__grid">
    
    <div class="iwt__image" style="{% if section.settings.layout == 'right' %}order: 2;{% endif %}">
      {%- if section.settings.image != blank -%}
        <img src="{{ section.settings.image | image_url: width: 1200 }}" alt="{{ section.settings.title | escape }}">
      {%- else -%}
        <div style="width:100%; height:100%; background: #f4f4f4; display: flex; align-items: center; justify-content: center;">
          {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
        </div>
      {%- endif -%}
    </div>

    <div class="iwt__content">
      <span class="section-tag">{{ section.settings.tag | default: 'Our Philosophy' }}</span>
      <h2 class="iwt__title">{{ section.settings.title | default: 'The Softest Touch for Their Skin' }}</h2>
      <p class="iwt__text">{{ section.settings.text | default: 'We believe every child deserves clothing that feels like a hug. Our signature bamboo fabric is naturally breathable, moisture-wicking, and incredibly gentle.' }}</p>
      
      <ul class="iwt__checklist">
        {%- if section.settings.item_1 != blank -%}<li class="iwt__check-item"><span>✔</span> {{ section.settings.item_1 }}</li>{%- endif -%}
        {%- if section.settings.item_2 != blank -%}<li class="iwt__check-item"><span>✔</span> {{ section.settings.item_2 }}</li>{%- endif -%}
        {%- if section.settings.item_3 != blank -%}<li class="iwt__check-item"><span>✔</span> {{ section.settings.item_3 }}</li>{%- endif -%}
      </ul>
      
      {%- if section.settings.button_label != blank -%}
        <a href="{{ section.settings.button_link }}" class="button" style="margin-top: 20px;">{{ section.settings.button_label }}</a>
      {%- endif -%}
    </div>

  </div>
</section>

{% schema %}
{
  "name": "Image with Text",
  "settings": [
    { "type": "image_picker", "id": "image", "label": "Image" },
    { "type": "select", "id": "layout", "label": "Image alignment", "options": [
        { "value": "left", "label": "Left" },
        { "value": "right", "label": "Right" }
      ], "default": "left" 
    },
    { "type": "text", "id": "tag", "label": "Eyebrow Label", "default": "Our Philosophy" },
    { "type": "text", "id": "title", "label": "Heading", "default": "The Softest Touch for Their Skin" },
    { "type": "textarea", "id": "text", "label": "Text" },
    { "type": "text", "id": "item_1", "label": "Checklist Item 1", "default": "Sustainably Sourced Bamboo" },
    { "type": "text", "id": "item_2", "label": "Checklist Item 2", "default": "Hypoallergenic & Gentle" },
    { "type": "text", "id": "item_3", "label": "Checklist Item 3", "default": "Designed for Better Sleep" },
    { "type": "text", "id": "button_label", "label": "Button Label" },
    { "type": "url", "id": "button_link", "label": "Button Link" }
  ],
  "presets": [
    { "name": "Image with Text" }
  ]
}
{% endschema %}
