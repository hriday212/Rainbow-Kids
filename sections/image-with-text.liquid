<style>
  .image-with-text { padding: 100px 0; background: #fff; }
  .iwt-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 80px; align-items: center; }
  
  .iwt-image-wrap { border-radius: 30px; overflow: hidden; box-shadow: 0 30px 60px rgba(0,0,0,0.05); aspect-ratio: 1/1; }
  .iwt-image { width: 100%; height: 100%; object-fit: cover; }
  
  .iwt-content { padding: 40px; }
  .iwt-subtitle { font-size: 0.8rem; font-weight: 800; text-transform: uppercase; letter-spacing: 0.2em; color: var(--color-primary); margin-bottom: 20px; display: block; }
  .iwt-title { font-family: var(--font-heading); font-size: 3.5rem; color: #1a1a1a; margin-bottom: 30px; line-height: 1.1; }
  .iwt-text { font-size: 1.1rem; line-height: 1.8; color: #666; margin-bottom: 40px; }

  @media (max-width: 1024px) { .iwt-grid { grid-template-columns: 1fr; gap: 40px; text-align: center; } .iwt-image-wrap { aspect-ratio: 16/9; } }
</style>

<section class="image-with-text">
  <div class="container">
    <div class="iwt-grid">
      <div class="iwt-image-wrap animate-reveal">
        {%- if section.settings.image != blank -%}
          <img src="{{ section.settings.image | image_url: width: 1000 }}" class="iwt-image">
        {%- else -%}
          <img src="https://images.unsplash.com/photo-1522771917710-2ee211117f77?q=80&w=1000" class="iwt-image" alt="Boutique Demo">
        {%- endif -%}
      </div>
      
      <div class="iwt-content animate-reveal" data-aos="fade-left">
        <span class="iwt-subtitle">{{ section.settings.subtitle | default: "Our Promise" }}</span>
        <h2 class="iwt-title">{{ section.settings.title | default: "Quality you can feel." }}</h2>
        <p class="iwt-text">
          {{ section.settings.text | default: "We believe that every baby deserves the softest, safest fabrics. Our boutique collection is curated with love, ensuring only the highest quality bamboo reaches your little one's skin." }}
        </p>
        <a href="{{ section.settings.link | default: '/collections/all' }}" class="hero-btn">Explore More</a>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Image with Text",
  "settings": [
    { "type": "image_picker", "id": "image", "label": "Image" },
    { "type": "text", "id": "subtitle", "label": "Subtitle", "default": "Our Promise" },
    { "type": "text", "id": "title", "label": "Title", "default": "Quality you can feel." },
    { "type": "textarea", "id": "text", "label": "Text", "default": "We believe that every baby deserves the softest, safest fabrics." },
    { "type": "url", "id": "link", "label": "Button Link" }
  ],
  "presets": [
    { "name": "Boutique Image with Text" }
  ]
}
{% endschema %}
