<style>
  .header { padding: 15px 0; background: #fff; border-bottom: 1px solid #f4f4f4; position: sticky; top: 0; z-index: 1000; }
  .header__grid { display: flex; justify-content: space-between; align-items: center; }
  
  .header__logo-wrapper { display: flex; align-items: center; gap: 15px; text-decoration: none; }
  .header__logo-text { font-family: var(--font-heading); font-size: 1.8rem; font-weight: 700; color: var(--color-text-dark); }
  
  .header__nav { display: flex; gap: 30px; align-items: center; }
  .header__nav-link { font-size: 0.8rem; font-weight: 800; text-transform: uppercase; letter-spacing: 0.15em; color: var(--color-text-light); text-decoration: none; padding: 20px 0; position: relative; }
  .header__nav-link::after { content: ''; position: absolute; bottom: 14px; left: 0; width: 0; height: 2px; background: var(--color-primary); transition: width 0.3s; }
  .header__nav-link:hover::after { width: 100%; }

  .header__actions { display: flex; gap: 20px; align-items: center; }
  .header__action-btn { background: none; border: none; cursor: pointer; color: var(--color-text-dark); text-decoration: none; padding: 5px; }

  /* Mobile Drawer */
  .mobile-nav-toggle { display: none; background: none; border: none; font-size: 1.5rem; cursor: pointer; }
  .mobile-drawer { position: fixed; inset: 0; background: #fff; z-index: 10000; transform: translateX(-100%); transition: transform 0.4s var(--ease-smooth); padding: 40px; display: flex; flex-direction: column; gap: 30px; }
  .mobile-drawer.active { transform: translateX(0); }
  .mobile-drawer__close { align-self: flex-end; font-size: 2rem; cursor: pointer; }
  .mobile-link { font-family: var(--font-heading); font-size: 2rem; color: #1a1a1a; text-decoration: none; }

  @media (max-width: 1024px) { 
    .header__nav { display: none; } 
    .mobile-nav-toggle { display: block; }
  }
</style>

<div class="mobile-drawer" id="MobileDrawer">
  <span class="mobile-drawer__close" id="MobileClose">&times;</span>
  <a href="/" class="mobile-link">Home</a>
  <a href="/collections/all" class="mobile-link">Shop All</a>
  <a href="/pages/newborn" class="mobile-link">Newborn</a>
  <a href="/pages/sleep-bags" class="mobile-link">Sleep Bags</a>
  <a href="/pages/story" class="mobile-link">Our Story</a>
  <a href="/pages/contact" class="mobile-link">Support</a>
</div>

<header class="header">
  <div class="container header__grid">
    <div style="display:flex; align-items:center; gap:15px;">
      <button class="mobile-nav-toggle" id="MobileToggle">☰</button>
      <a href="/" class="header__logo-wrapper">
        <span class="header__logo-text">{{ shop.name }}</span>
      </a>
    </div>

    <nav class="header__nav">
      <a href="/collections/all" class="header__nav-link">Shop All</a>
      <a href="/pages/newborn" class="header__nav-link">Newborn</a>
      <a href="/pages/sleep-bags" class="header__nav-link">Sleep Bags</a>
      <a href="/pages/story" class="header__nav-link">Our Story</a>
      <a href="/pages/contact" class="header__nav-link">Support</a>
    </nav>

    <div class="header__actions">
      <a href="/account" class="header__action-btn">👤</a>
      <button class="header__action-btn" id="SearchToggle">🔍</button>
      <button class="header__action-btn">🛒</button>
    </div>
  </div>
</header>

<script>
  document.getElementById('MobileToggle')?.addEventListener('click', () => {
    document.getElementById('MobileDrawer').classList.add('active');
  });
  document.getElementById('MobileClose')?.addEventListener('click', () => {
    document.getElementById('MobileDrawer').classList.remove('active');
  });
</script>

{% schema %}
{ "name": "Boutique Header", "settings": [] }
{% endschema %}
