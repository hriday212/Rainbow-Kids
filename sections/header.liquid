<style>
  .header { height: 80px; background: #fff; border-bottom: 1px solid #f4f4f4; position: fixed; top: 40px; left: 0; width: 100%; z-index: 1000; transition: transform 0.4s var(--ease-smooth); display: flex; align-items: center; }
  .header--hidden { transform: translateY(-200%); }
  .header--visible { transform: translateY(0); box-shadow: 0 10px 30px rgba(0,0,0,0.05); }
  body { padding-top: 120px; } 
  .header .container { height: 100%; }
  
  :root { --logo-max-left: -40px; }
  @media (min-width: 1480px) {
    :root { --logo-max-left: calc(-1 * ((100vw - 1400px) / 2 + 40px)); }
  }
  
  .header__grid { display: grid; grid-template-columns: 1fr auto 1fr; align-items: center; height: 100%; }
  .header__grid--left { grid-template-columns: auto 1fr auto; }
  
  .header__logo-wrapper { display: flex; align-items: center; text-decoration: none; position: relative; z-index: 10; height: 80px; overflow: visible; }
  .header__logo-text { font-family: var(--font-heading); font-size: 1.8rem; font-weight: 700; color: #1a1a1a; line-height: 1; }
  .header__logo-text span { color: var(--color-primary); }
  
  .header__nav { display: flex; gap: 30px; align-items: center; height: 80px; width: 100%; }
  .header__nav--left { justify-content: flex-start; padding-left: 40px; }
  .header__nav--center { justify-content: center; }
  .header__nav--right { justify-content: flex-end; padding-right: 40px; }
  
  .header__nav-item { position: relative; height: 80px; display: flex; align-items: center; }
  .header__nav-link { font-size: 0.8rem; font-weight: 800; text-transform: uppercase; letter-spacing: 0.15em; color: var(--color-text-light); text-decoration: none; position: relative; display: flex; align-items: center; justify-content: center; height: 100%; transition: color 0.3s; }
  .header__nav-link::after { content: ''; position: absolute; bottom: 20px; left: 0; width: 0; height: 2px; background: var(--color-primary); transition: width 0.3s; }
  .header__nav-item:hover .header__nav-link { color: var(--color-primary); }
  .header__nav-item:hover .header__nav-link::after { width: 100%; }

  .mega-menu { position: absolute; top: 100%; left: -300px; width: 1100px; background: #fff; border-top: 1px solid #f4f4f4; box-shadow: 0 40px 100px rgba(0,0,0,0.05); padding: 60px; display: grid; grid-template-columns: repeat(4, 1fr); gap: 40px; opacity: 0; visibility: hidden; transition: all 0.3s; }
  .header__nav-item:hover .mega-menu { opacity: 1; visibility: visible; }
  
  .dropdown-menu { position: absolute; top: 100%; left: 0; width: 220px; background: #fff; border: 1px solid #f4f4f4; box-shadow: 0 20px 50px rgba(0,0,0,0.05); padding: 20px; opacity: 0; visibility: hidden; transition: all 0.3s; display: flex; flex-direction: column; gap: 15px; }
  .header__nav-item:hover .dropdown-menu { opacity: 1; visibility: visible; }
  .dropdown-link { font-size: 0.85rem; color: #666; text-decoration: none; transition: color 0.3s; }
  .dropdown-link:hover { color: var(--color-primary); font-weight: 700; }

  .header__actions { display: flex; align-items: center; gap: 15px; height: 80px; justify-content: flex-end; }
  .header__action-btn { background: none; border: none; padding: 8px; cursor: pointer; color: #1a1a1a; display: flex; align-items: center; justify-content: center; transition: color 0.3s; height: 100%; }
  .header__action-btn:hover { color: var(--color-primary); }
  .header__action-btn svg { width: 22px; height: 22px; }

  .search-modal { position: fixed; inset: 0; z-index: 3000; visibility: hidden; opacity: 0; transition: all 0.4s var(--ease-smooth); }
  .search-modal.active { visibility: visible; opacity: 1; }
  .search-modal__overlay { position: absolute; inset: 0; background: rgba(255,255,255,0.95); backdrop-filter: blur(10px); }
  .search-modal__content { position: relative; width: 100%; max-width: 800px; margin: 150px auto; padding: 0 20px; transform: translateY(-30px); transition: transform 0.4s; }
  .search-modal.active .search-modal__content { transform: translateY(0); }
  .search-input { flex: 1; background: none; border: none; font-family: var(--font-heading); font-size: 3rem; color: #1a1a1a; outline: none; width: 100%; border-bottom: 3px solid #1a1a1a; padding: 0 0 15px; }

  @media (max-width: 1024px) { .header__nav { display: none; } }
</style>

<header class="header" id="SmartHeader">
  <div class="container header__grid {% if section.settings.logo_position == 'left' %}header__grid--left{% endif %}">
    
    {%- if section.settings.logo_position == 'center' -%}
      <nav class="header__nav header__nav--left">
        <div class="header__nav-item">
          <a href="/collections/all" class="header__nav-link">Shop All</a>
          <div class="mega-menu" style="left: 0;">
            <div>
              <span style="font-size:0.75rem; font-weight:800; text-transform:uppercase; letter-spacing:0.15em; color:#1a1a1a; margin-bottom:25px; display:block;">Clothing</span>
              <a href="/collections/all?cat=dresses" class="dropdown-link" style="display:block; margin-bottom:12px;">Dresses & Frocks</a>
              <a href="/collections/all?cat=pajamas" class="dropdown-link" style="display:block; margin-bottom:12px;">Pajamas & Nightsuits</a>
              <a href="/collections/all?cat=sets" class="dropdown-link" style="display:block; margin-bottom:12px;">Sets & Dungarees</a>
            </div>
            <div>
              <span style="font-size:0.75rem; font-weight:800; text-transform:uppercase; letter-spacing:0.15em; color:#1a1a1a; margin-bottom:25px; display:block;">Essentials</span>
              <a href="/collections/all?cat=bodysuits" class="dropdown-link" style="display:block; margin-bottom:12px;">Bodysuits & Basics</a>
              <a href="/collections/all?cat=accessories" class="dropdown-link" style="display:block; margin-bottom:12px;">Bedding & Accessories</a>
            </div>
            <div style="grid-column: span 2; display: grid; grid-template-columns: 1fr 1fr; gap: 20px;">
               <div style="background:#f4f4f4; border-radius:12px; height:100%;">{{ 'product-1' | placeholder_svg_tag }}</div>
               <div style="background:#f4f4f4; border-radius:12px; height:100%;">{{ 'product-2' | placeholder_svg_tag }}</div>
            </div>
          </div>
        </div>
        <div class="header__nav-item"><a href="/collections/new-arrivals" class="header__nav-link">New Arrivals</a></div>
      </nav>
    {%- endif -%}

    <a href="{{ routes.root_url }}" class="header__logo-wrapper" style="justify-content: {{ section.settings.logo_position | default: 'left' }}; transform: translateX(max(var(--logo-max-left), {{ section.settings.logo_horizontal_offset | default: 0 }}px));">
      {%- if section.settings.logo != blank -%}
        <img src="{{ section.settings.logo | image_url: width: 600 }}" alt="{{ section.settings.logo.alt | default: shop.name | escape }}" style="width: {{ section.settings.logo_width | default: 180 }}px; height: auto; display: block; max-width: none; transform: translateY({{ section.settings.logo_vertical_offset | default: 0 }}px);">
      {%- else -%}
        <span class="header__logo-text" style="font-family: var(--font-heading); font-size: 1.5rem; font-weight: 800; color: var(--color-primary);">{{ shop.name }}</span>
      {%- endif -%}
    </a>

    {%- if section.settings.logo_position == 'left' -%}
      <nav class="header__nav header__nav--right">
        <div class="header__nav-item">
          <a href="/collections/all" class="header__nav-link">Shop All</a>
          <div class="mega-menu">
            <div>
              <span style="font-size:0.75rem; font-weight:800; text-transform:uppercase; letter-spacing:0.15em; color:#1a1a1a; margin-bottom:25px; display:block;">Clothing</span>
              <a href="/collections/all?cat=dresses" class="dropdown-link" style="display:block; margin-bottom:12px;">Dresses & Frocks</a>
              <a href="/collections/all?cat=pajamas" class="dropdown-link" style="display:block; margin-bottom:12px;">Pajamas & Nightsuits</a>
              <a href="/collections/all?cat=sets" class="dropdown-link" style="display:block; margin-bottom:12px;">Sets & Dungarees</a>
            </div>
            <div>
              <span style="font-size:0.75rem; font-weight:800; text-transform:uppercase; letter-spacing:0.15em; color:#1a1a1a; margin-bottom:25px; display:block;">Essentials</span>
              <a href="/collections/all?cat=bodysuits" class="dropdown-link" style="display:block; margin-bottom:12px;">Bodysuits & Basics</a>
              <a href="/collections/all?cat=accessories" class="dropdown-link" style="display:block; margin-bottom:12px;">Bedding & Accessories</a>
            </div>
            <div style="grid-column: span 2; display: grid; grid-template-columns: 1fr 1fr; gap: 20px;">
               <div style="background:#f4f4f4; border-radius:12px; height:100%;">{{ 'product-1' | placeholder_svg_tag }}</div>
               <div style="background:#f4f4f4; border-radius:12px; height:100%;">{{ 'product-2' | placeholder_svg_tag }}</div>
            </div>
          </div>
        </div>
        <div class="header__nav-item"><a href="/collections/new-arrivals" class="header__nav-link">New Arrivals</a></div>
        <div class="header__nav-item"><a href="/pages/story" class="header__nav-link">Our Story</a></div>
        <div class="header__nav-item"><a href="/pages/contact" class="header__nav-link">Support</a></div>
      </nav>
    {%- else -%}
      <nav class="header__nav header__nav--left" style="gap: 20px;">
         <div class="header__nav-item"><a href="/pages/story" class="header__nav-link">Story</a></div>
         <div class="header__nav-item"><a href="/pages/contact" class="header__nav-link">Support</a></div>
      </nav>
    {%- endif -%}

    <div class="header__actions" style="display: flex; align-items: center; gap: 15px; height: 80px; justify-content: flex-end;">
      <a href="/account" class="header__action-btn" title="Account" style="display: flex; align-items: center;"><svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0ZM4.501 20.118a7.5 7.5 0 0 1 14.998 0A17.933 17.933 0 0 1 12 21.75c-2.676 0-5.216-.584-7.499-1.632Z" /></svg></a>
      <button class="header__action-btn" onclick="toggleSearch()" style="display: flex; align-items: center;"><svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m21 21-5.197-5.197m0 0A7.5 7.5 0 1 0 5.196 5.196a7.5 7.5 0 0 0 10.607 10.607Z" /></svg></button>
      <button class="header__action-btn" onclick="toggleCart()" style="display: flex; align-items: center;"><svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 10.5V6a3.75 3.75 0 1 0-7.5 0v4.5m11.356-1.993 1.263 12c.07.665-.45 1.243-1.119 1.243H4.25a1.125 1.125 0 0 1-1.12-1.243l1.264-12A1.125 1.125 0 0 1 5.513 7.5h12.974c.576 0 1.059.435 1.119 1.007ZM8.625 10.5a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Zm7.5 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Z" /></svg></button>
    </div>
  </div>
</header>

<div class="search-modal" id="SearchModal">
  <div class="search-modal__overlay" onclick="toggleSearch()"></div>
  <div class="search-modal__content">
    <form action="/search" method="get">
      <input type="text" name="q" class="search-input" placeholder="What are you looking for?" autofocus>
    </form>
  </div>
</div>

<script>
  function toggleSearch() {
    const modal = document.getElementById('SearchModal');
    modal.classList.toggle('active');
    if(modal.classList.contains('active')) setTimeout(() => document.querySelector('.search-input').focus(), 300);
  }
  function toggleCart() {
    const drawer = document.getElementById('CartDrawer');
    if(drawer) drawer.classList.toggle('active');
  }

  document.addEventListener('DOMContentLoaded', function() {
    const header = document.getElementById('SmartHeader');
    let lastScroll = 0;
    window.addEventListener('scroll', () => {
      const currentScroll = window.pageYOffset;
      if (currentScroll <= 100) { header.classList.remove('header--hidden', 'header--visible'); return; }
      if (currentScroll > lastScroll && !header.classList.contains('header--hidden')) {
        header.classList.remove('header--visible'); header.classList.add('header--hidden');
      } else if (currentScroll < lastScroll && header.classList.contains('header--hidden')) {
        header.classList.remove('header--hidden'); header.classList.add('header--visible');
      }
      lastScroll = currentScroll;
    });
  });
</script>

{% schema %}
{
  "name": "Boutique Header",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo image"
    },
    {
      "type": "select",
      "id": "logo_position",
      "label": "Logo position",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" }
      ],
      "default": "left"
    },
    {
      "type": "range",
      "id": "logo_width",
      "min": 50,
      "max": 300,
      "step": 10,
      "default": 180,
      "unit": "px",
      "label": "Custom logo width"
    },
    {
      "type": "range",
      "id": "logo_vertical_offset",
      "min": -20,
      "max": 50,
      "step": 1,
      "default": 10,
      "unit": "px",
      "label": "Logo vertical offset"
    },
    {
      "type": "range",
      "id": "logo_horizontal_offset",
      "min": -200,
      "max": 200,
      "step": 5,
      "default": 0,
      "unit": "px",
      "label": "Logo horizontal offset"
    }
  ]
}
{% endschema %}
