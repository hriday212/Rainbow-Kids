<style>
  .header { padding: 15px 0; background: #fff; border-bottom: 1px solid #f4f4f4; position: sticky; top: 0; z-index: 1000; }
  .header__grid { display: flex; justify-content: space-between; align-items: center; }
  
  .header__logo-wrapper { display: flex; align-items: center; gap: 15px; text-decoration: none; }
  .header__logo-img { display: block; height: auto; transition: transform 0.3s; }
  .header__logo-img:hover { transform: scale(1.05); }
  
  .header__logo-text { font-family: var(--font-heading); font-size: 1.8rem; font-weight: 700; color: var(--color-text-dark); letter-spacing: -0.02em; }
  
  /* Mega Navigation */
  .header__nav { display: flex; gap: 30px; height: 100%; align-items: center; }
  .nav-item { position: relative; height: 100%; display: flex; align-items: center; }

  /* Animated underline on all nav links */
  .header__nav-link {
    font-size: 0.8rem; font-weight: 800; text-transform: uppercase; letter-spacing: 0.15em;
    color: var(--color-text-light); padding: 20px 0; text-decoration: none;
    position: relative; transition: color 0.25s;
  }
  .header__nav-link::after {
    content: ''; position: absolute; bottom: 14px; left: 0; width: 0; height: 2px;
    background: var(--color-primary); transition: width 0.3s var(--ease-smooth);
  }
  .nav-item:hover .header__nav-link { color: var(--color-text-dark); }
  .nav-item:hover .header__nav-link::after { width: 100%; }

  /* Mega Menu */
  .mega-menu { position: absolute; top: 100%; left: 50%; transform: translateX(-50%); width: 100vw; max-width: 1200px; background: #fff; padding: 40px; border-radius: 0 0 20px 20px; box-shadow: 0 20px 40px rgba(0,0,0,0.05); display: none; grid-template-columns: repeat(4, 1fr); gap: 30px; opacity: 0; transition: opacity 0.3s; z-index: 100; }
  .nav-item:hover .mega-menu { display: grid; opacity: 1; }
  
  .mega-col__title { font-weight: 800; font-size: 0.75rem; text-transform: uppercase; margin-bottom: 15px; display: block; border-bottom: 1px solid #f4f4f4; padding-bottom: 8px; letter-spacing: 0.1em; }
  .mega-link { display: block; font-size: 0.9rem; color: var(--color-text-light); margin-bottom: 8px; text-decoration: none; transition: all 0.2s; }
  .mega-link:hover { color: var(--color-text-dark); transform: translateX(5px); }
  
  .mega-image { border-radius: 12px; overflow: hidden; aspect-ratio: 1/1; position: relative; }
  .mega-image img { width: 100%; height: 100%; object-fit: cover; }

  /* "More" Utility Dropdown */
  .more-dropdown {
    position: absolute; top: calc(100% + 10px); right: 0;
    background: #fff; border-radius: 16px;
    box-shadow: 0 20px 50px rgba(0,0,0,0.08);
    padding: 12px 0; min-width: 180px;
    opacity: 0; visibility: hidden; transform: translateY(-8px);
    transition: all 0.3s var(--ease-smooth); z-index: 200;
  }
  .nav-item:hover .more-dropdown { opacity: 1; visibility: visible; transform: translateY(0); }

  .more-dropdown__link {
    display: flex; align-items: center; gap: 12px;
    padding: 12px 24px; font-size: 0.85rem; font-weight: 700;
    color: var(--color-text-light); text-decoration: none;
    text-transform: uppercase; letter-spacing: 0.1em;
    transition: all 0.2s;
  }
  .more-dropdown__link:hover { color: var(--color-text-dark); background: var(--color-background); padding-left: 30px; }
  .more-dropdown__link span { font-size: 1rem; }

  .header__actions { display: flex; gap: 20px; align-items: center; }
  .header__action-btn { background: none; border: none; cursor: pointer; color: var(--color-text-dark); position: relative; padding: 5px; transition: transform 0.3s; }
  .header__action-btn:hover { transform: scale(1.1); color: var(--color-primary); }
  .header__cart-count { position: absolute; top: -2px; right: -2px; background: var(--color-primary); color: var(--color-text-dark); font-size: 0.6rem; font-weight: 800; width: 16px; height: 16px; border-radius: 50%; display: flex; align-items: center; justify-content: center; }

  /* Search Overlay Polish */
  .search-overlay { position: fixed; inset: 0; background: #fff; z-index: 10000; display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 40px; transform: translateY(-100%); transition: transform 0.6s var(--ease-smooth); }
  .search-overlay.active { transform: translateY(0); }
  .search-overlay__close { position: absolute; top: 40px; right: 40px; background: none; border: none; font-size: 3rem; cursor: pointer; color: var(--color-text-light); transition: color 0.3s; }
  .search-overlay__close:hover { color: var(--color-text-dark); }
  
  .search-overlay__input { width: 100%; max-width: 900px; border: none; border-bottom: 4px solid #eee; font-size: clamp(2rem, 5vw, 4rem); font-family: var(--font-heading); padding: 30px 0; outline: none; text-align: center; color: var(--color-text-dark); transition: border-color 0.4s; }
  .search-overlay__input:focus { border-color: var(--color-text-dark); }
  .search-overlay__hint { margin-top: 30px; color: #999; text-transform: uppercase; letter-spacing: 0.2em; font-size: 0.85rem; font-weight: 700; }

  @media (max-width: 768px) { .header__logo-text { font-size: 1.2rem; } .header__nav { display: none; } }
</style>

<div class="search-overlay" id="SearchOverlay">
  <button class="search-overlay__close" id="SearchClose">&times;</button>
  <form action="/search" method="get" role="search" style="width: 100%; display: flex; flex-direction: column; align-items: center;">
    <input type="search" name="q" class="search-overlay__input" placeholder="What are you looking for?" id="SearchInput" autocomplete="off">
    <p class="search-overlay__hint">Press Enter to Search</p>
  </form>
</div>

<header class="header">
  <div class="container header__grid">
    <!-- Logo & Title -->
    <a href="/" class="header__logo-wrapper">
      {%- if section.settings.logo != blank -%}
        <img src="{{ section.settings.logo | image_url: width: 400 }}" 
             class="header__logo-img" 
             style="width: {{ section.settings.logo_width }}px;"
             alt="{{ shop.name }}">
      {%- endif -%}
      
      {%- if section.settings.show_text or section.settings.logo == blank -%}
        <span class="header__logo-text">{{ shop.name }}</span>
      {%- endif -%}
    </a>

    <!-- Nav -->
    <nav class="header__nav">
      <div class="nav-item">
        <a href="/collections/all" class="header__nav-link">Shop All</a>
        <div class="mega-menu">
          <div>
            <span class="mega-col__title">Essentials</span>
            <a href="/collections/sleep-bags" class="mega-link">Sleep Bags</a>
            <a href="/collections/pajamas" class="mega-link">Pajamas</a>
            <a href="/collections/bodysuits" class="mega-link">Bodysuits</a>
          </div>
          <div>
            <span class="mega-col__title">Shop by Age</span>
            <a href="/collections/newborn" class="mega-link">Newborn</a>
            <a href="/collections/baby" class="mega-link">Baby</a>
            <a href="/collections/toddler" class="mega-link">Toddler</a>
          </div>
          <div class="mega-image">
            <img src="https://images.unsplash.com/photo-1522771917710-2ee211117f77?auto=format&fit=crop&q=80&w=600" alt="Sleep Bags">
            <div style="position:absolute; bottom:20px; left:20px; color:#fff; z-index:2;">
              <span style="font-size:0.7rem; font-weight:800; text-transform:uppercase; letter-spacing:0.1em; display:block; margin-bottom:5px;">Bestseller</span>
              <h4 style="font-family:var(--font-heading); font-size:1.2rem; margin:0;">Sleep Bags</h4>
            </div>
            <div style="position:absolute; inset:0; background:linear-gradient(transparent, rgba(0,0,0,0.4));"></div>
          </div>
          <div class="mega-image">
            <img src="https://images.unsplash.com/photo-1515488403636-ee00ca9ff67b?auto=format&fit=crop&q=80&w=600" alt="Newborn">
            <div style="position:absolute; bottom:20px; left:20px; color:#fff; z-index:2;">
              <span style="font-size:0.7rem; font-weight:800; text-transform:uppercase; letter-spacing:0.1em; display:block; margin-bottom:5px;">Softest Bamboo</span>
              <h4 style="font-family:var(--font-heading); font-size:1.2rem; margin:0;">Newborn Gift Sets</h4>
            </div>
            <div style="position:absolute; inset:0; background:linear-gradient(transparent, rgba(0,0,0,0.4));"></div>
          </div>
        </div>
      </div>
      <div class="nav-item"><a href="/collections/new-arrivals" class="header__nav-link">New Arrivals</a></div>
      <div class="nav-item"><a href="/pages/about" class="header__nav-link">Our Story</a></div>
      <div class="nav-item"><a href="/pages/contact" class="header__nav-link">Support</a></div>

      {%- comment -%} Utility "More" Dropdown {%- endcomment -%}
      <div class="nav-item">
        <a href="#" class="header__nav-link" style="display:flex;align-items:center;gap:5px;">
          More
          <svg style="width:10px;height:10px;transition:transform 0.3s;" viewBox="0 0 10 6" fill="none">
            <path d="M1 1l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
        </a>
        <div class="more-dropdown">
          <a href="/collections/gifts" class="more-dropdown__link"><span>🎁</span> Gifts</a>
          <a href="/blogs/news" class="more-dropdown__link"><span>📖</span> Blog</a>
          <a href="/pages/rewards" class="more-dropdown__link"><span>⭐</span> Rewards</a>
          <a href="/pages/wishlist" class="more-dropdown__link"><span>🤍</span> Wishlist</a>
          <a href="/pages/wholesale" class="more-dropdown__link"><span>🏪</span> Wholesale</a>
        </div>
      </div>
    </nav>

    <!-- Actions -->
    <div class="header__actions">
      <button class="header__action-btn" id="SearchToggle" aria-label="Search">{% render 'icon', icon: 'search' %}</button>
      <button class="header__action-btn" id="CartToggle" aria-label="Cart">
        {% render 'icon', icon: 'cart' %}
        <span class="header__cart-count">0</span>
      </button>
    </div>
  </div>
</header>

<script>
  // Search Overlay Toggle
  const searchToggle = document.getElementById('SearchToggle');
  const searchClose = document.getElementById('SearchClose');
  const searchOverlay = document.getElementById('SearchOverlay');
  const searchInput = document.getElementById('SearchInput');

  if(searchToggle) {
    searchToggle.addEventListener('click', () => {
      searchOverlay.classList.add('active');
      setTimeout(() => searchInput.focus(), 100);
    });
  }
  if(searchClose) {
    searchClose.addEventListener('click', () => searchOverlay.classList.remove('active'));
  }

  // Cart Logic is handled by cart-logic.js
</script>

{% schema %}
{
  "name": "Header",
  "settings": [
    { "type": "image_picker", "id": "logo", "label": "Logo Image" },
    { "type": "range", "id": "logo_width", "min": 50, "max": 250, "step": 10, "default": 100, "unit": "px", "label": "Logo Width" },
    { "type": "checkbox", "id": "show_text", "label": "Show Shop Name next to Logo", "default": true }
  ]
}
{% endschema %}
