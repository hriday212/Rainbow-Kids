<style>
  .header { padding: 15px 0; background: #fff; border-bottom: 1px solid #f4f4f4; position: sticky; top: 0; z-index: 1000; }
  .header__grid { display: flex; justify-content: space-between; align-items: center; }
  
  .header__logo-wrapper { display: flex; align-items: center; gap: 15px; text-decoration: none; }
  .header__logo-img { display: block; height: auto; max-width: 100%; object-fit: contain; }
  .header__logo-text { font-family: var(--font-heading); font-size: 1.8rem; font-weight: 700; color: var(--color-text-dark); line-height: 1; }
  
  .header__nav { display: flex; gap: 30px; align-items: center; }
  .header__nav-item { position: static; }
  .header__nav-link { font-size: 0.8rem; font-weight: 800; text-transform: uppercase; letter-spacing: 0.15em; color: var(--color-text-light); text-decoration: none; padding: 25px 0; position: relative; display: block; }
  .header__nav-link::after { content: ''; position: absolute; bottom: 20px; left: 0; width: 0; height: 2px; background: var(--color-primary); transition: width 0.3s; }
  .header__nav-item:hover .header__nav-link::after { width: 100%; }

  /* Mega Menu Elite */
  .mega-menu { position: absolute; top: 100%; left: 0; width: 100%; background: #fff; border-top: 1px solid #f4f4f4; box-shadow: 0 40px 100px rgba(0,0,0,0.05); padding: 60px 0; display: grid; grid-template-columns: repeat(4, 1fr); gap: 40px; opacity: 0; visibility: hidden; transition: all 0.3s var(--ease-smooth); }
  .header__nav-item:hover .mega-menu { opacity: 1; visibility: visible; }
  
  .mega-col__title { font-size: 0.75rem; font-weight: 800; text-transform: uppercase; letter-spacing: 0.15em; color: #1a1a1a; margin-bottom: 25px; display: block; }
  .mega-link { display: block; font-size: 0.95rem; color: #666; text-decoration: none; margin-bottom: 12px; transition: color 0.3s; }
  .mega-link:hover { color: var(--color-primary); }
  
  .mega-image { position: relative; border-radius: 12px; overflow: hidden; aspect-ratio: 1/1; text-decoration: none; display: block; background: #f4f4f4; }
  .mega-image img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.5s; }
  .mega-image:hover img { transform: scale(1.1); }
  .mega-placeholder { width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; color: #ccc; }
  .mega-placeholder svg { width: 50%; height: 50%; }

  /* Mobile Drawer */
  .mobile-nav-toggle { display: none; background: none; border: none; font-size: 1.5rem; cursor: pointer; }
  .mobile-drawer { position: fixed; inset: 0; background: #fff; z-index: 10000; transform: translateX(-100%); transition: transform 0.4s var(--ease-smooth); padding: 40px; display: flex; flex-direction: column; gap: 20px; overflow-y: auto; }
  .mobile-drawer.active { transform: translateX(0); }
  .mobile-drawer__close { align-self: flex-end; font-size: 2rem; cursor: pointer; }
  .mobile-link { font-family: var(--font-heading); font-size: 1.8rem; color: #1a1a1a; text-decoration: none; margin-bottom: 10px; display: block; }

  @media (max-width: 1024px) { .header__nav { display: none; } .mobile-nav-toggle { display: block; } .header__logo-text { font-size: 1.2rem; } }
</style>

<div class="mobile-drawer" id="MobileDrawer">
  <span class="mobile-drawer__close" id="MobileClose">&times;</span>
  <a href="/" class="mobile-link">Home</a>
  <a href="/collections/all" class="mobile-link">Shop All</a>
  <a href="/pages/newborn" class="mobile-link">Newborn Essentials</a>
  <a href="/pages/sleep-bags" class="mobile-link">Sleep Solutions</a>
  <a href="/pages/pajamas" class="mobile-link">Pajamas</a>
  <a href="/pages/story" class="mobile-link">Our Story</a>
  <a href="/pages/contact" class="mobile-link">Support</a>
</div>

<header class="header">
  <div class="container header__grid">
    <div style="display:flex; align-items:center; gap:15px;">
      <button class="mobile-nav-toggle" id="MobileToggle">☰</button>
      <a href="/" class="header__logo-wrapper">
        {% if section.settings.logo != blank %}
          <img src="{{ section.settings.logo | image_url: width: 400 }}" class="header__logo-img" style="width: {{ section.settings.logo_width }}px;" alt="{{ shop.name }}">
        {% endif %}
        <span class="header__logo-text">{{ shop.name }}</span>
      </a>
    </div>

    <nav class="header__nav">
      <div class="header__nav-item">
        <a href="/collections/all" class="header__nav-link">Shop All</a>
        <div class="mega-menu">
          <div class="container" style="display:grid; grid-template-columns: repeat(4, 1fr); gap:40px; width:100%;">
            <div>
              <span class="mega-col__title">Essentials</span>
              <a href="/pages/sleep-bags" class="mega-link">Sleep Bags</a>
              <a href="/pages/pajamas" class="mega-link">Pajamas</a>
              <a href="/pages/bodysuits" class="mega-link">Bodysuits</a>
            </div>
            <div>
              <span class="mega-col__title">Shop by Age</span>
              <a href="/pages/newborn" class="mega-link">Newborn</a>
              <a href="/pages/baby" class="mega-link">Baby</a>
              <a href="/pages/toddler" class="mega-link">Toddler</a>
            </div>
            <a href="/pages/sleep-bags" class="mega-image">
              <div class="mega-placeholder">{{ 'product-1' | placeholder_svg_tag }}</div>
            </a>
            <a href="/pages/newborn" class="mega-image">
              <div class="mega-placeholder">{{ 'product-2' | placeholder_svg_tag }}</div>
            </a>
          </div>
        </div>
      </div>
      <div class="header__nav-item"><a href="/collections/new-arrivals" class="header__nav-link">New Arrivals</a></div>
      <div class="header__nav-item"><a href="/pages/story" class="header__nav-link">Our Story</a></div>
      <div class="header__nav-item"><a href="/pages/contact" class="header__nav-link">Support</a></div>
    </nav>

    <div class="header__actions">
      <a href="/account" class="header__action-btn">👤</a>
      <button class="header__action-btn" id="SearchToggle">🔍</button>
      <button class="header__action-btn">🛒</button>
    </div>
  </div>
</header>

<script>
  document.getElementById('MobileToggle')?.addEventListener('click', () => {
    document.getElementById('MobileDrawer').classList.add('active');
  });
  document.getElementById('MobileClose')?.addEventListener('click', () => {
    document.getElementById('MobileDrawer').classList.remove('active');
  });
</script>

{% schema %}
{
  "name": "Boutique Header",
  "settings": [
    { "type": "image_picker", "id": "logo", "label": "Logo Image" },
    { "type": "range", "id": "logo_width", "min": 30, "max": 300, "step": 10, "unit": "px", "label": "Logo Width", "default": 60 }
  ]
}
{% endschema %}
