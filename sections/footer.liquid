<style>
  .footer { background: #fff; padding: 100px 0 40px; border-top: 1px solid #f4f4f4; color: #1a1a1a; }
  .footer-grid { display: grid; grid-template-columns: 1.5fr 1fr 1fr 1.5fr; gap: 60px; margin-bottom: 80px; }
  
  .footer-col__title { font-size: 0.75rem; font-weight: 800; text-transform: uppercase; letter-spacing: 0.15em; color: #1a1a1a; margin-bottom: 25px; display: block; }
  .footer-col__text { font-size: 0.95rem; line-height: 1.8; color: #666; margin-bottom: 25px; }
  
  .footer-link { display: block; font-size: 0.9rem; color: #666; text-decoration: none; margin-bottom: 12px; transition: all 0.3s; }
  .footer-link:hover { color: var(--color-primary); transform: translateX(5px); }
  
  .footer-news__input-wrap { position: relative; margin-top: 20px; }
  .footer-news__input { width: 100%; padding: 15px 0; border: none; border-bottom: 2px solid #eee; outline: none; font-size: 0.9rem; transition: border-color 0.3s; background: transparent; }
  .footer-news__input:focus { border-color: var(--color-primary); }
  .footer-news__btn { position: absolute; right: 0; top: 12px; background: none; border: none; font-weight: 800; color: var(--color-primary); cursor: pointer; text-transform: uppercase; font-size: 0.7rem; letter-spacing: 0.1em; }

  .footer-socials { display: flex; gap: 20px; margin-top: 25px; }
  .footer-social-link { color: #aaa; transition: color 0.3s; }
  .footer-social-link:hover { color: var(--color-primary); }
  .footer-social-link svg { width: 20px; height: 20px; }

  .footer-bottom { border-top: 1px solid #f4f4f4; padding-top: 40px; display: flex; justify-content: space-between; align-items: center; }
  .footer-copy { font-size: 0.8rem; color: #999; }
  .footer-payments { display: flex; gap: 12px; }
  .footer-payments svg { width: 38px; height: 24px; opacity: 0.6; filter: grayscale(1); transition: opacity 0.3s; }
  .footer-payments svg:hover { opacity: 1; filter: none; }

  @media (max-width: 1024px) { .footer-grid { grid-template-columns: 1fr 1fr; gap: 40px; } }
  @media (max-width: 600px) { .footer-grid { grid-template-columns: 1fr; } .footer-bottom { flex-direction: column; gap: 25px; text-align: center; } }
</style>

<footer class="footer">
  <div class="container">
    <div class="footer-grid">
      <!-- Brand Story -->
      <div class="footer-col">
        <span class="footer-col__title">{{ shop.name }}</span>
        <p class="footer-col__text">Bringing softness and safety to every nursery. Our bamboo apparel is crafted with love for your little ones and the planet.</p>
        <div class="footer-socials">
          <a href="#" class="footer-social-link" title="Instagram">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M6.827 6.175A2.31 2.31 0 0 1 5.186 7.23c-.38.054-.757.112-1.134.175C2.999 7.58 2.25 8.507 2.25 9.574V18a2.25 2.25 0 0 0 2.25 2.25h15a2.25 2.25 0 0 0 2.25-2.25V9.574c0-1.067-.75-1.994-1.802-2.169a47.865 47.865 0 0 0-1.134-.175 2.31 2.31 0 0 1-1.64-1.055l-.822-1.316a2.192 2.192 0 0 0-1.736-1.039 48.774 48.774 0 0 0-5.232 0 2.192 2.192 0 0 0-1.736 1.039l-.821 1.316Z" /><path stroke-linecap="round" stroke-linejoin="round" d="M16.5 12.75a4.5 4.5 0 1 1-9 0 4.5 4.5 0 0 1 9 0ZM18.75 10.5h.008v.008h-.008V10.5Z" /></svg>
          </a>
          <a href="#" class="footer-social-link" title="Pinterest">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m15 11.25-3-3m0 0-3 3m3-3v7.5M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" /></svg>
          </a>
        </div>
      </div>

      <!-- Quick Links -->
      <div class="footer-col">
        <span class="footer-col__title">Shop</span>
        <a href="/collections/all" class="footer-link">Shop All</a>
        <a href="/collections/all?cat=dresses" class="footer-link">Dresses & Frocks</a>
        <a href="/collections/all?cat=bodysuits" class="footer-link">Bodysuits & Basics</a>
        <a href="/collections/all?cat=pajamas" class="footer-link">Pajamas & Nightsuits</a>
      </div>

      <!-- Support -->
      <div class="footer-col">
        <span class="footer-col__title">Support</span>
        <a href="/pages/faq" class="footer-link">FAQ</a>
        <a href="/pages/shipping" class="footer-link">Shipping & Returns</a>
        <a href="/pages/contact" class="footer-link">Contact Us</a>
        <a href="/pages/wholesale" class="footer-link">Wholesale</a>
      </div>

      <!-- Newsletter -->
      <div class="footer-col">
        <span class="footer-col__title">Stay in the Loop</span>
        <p class="footer-col__text">Join our family for exclusive launches and 15% OFF your first order.</p>
        <div class="footer-news__input-wrap">
          <input type="email" placeholder="Email Address" class="footer-news__input">
          <button class="footer-news__btn">Join</button>
        </div>
      </div>
    </div>

    <div class="footer-bottom">
      <p class="footer-copy">&copy; {{ 'now' | date: "%Y" }} {{ shop.name }}. All rights reserved.</p>
      <div class="footer-payments">
        {%- comment -%} Professional Payment SVGs {%- endcomment -%}
        <svg viewBox="0 0 38 24" xmlns="http://www.w3.org/2000/svg" role="img" width="38" height="24"><title>Visa</title><rect width="38" height="24" rx="4" fill="#1A1F71"/><path d="M14.5 17h-2.2l1.4-8.5h2.2L14.5 17zm11.2-8.3c-.5-.2-1.2-.4-2.1-.4-2.3 0-3.9 1.2-3.9 3 0 1.3 1.2 2 2 2.5.9.4 1.2.7 1.2 1.1 0 .6-.7.9-1.3.9-1.1 0-1.7-.2-2.6-.6l-.4-.2-.4 2.5c.7.3 2 .6 3.3.6 2.4 0 4-1.2 4-3.1 0-1-.6-1.8-2-2.4-.8-.4-1.3-.7-1.3-1.1 0-.4.4-.8 1.3-.8.7 0 1.3.2 1.8.4l.2.1.4-2.4zM32 8.5h-2.1c-.6 0-1.1.4-1.4 1l-3.9 8.5h2.3l.5-1.3h2.8l.3 1.3h2L32 8.5zm-3.2 5.8 1-2.7.5 2.7h-1.5zM8.5 8.5H5.4l-.1.4c2.4.6 4 2.1 4.7 3.9l.8-4.3h-2.3z" fill="#FFF"/></svg>
        <svg viewBox="0 0 38 24" xmlns="http://www.w3.org/2000/svg" role="img" width="38" height="24"><title>Mastercard</title><rect width="38" height="24" rx="4" fill="#222"/><circle cx="15" cy="12" r="7" fill="#EB001B"/><circle cx="23" cy="12" r="7" fill="#F79E1B"/><path d="M19 12a6.97 6.97 0 0 0 2.7-5.5 6.97 6.97 0 0 0-5.4 0 6.97 6.97 0 0 0 2.7 5.5z" fill="#FF5F00"/></svg>
        <svg viewBox="0 0 38 24" xmlns="http://www.w3.org/2000/svg" role="img" width="38" height="24"><title>Amex</title><rect width="38" height="24" rx="4" fill="#0070D1"/><path d="M13.6 15.5h-1.4l-.2-1.1H10l-.2 1.1H8.4l1.3-7h1.6l1.3 7zM11.5 10l-.6 3.1h1.2L11.5 10zM17.5 8.5l1.1 4 1.1-4h1.6v7h-1.4V10l-1.1 4.1h-.6l-1.1-4.1v5.5h-1.4v-7h1.8zM24 8.5h4.2v1.2H25.4v1.5h2.4v1.2h-2.4v1.9h2.8v1.2H24v-7zM31 8.5h1.6l1.2 2.3 1.2-2.3h1.6l-2 3.5 2 3.5h-1.6l-1.2-2.3-1.2 2.3H31l2-3.5-2-3.5z" fill="#FFF"/></svg>
      </div>
    </div>
  </div>
</footer>

