<style>
  .footer { background: var(--color-text-dark); padding: 100px 0 40px; color: #fff; }
  .footer__grid { display: grid; grid-template-columns: 1.5fr repeat(3, 1fr) 1.5fr; gap: 40px; }
  
  .footer__col-title { font-weight: 800; font-size: 0.85rem; text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 24px; display: block; color: rgba(255,255,255,0.6); }
  .footer__link { display: block; font-size: 0.9rem; color: #fff; margin-bottom: 12px; transition: color 0.2s; opacity: 0.8; text-decoration: none; }
  .footer__link:hover { color: var(--color-primary); opacity: 1; }
  
  .footer__socials { display: flex; gap: 15px; margin-top: 20px; }
  .footer__social-icon { width: 40px; height: 40px; border-radius: 50%; border: 1px solid rgba(255,255,255,0.1); display: flex; align-items: center; justify-content: center; transition: all 0.3s; color: #fff; }
  .footer__social-icon:hover { border-color: var(--color-primary); color: var(--color-primary); transform: translateY(-3px); }
  
  .footer__contact-item { display: flex; align-items: center; gap: 12px; font-size: 0.9rem; color: rgba(255,255,255,0.8); margin-bottom: 12px; }
  .footer__nicus { background: rgba(255,255,255,0.05); padding: 20px; border-radius: 12px; margin-top: 30px; display: flex; align-items: center; gap: 15px; font-size: 0.85rem; }

  .footer__bottom { margin-top: 80px; padding-top: 30px; border-top: 1px solid rgba(255,255,255,0.1); display: flex; justify-content: space-between; align-items: center; font-size: 0.8rem; color: rgba(255,255,255,0.4); }

  @media (max-width: 1024px) { .footer__grid { grid-template-columns: 1fr 1fr; } }
  @media (max-width: 600px) { .footer__grid { grid-template-columns: 1fr; } }
</style>

<footer class="footer">
  <div class="container">
    <div class="footer__grid">
      
      <!-- Branding -->
      <div class="footer__col">
        <h2 style="color:#fff; margin-bottom: 20px; font-size: 1.8rem;">Rainbow Kids Hub</h2>
        <p style="font-size: 0.9rem; line-height: 1.7; opacity: 0.7;">
          Soft clothing for little ones. Join our community of happy mamas.
        </p>
        <div class="footer__nicus">
          <span style="font-size: 1.5rem;">💛</span>
          <span>We donate to NICUs.</span>
        </div>
        <div class="footer__socials">
          <a href="https://www.instagram.com/rainbowkidshub26/" class="footer__social-icon">{% render 'icon', icon: 'instagram' %}</a>
          <a href="https://share.google/3KW7AdBGh5ncM2c52" class="footer__social-icon">{% render 'icon', icon: 'star' %}</a>
        </div>
      </div>

      <!-- Shop -->
      <div class="footer__col">
        <span class="footer__col-title">Help</span>
        <a href="/collections/all" class="footer__link">Shop All</a>
        <a href="/collections/new-arrivals" class="footer__link">New Arrivals</a>
        <a href="/collections/sleep-bags" class="footer__link">Sleep Bags</a>
      </div>

      <!-- Account -->
      <div class="footer__col">
        <span class="footer__col-title">Account</span>
        <a href="/account/login" class="footer__link">Login</a>
        <a href="/account/register" class="footer__link">Create Account</a>
        <a href="/pages/rewards" class="footer__link">Rewards</a>
      </div>

      <!-- Resources -->
      <div class="footer__col">
        <span class="footer__col-title">Resources</span>
        <a href="/pages/faq" class="footer__link">FAQs</a>
        <a href="/pages/size-chart" class="footer__link">Size Chart</a>
        <a href="/pages/contact" class="footer__link">Contact Us</a>
      </div>

      <!-- About -->
      <div class="footer__col">
        <span class="footer__col-title">About</span>
        <a href="/pages/about" class="footer__link">Our Story</a>
        <a href="/pages/why-bamboo" class="footer__link">Why Bamboo</a>
        <a href="/pages/kyte-cares" class="footer__link">Kyte Cares</a>
      </div>

    </div>

    <div class="footer__bottom">
      <p>&copy; {{ 'now' | date: '%Y' }} Rainbow Kids Hub.</p>
      <div style="display:flex; gap: 20px;">
        <a href="/policies/privacy-policy" style="color:inherit;">Privacy</a>
        <a href="/policies/terms-of-service" style="color:inherit;">Terms</a>
      </div>
    </div>
  </div>
</footer>

{% schema %}
{ "name": "Footer" }
{% endschema %}
