<style>
  .footer { background: var(--color-text-dark); padding: 100px 0 40px; color: #fff; }
  .footer__grid { display: grid; grid-template-columns: 1.5fr repeat(3, 1fr) 1.5fr; gap: 40px; }
  
  .footer__col-title { font-weight: 800; font-size: 0.85rem; text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 24px; display: block; color: rgba(255,255,255,0.6); }
  .footer__link { display: block; font-size: 0.9rem; color: #fff; margin-bottom: 12px; transition: color 0.2s; opacity: 0.8; text-decoration: none; }
  .footer__link:hover { color: #F8C8DC; opacity: 1; }
  
  .footer__socials { display: flex; gap: 15px; margin-top: 20px; }
  .footer__social-icon { width: 40px; height: 40px; border-radius: 50%; border: 1px solid rgba(255,255,255,0.1); display: flex; align-items: center; justify-content: center; transition: all 0.3s; color: #fff; }
  .footer__social-icon:hover { border-color: #F8C8DC; color: #F8C8DC; transform: translateY(-3px); }

  .footer__bottom { margin-top: 80px; padding-top: 30px; border-top: 1px solid rgba(255,255,255,0.1); display: flex; justify-content: space-between; align-items: center; font-size: 0.8rem; color: rgba(255,255,255,0.4); }

  @media (max-width: 1024px) { .footer__grid { grid-template-columns: 1fr 1fr; } }
  @media (max-width: 600px) { .footer__grid { grid-template-columns: 1fr; } }
</style>

<footer class="footer">
  <div class="container">
    <div class="footer__grid">
      
      <!-- Branding -->
      <div class="footer__col">
        <h2 style="color:#fff; margin-bottom: 20px; font-size: 1.8rem;">{{ shop.name }}</h2>
        <p style="font-size: 0.9rem; line-height: 1.7; opacity: 0.7;">
          {{ section.settings.description }}
        </p>
        <div class="footer__socials">
          {%- if settings.social_instagram_link != blank -%}
            <a href="{{ settings.social_instagram_link }}" class="footer__social-icon">{% render 'icon', icon: 'instagram' %}</a>
          {%- endif -%}
        </div>
      </div>

      {%- for block in section.blocks -%}
        <div class="footer__col">
          <span class="footer__col-title">{{ block.settings.title }}</span>
          {%- if block.settings.menu != blank -%}
            {%- for link in block.settings.menu.links -%}
              <a href="{{ link.url }}" class="footer__link">{{ link.title }}</a>
            {%- endfor -%}
          {%- endif -%}
        </div>
      {%- endfor -%}

    </div>

    <div class="footer__bottom">
      <p>&copy; {{ 'now' | date: '%Y' }} {{ shop.name }}.</p>
      <div style="display:flex; gap: 20px;">
        <a href="/policies/privacy-policy" style="color:inherit; text-decoration:none;">Privacy</a>
        <a href="/policies/terms-of-service" style="color:inherit; text-decoration:none;">Terms</a>
      </div>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Boutique Footer",
  "settings": [
    { "type": "textarea", "id": "description", "label": "Shop Description", "default": "Soft clothing for little ones. Join our community of happy mamas." }
  ],
  "blocks": [
    {
      "type": "menu",
      "name": "Menu Column",
      "settings": [
        { "type": "text", "id": "title", "label": "Column Title", "default": "Support" },
        { "type": "link_list", "id": "menu", "label": "Menu" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Boutique Footer",
      "blocks": [
        { "type": "menu", "settings": { "title": "Help" } },
        { "type": "menu", "settings": { "title": "Resources" } },
        { "type": "menu", "settings": { "title": "About" } }
      ]
    }
  ]
}
{% endschema %}
