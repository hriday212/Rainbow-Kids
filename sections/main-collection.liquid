<style>
  {% include 'static-products' %}
  .collection-grid { padding: 60px 0; background: #fff; }
  .collection-layout { display: grid; grid-template-columns: 280px 1fr; gap: 60px; }
  
  .sidebar-section { margin-bottom: 40px; padding-bottom: 30px; border-bottom: 1px solid #f4f4f4; }
  .sidebar-title { font-size: 0.75rem; font-weight: 800; text-transform: uppercase; letter-spacing: 0.15em; color: #1a1a1a; margin-bottom: 25px; display: block; }
  
  .filter-list { list-style: none; padding: 0; margin: 0; }
  .filter-link { display: block; padding: 10px 0; font-size: 0.95rem; color: #666; text-decoration: none; transition: color 0.3s; }
  .filter-link:hover, .filter-link.active { color: var(--color-primary); font-weight: 700; }
  
  /* Elite Sort By */
  .elite-sort { position: relative; display: flex; align-items: center; gap: 15px; }
  .elite-sort__label { font-size: 0.75rem; font-weight: 800; text-transform: uppercase; letter-spacing: 0.1em; color: #999; }
  .elite-sort__select { background: none; border: none; border-bottom: 1.5px solid #1a1a1a; padding: 5px 20px 5px 0; font-weight: 800; font-size: 0.85rem; text-transform: uppercase; cursor: pointer; outline: none; }

  .product-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 30px; }
  .product-card { text-decoration: none; color: inherit; display: block; transition: transform 0.3s; }
  .product-card:hover { transform: translateY(-5px); }
  .product-card__img { aspect-ratio: 4/5; border-radius: 12px; overflow: hidden; background: #f9f9f9; margin-bottom: 15px; position: relative; }
  
  @media (max-width: 1024px) { .collection-layout { grid-template-columns: 1fr; } .product-grid { grid-template-columns: repeat(2, 1fr); } }
</style>

<section class="collection-grid">
  <div class="container">
    <div class="collection-layout">
      <!-- Sidebar -->
      <aside class="collection-sidebar">
        <div class="sidebar-section">
          <span class="sidebar-title">Category</span>
          <div class="filter-list">
            <a href="/collections/all" class="filter-link active" data-category="all">All Products</a>
            <a href="#" class="filter-link" data-category="dresses">Dresses & Frocks</a>
            <a href="#" class="filter-link" data-category="pajamas">Pajamas & Nightsuits</a>
            <a href="#" class="filter-link" data-category="sets">Sets & Dungarees</a>
            <a href="#" class="filter-link" data-category="bodysuits">Bodysuits & Basics</a>
            <a href="#" class="filter-link" data-category="accessories">Bedding & Accessories</a>
          </div>
        </div>
        
        <div class="sidebar-section">
          <span class="sidebar-title">Availability</span>
          <div style="display:flex; flex-direction:column; gap:10px;">
            <label style="display:flex; align-items:center; gap:10px; font-size:0.9rem; cursor:pointer;"><input type="checkbox" checked> In Stock</label>
            <label style="display:flex; align-items:center; gap:10px; font-size:0.9rem; cursor:pointer;"><input type="checkbox"> Out of Stock</label>
          </div>
        </div>

        <div class="sidebar-section">
          <span class="sidebar-title">Color Palette</span>
          <div style="display:flex; gap:10px; flex-wrap:wrap;">
            <div style="width:25px; height:25px; border-radius:50%; background:#F8D7E3; border:1px solid #eee; cursor:pointer;"></div>
            <div style="width:25px; height:25px; border-radius:50%; background:#D7E9F8; border:1px solid #eee; cursor:pointer;"></div>
            <div style="width:25px; height:25px; border-radius:50%; background:#E3D7F8; border:1px solid #eee; cursor:pointer;"></div>
          </div>
        </div>
      </aside>

      <!-- Main Grid -->
      <main class="collection-main">
        <div style="margin-bottom: 60px; display: flex; justify-content: space-between; align-items: center;">
          <div>
            <h1 style="font-family: var(--font-heading); font-size: 3.5rem; margin: 0;">{{ section.settings.title | default: collection.title | default: "Our Shop" }}</h1>
          </div>
          
          <div class="elite-sort">
            <span class="elite-sort__label">Sort By</span>
            <select class="elite-sort__select">
              <option>Bestsellers</option>
              <option>Newest First</option>
              <option>Price: Low to High</option>
              <option>Price: High to Low</option>
            </select>
          </div>
        </div>

        <div class="product-grid">
          {%- assign target_collection = section.settings.collection | default: collection -%}
          {%- if target_collection.products.size > 0 -%}
            {%- for product in target_collection.products -%}
              <a href="{{ product.url }}" class="product-card js-filter-item" data-category="sets">
                <div class="product-card__img">
                  <img src="{{ product.featured_image | image_url: width: 800 }}" style="width:100%; height:100%; object-fit:cover;">
                </div>
                <h3 style="font-family: var(--font-heading); font-size: 1.1rem; margin: 0 0 5px;">{{ product.title }}</h3>
                <p style="font-weight: 700; color: var(--color-primary);">{{ product.price | money }}</p>
              </a>
            {%- endfor -%}
          {%- endif -%}

          {%- for image_name in static_product_images -%}
            {%- assign di = forloop.index0 -%}
            {%- assign category = "all" -%}
            {%- if image_name contains "dress" or image_name contains "frock" or image_name contains "gown" or image_name contains "tutu" -%}
              {%- assign category = "dresses" -%}
            {%- elsif image_name contains "nightsuit" or image_name contains "pajama" or image_name contains "sleeping-bag" -%}
              {%- assign category = "pajamas" -%}
            {%- elsif image_name contains "set" or image_name contains "dungaree" or image_name contains "polo" or image_name contains "soccer" -%}
              {%- assign category = "sets" -%}
            {%- elsif image_name contains "mattress" or image_name contains "pillow" or image_name contains "pad" or image_name contains "bottles" or image_name contains "sunglasses" -%}
              {%- assign category = "accessories" -%}
            {%- else -%}
              {%- assign category = "bodysuits" -%}
            {%- endif -%}
              
              <a href="/products/{{ image_name | remove: '.webp' | handleize }}" class="product-card js-filter-item" data-category="{{ category }}">
                <div class="product-card__img">
                  <img src="{{ image_name | asset_url }}" style="width:100%; height:100%; object-fit:cover;" alt="{{ image_name | remove: '.webp' | replace: '-', ' ' }}">
                </div>
                <h3 style="font-family: var(--font-heading); font-size: 1.1rem; margin: 0 0 5px; text-transform: capitalize;">{{ image_name | remove: '.webp' | replace: '-', ' ' | split: '(' | first }}</h3>
                <p style="font-weight: 700; color: var(--color-primary);">{{ static_product_prices[di] }}</p>
              </a>
            {%- endfor -%}
        </div>
      </main>
    </div>
  </div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const filterLinks = document.querySelectorAll('.filter-link[data-category]');
    const filterItems = document.querySelectorAll('.js-filter-item');
    const pageTitle = document.querySelector('.collection-main h1');

    filterLinks.forEach(link => {
      link.addEventListener('click', function(e) {
        e.preventDefault();
        const category = this.getAttribute('data-category');
        
        // Update Active State
        filterLinks.forEach(l => l.classList.remove('active'));
        this.classList.add('active');

        // Update Title
        if(category === 'all') {
          pageTitle.textContent = 'All Products';
        } else {
          pageTitle.textContent = this.textContent;
        }

        // Filter Items
        filterItems.forEach(item => {
          if (category === 'all' || item.getAttribute('data-category') === category) {
            item.style.display = 'block';
          } else {
            item.style.display = 'none';
          }
        });

        // Smooth Scroll to Top of Grid
        window.scrollTo({ top: document.querySelector('.collection-main').offsetTop - 150, behavior: 'smooth' });
      });
    });

    // Handle URL param if coming from header
    const urlParams = new URLSearchParams(window.location.search);
    const catParam = urlParams.get('cat');
    if(catParam) {
      const targetLink = document.querySelector(`.filter-link[data-category="${catParam}"]`);
      if(targetLink) targetLink.click();
    }
  });
</script>

{% schema %}
{
  "name": "Elite Collection Grid",
  "settings": [
    { "type": "text", "id": "title", "label": "Custom Heading" },
    { "type": "collection", "id": "collection", "label": "Select Collection" },
    {
      "type": "select",
      "id": "active_category",
      "label": "Active Sidebar Link",
      "options": [
        { "value": "none", "label": "None" },
        { "value": "sleep-bags", "label": "Sleep Bags" },
        { "value": "pajamas", "label": "Pajamas" },
        { "value": "bodysuits", "label": "Bodysuits" },
        { "value": "newborn", "label": "Newborn" }
      ],
      "default": "none"
    }
  ]
}
{% endschema %}
