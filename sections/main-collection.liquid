<style>
  .collection-page { padding: 60px 0; background: var(--color-background); min-height: 100vh; }
  .collection-layout { display: grid; grid-template-columns: 280px 1fr; gap: 60px; }
  
  .collection-toolbar { display: flex; justify-content: space-between; align-items: center; margin-bottom: 40px; padding-bottom: 20px; border-bottom: 1px solid rgba(0,0,0,0.05); }
  .sort-dropdown { border: none; background: none; font-size: 0.85rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: #1a1a1a; cursor: pointer; outline: none; }

  .collection-sidebar { position: sticky; top: 120px; height: fit-content; }
  .filter-group { margin-bottom: 30px; border-bottom: 1px solid rgba(0,0,0,0.05); padding-bottom: 20px; }
  .filter-group__title { font-size: 0.75rem; font-weight: 800; text-transform: uppercase; letter-spacing: 0.15em; color: #1a1a1a; margin-bottom: 20px; display: flex; justify-content: space-between; align-items: center; }
  
  .swatch-grid { display: grid; grid-template-columns: repeat(5, 1fr); gap: 10px; }
  .swatch { width: 30px; height: 30px; border-radius: 50%; border: 1px solid #eee; cursor: pointer; transition: transform 0.2s; }
  .swatch:hover { transform: scale(1.2); }

  .collection-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 40px 20px; }

  @media (max-width: 1024px) { .collection-layout { grid-template-columns: 1fr; } .collection-sidebar { display: none; } }
</style>

<section class="collection-page">
  <div class="container">
    <header style="margin-bottom: 40px;">
      <h1 style="font-family:var(--font-heading); font-size: 3.5rem; margin:0;">{{ collection.title | default: "All Apparel" }}</h1>
    </header>

    <div class="collection-toolbar">
      <p style="color:#888; margin:0;">{{ collection.products_count | default: 24 }} Items</p>
      <div style="display:flex; align-items:center; gap:10px;">
        <span style="font-size:0.7rem; font-weight:800; color:#999; text-transform:uppercase;">Sort By:</span>
        <select class="sort-dropdown">
          <option>Featured</option>
          <option>Best Selling</option>
          <option>Newest</option>
          <option>Price: Low to High</option>
          <option>Price: High to Low</option>
        </select>
      </div>
    </div>

    <div class="collection-layout">
      <aside class="collection-sidebar">
        <div class="filter-group">
          <span class="filter-group__title">Availability</span>
          <label style="display:flex;align-items:center;gap:10px;font-size:0.9rem;color:#666;margin-bottom:10px;"><input type="checkbox" checked> In Stock</label>
          <label style="display:flex;align-items:center;gap:10px;font-size:0.9rem;color:#666;"><input type="checkbox"> Out of Stock</label>
        </div>

        <div class="filter-group">
          <span class="filter-group__title">Color Palette</span>
          <div class="swatch-grid">
            <div class="swatch" style="background: var(--color-pink);" title="Blossom"></div>
            <div class="swatch" style="background: var(--color-blue);" title="Cloud"></div>
            <div class="swatch" style="background: var(--color-lavender);" title="Lavender"></div>
            <div class="swatch" style="background: var(--color-primary);" title="Coral"></div>
            <div class="swatch" style="background: var(--color-mint);" title="Sage"></div>
          </div>
        </div>

        <div class="filter-group">
          <span class="filter-group__title">Category</span>
          <ul style="list-style:none;padding:0;margin:0;">
            <li style="margin-bottom:10px;"><a href="#" style="text-decoration:none;color:#666;font-size:0.9rem;">Sleep Bags</a></li>
            <li style="margin-bottom:10px;"><a href="#" style="text-decoration:none;color:#666;font-size:0.9rem;">Pajamas</a></li>
            <li style="margin-bottom:10px;"><a href="#" style="text-decoration:none;color:#666;font-size:0.9rem;">Bodysuits</a></li>
          </ul>
        </div>
      </aside>

      <main class="collection-main">
        <div class="collection-grid">
          {%- for i in (1..9) -%}
            <div class="product-card">
              <div class="product-card__image-wrap" style="aspect-ratio:1/1.2; border-radius:12px; overflow:hidden; background:#fff; margin-bottom:15px; position:relative;">
                <img src="https://images.unsplash.com/photo-1522771917710-2ee211117f77?q=80&w=600" style="width:100%; height:100%; object-fit:cover;">
                {% if i == 1 %}
                  <span class="badge badge--new" style="position:absolute; top:10px; right:10px;">NEW</span>
                {% elsif i == 2 %}
                  <span class="badge badge--sale" style="position:absolute; top:10px; right:10px;">SALE</span>
                {% elsif i == 3 %}
                  <span class="badge badge--exclusive" style="position:absolute; top:10px; right:10px;">LIMIT</span>
                {% endif %}
              </div>
              <h3 style="font-family:var(--font-heading); font-size:1.1rem; margin:0 0 5px;">Bamboo Apparel {{ i }}</h3>
              <p style="font-weight:700; color:var(--color-primary);">$55.00</p>
            </div>
          {%- endfor -%}
        </div>
      </main>
    </div>
  </div>
</section>

{% schema %}
{ "name": "Elite Collection Grid", "settings": [] }
{% endschema %}
