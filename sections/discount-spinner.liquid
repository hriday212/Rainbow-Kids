<style>
  #spinner-popup {
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.6);
    z-index: 20000;
    display: none; /* Controlled by JS */
    align-items: center;
    justify-content: center;
    backdrop-filter: blur(10px);
  }
  
  .spinner-content {
    background: #fff;
    padding: 60px;
    border-radius: 40px;
    text-align: center;
    max-width: 500px;
    width: 90%;
    position: relative;
    box-shadow: 0 40px 100px rgba(0,0,0,0.2);
  }
  
  .spinner-title { font-family: var(--font-heading); font-size: 2.5rem; margin-bottom: 20px; color: #1a1a1a; }
  .spinner-text { font-size: 1.1rem; color: #666; margin-bottom: 40px; }
  
  .wheel-wrap { position: relative; width: 300px; height: 300px; margin: 0 auto 40px; }
  .wheel { width: 100%; height: 100%; border-radius: 50%; border: 10px solid #f4f4f4; transition: transform 4s cubic-bezier(0.15, 0, 0.15, 1); background: conic-gradient(var(--color-pink) 0deg 90deg, var(--color-blue) 90deg 180deg, var(--color-lavender) 180deg 270deg, var(--color-primary) 270deg 360deg); }
  
  .wheel-pointer { position: absolute; top: -20px; left: 50%; transform: translateX(-50%); width: 0; height: 0; border-left: 15px solid transparent; border-right: 15px solid transparent; border-top: 30px solid #1a1a1a; z-index: 10; }
  
  .spin-btn { padding: 20px 60px; background: #1a1a1a; color: #fff; border-radius: 50px; font-weight: 800; text-transform: uppercase; cursor: pointer; border: none; }
</style>

<div id="spinner-popup">
  <div class="spinner-content animate-reveal">
    <button style="position:absolute; top:30px; right:30px; background:none; border:none; font-size:2rem; cursor:pointer;" id="CloseSpinner">&times;</button>
    <h2 class="spinner-title">Spin for a Sweet Deal! 🎡</h2>
    <p class="spinner-text">Win up to 25% off your first boutique order.</p>
    
    <div class="wheel-wrap">
      <div class="wheel-pointer"></div>
      <div class="wheel" id="LuckyWheel"></div>
    </div>
    
    <button class="spin-btn" id="SpinStart">Spin the Wheel</button>
  </div>
</div>

<script>
  const popup = document.getElementById('spinner-popup');
  const wheel = document.getElementById('LuckyWheel');
  const spinBtn = document.getElementById('SpinStart');
  const closeBtn = document.getElementById('CloseSpinner');

  // Check if already spun
  if (!localStorage.getItem('rainbow_spun')) {
    setTimeout(() => {
      popup.style.display = 'flex';
    }, 5000); // Show after 5 seconds
  }

  spinBtn?.addEventListener('click', () => {
    const randomDeg = 1800 + Math.floor(Math.random() * 360);
    wheel.style.transform = `rotate(${randomDeg}deg)`;
    spinBtn.disabled = true;
    spinBtn.innerText = "Good Luck!";
    
    localStorage.setItem('rainbow_spun', 'true'); // Mark as spun

    setTimeout(() => {
      alert("You won 15% OFF! Use code: RAINBOW15");
      popup.style.display = 'none';
    }, 4500);
  });

  closeBtn?.addEventListener('click', () => {
    popup.style.display = 'none';
    localStorage.setItem('rainbow_spun', 'true'); // Don't show again this visit
  });
</script>

{% schema %}
{ "name": "Discount Spinner", "settings": [] }
{% endschema %}
