<style>
  .spinner-overlay {
    position: fixed; inset: 0; width: 100vw; height: 100vh;
    background: rgba(252, 248, 241, 0.8); backdrop-filter: blur(12px);
    z-index: 10000; display: flex; align-items: center; justify-content: center;
    opacity: 0; pointer-events: none; transition: opacity 0.8s cubic-bezier(0.19, 1, 0.22, 1);
  }
  .spinner-overlay.show { opacity: 1; pointer-events: all; }

  .spinner-modal {
    background: #fff; padding: 60px 40px; border-radius: 40px; text-align: center;
    position: relative; width: 480px; max-width: 90vw;
    box-shadow: 0 40px 100px rgba(0,0,0,0.08);
    transform: translateY(30px); transition: transform 0.8s cubic-bezier(0.19, 1, 0.22, 1);
    border: 1px solid rgba(255,255,255,0.5);
  }
  .spinner-overlay.show .spinner-modal { transform: translateY(0); }

  .spinner-close { position: absolute; top: 25px; right: 25px; background: none; border: none; font-size: 1.8rem; cursor: pointer; color: #ccc; transition: color 0.3s; }
  .spinner-close:hover { color: #1a1a1a; }

  .spinner-wheel-wrap { position: relative; margin: 0 auto 40px; width: 300px; height: 300px; }
  .spinner-pointer { 
    width: 0; height: 0; border-left: 12px solid transparent; border-right: 12px solid transparent;
    border-top: 20px solid #1a1a1a; position: absolute; top: -10px; left: 50%; transform: translateX(-50%); z-index: 10;
  }
  .spinner-wheel {
    width: 100%; height: 100%; border-radius: 50%;
    background: conic-gradient(
      #FDF4F2 0 120deg,
      #F1F8FD 120deg 240deg,
      #F6FDF1 240deg 360deg
    );
    position: relative; transition: transform 4s cubic-bezier(0.15, 0, 0.15, 1);
    border: 8px solid #fff; box-shadow: 0 10px 40px rgba(0,0,0,0.05);
  }
  .s-label { position: absolute; top: 50%; left: 50%; font-weight: 800; font-size: 1.2rem; color: #1a1a1a; }
  .s-label-1 { transform: rotate(60deg) translate(60px, -15px); }
  .s-label-2 { transform: rotate(180deg) translate(60px, -15px); }
  .s-label-3 { transform: rotate(300deg) translate(60px, -15px); }

  .spinner-title { font-family: var(--font-heading); font-size: 2.5rem; margin-bottom: 10px; color: #1a1a1a; font-weight: 400; }
  .spinner-text { font-size: 1rem; color: #666; margin-bottom: 30px; line-height: 1.6; }

  .spinner-form input { width: 100%; padding: 18px; border-radius: 12px; border: 1px solid #eee; margin-bottom: 15px; text-align: center; font-size: 1rem; }
  .spinner-form .button { width: 100%; padding: 18px; background: #1a1a1a; color: #fff; border-radius: 12px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; cursor: pointer; border: none; }
</style>

<div class="spinner-overlay" id="SpinnerOverlay">
  <div class="spinner-modal">
    <button class="spinner-close" id="SpinnerClose">&times;</button>
    <h2 class="spinner-title">Spin to Win</h2>
    <p class="spinner-text">Unlock a special welcome gift for your little one.</p>
    
    <div class="spinner-wheel-wrap">
      <div class="spinner-pointer"></div>
      <div class="spinner-wheel" id="Wheel">
        <div class="s-label s-label-1">10%</div>
        <div class="s-label s-label-2">15%</div>
        <div class="s-label s-label-3">20%</div>
      </div>
    </div>

    <div class="spinner-form" id="SpinnerForm">
      <input type="email" id="SpinnerEmail" placeholder="Your email address" required>
      <button type="button" class="button" id="SpinButton">Try My Luck</button>
    </div>
    
    <div id="SpinnerResult" style="display:none; animation: fadeUp 0.6s forwards;">
      <h3 style="font-family:var(--font-heading); font-size: 2.2rem; color:#1a1a1a; margin-bottom:10px;">It's Your Lucky Day!</h3>
      <p style="font-size: 1.1rem; color:#666;">You won <strong style="color:#1a1a1a;">20% OFF</strong> your first order.</p>
      <div style="margin-top:20px; padding: 15px; background: #f9f9f9; border-radius: 8px; font-weight: 800; letter-spacing: 0.1em;">CODE: RAINBOW20</div>
    </div>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    // Temporarily disabled check so you can see it pop up for testing
    // if (!localStorage.getItem('rainbow_spun')) {
      setTimeout(() => {
        const overlay = document.getElementById('SpinnerOverlay');
        if (overlay) overlay.classList.add('show');
      }, 4000);
    // }
    const closeSpinner = () => {
      document.getElementById('SpinnerOverlay').classList.remove('show');
      localStorage.setItem('rainbow_spun', 'dismissed');
    };
    const closeBtn = document.getElementById('SpinnerClose');
    if (closeBtn) closeBtn.addEventListener('click', closeSpinner);
    
    const spinBtn = document.getElementById('SpinButton');
    if (spinBtn) {
      spinBtn.addEventListener('click', () => {
        const email = document.getElementById('SpinnerEmail').value;
        if(!email || !email.includes('@')) return alert('Valid email please!');
        document.getElementById('Wheel').style.transform = `rotate(1860deg)`;
        setTimeout(() => {
          document.getElementById('SpinnerForm').style.display = 'none';
          document.getElementById('SpinnerResult').style.display = 'block';
          localStorage.setItem('rainbow_spun', 'won');
        }, 4000);
      });
    }
  });
</script>

{% schema %}
{ "name": "Boutique Spinner" }
{% endschema %}
