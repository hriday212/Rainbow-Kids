<style>
  .faq { padding: 100px 0; background: var(--color-background); }
  .faq__header { text-align: center; margin-bottom: 60px; }
  
  .faq__container { max-width: 800px; margin: 0 auto; display: flex; flex-direction: column; gap: 16px; }
  
  .faq__item { background: #fff; border-radius: 16px; border: 1px solid #f4f4f4; overflow: hidden; transition: all 0.3s; }
  .faq__item:hover { border-color: var(--color-primary); box-shadow: 0 10px 30px rgba(0,0,0,0.02); }
  
  .faq__question { width: 100%; padding: 24px 32px; display: flex; justify-content: space-between; align-items: center; background: none; border: none; cursor: pointer; text-align: left; font-size: 1.1rem; font-weight: 700; color: var(--color-text-dark); transition: color 0.3s; }
  .faq__item.active .faq__question { color: var(--color-primary); filter: brightness(0.8); }
  
  .faq__icon { width: 24px; height: 24px; position: relative; transition: transform 0.4s; }
  .faq__icon::before, .faq__icon::after { content: ''; position: absolute; background: currentColor; transition: transform 0.4s; }
  .faq__icon::before { width: 14px; height: 2px; top: 11px; left: 5px; }
  .faq__icon::after { width: 2px; height: 14px; top: 5px; left: 11px; }
  .faq__item.active .faq__icon { transform: rotate(135deg); }
  .faq__item.active .faq__icon::after { display: none; }

  .faq__answer { max-height: 0; overflow: hidden; transition: all 0.5s var(--ease-smooth); padding: 0 32px; opacity: 0; }
  .faq__item.active .faq__answer { max-height: 500px; padding-bottom: 32px; opacity: 1; }
  .faq__answer-text { font-size: 1rem; line-height: 1.7; color: var(--color-text-light); }

  @media (max-width: 768px) { .faq__question { padding: 20px; font-size: 1rem; } .faq__answer { padding: 0 20px; } }
</style>

<section class="faq animate-reveal">
  <div class="container">
    
    <div class="faq__header" data-aos="fade-up">
      <span class="section-tag">Help Center</span>
      <h2 style="font-size: 3rem;">Frequently Asked Questions</h2>
    </div>

    <div class="faq__container">
      {%- if section.blocks.size > 0 -%}
        {%- for block in section.blocks -%}
          <div class="faq__item" data-aos="fade-up" data-aos-delay="{{ forloop.index | times: 100 }}" {{ block.shopify_attributes }}>
            <button class="faq__question">
              {{ block.settings.question }}
              <div class="faq__icon"></div>
            </button>
            <div class="faq__answer">
              <div class="faq__answer-text">{{ block.settings.answer }}</div>
            </div>
          </div>
        {%- endfor -%}
      {%- else -%}
        {%- for i in (1..3) -%}
          <div class="faq__item">
            <button class="faq__question">Sample Question {{ i }} <div class="faq__icon"></div></button>
            <div class="faq__answer"><div class="faq__answer-text">Sample answer text goes here.</div></div>
          </div>
        {%- endfor -%}
      {%- endif -%}
    </div>

  </div>
</section>

<script>
  document.querySelectorAll('.faq__question').forEach(button => {
    button.addEventListener('click', () => {
      const item = button.parentElement;
      item.classList.toggle('active');
    });
  });
</script>

{% schema %}
{
  "name": "FAQ Accordion",
  "blocks": [
    {
      "type": "faq",
      "name": "FAQ Item",
      "settings": [
        { "type": "text", "id": "question", "label": "Question", "default": "How long does shipping take?" },
        { "type": "textarea", "id": "answer", "label": "Answer", "default": "Orders are processed within 1-2 business days. Shipping usually takes 3-5 days." }
      ]
    }
  ],
  "presets": [
    {
      "name": "FAQ Accordion",
      "blocks": [
        { "type": "faq", "settings": { "question": "What is your return policy?", "answer": "We offer 30-day easy returns on all unwashed and unworn items." } },
        { "type": "faq", "settings": { "question": "How do I choose the right TOG?", "answer": "Check our TOG Guide for detailed temperature charts!" } }
      ]
    }
  ]
}
{% endschema %}
