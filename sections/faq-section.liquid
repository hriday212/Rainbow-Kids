<style>
  .faq-section { padding: 100px 0; background: #fff; }
  .faq-header { text-align: center; margin-bottom: 60px; }
  .faq-title { font-family: var(--font-heading); font-size: 3.5rem; font-weight: 400; color: #1a1a1a; }
  
  .faq-container { max-width: 800px; margin: 0 auto; display: flex; flex-direction: column; gap: 15px; }
  .faq-item { border: 1px solid #eee; border-radius: 12px; overflow: hidden; transition: all 0.3s; }
  .faq-question { width: 100%; padding: 25px 30px; display: flex; justify-content: space-between; align-items: center; background: none; border: none; font-size: 1.1rem; font-weight: 700; color: #1a1a1a; cursor: pointer; text-align: left; }
  .faq-question svg { width: 14px; height: 14px; transition: transform 0.3s; }
  .faq-item.active { border-color: #1a1a1a; box-shadow: 0 10px 30px rgba(0,0,0,0.05); }
  .faq-item.active .faq-question svg { transform: rotate(180deg); }
  
  .faq-answer { max-height: 0; overflow: hidden; transition: max-height 0.4s var(--ease-smooth); background: #fdfdfd; }
  .faq-answer-inner { padding: 0 30px 25px; font-size: 1rem; color: #666; line-height: 1.8; }
</style>

<section class="faq-section">
  <div class="container">
    <div class="faq-header animate-reveal">
      <h2 class="faq-title">Frequently Asked Questions</h2>
    </div>

    <div class="faq-container">
      {%- for block in section.blocks -%}
        <div class="faq-item animate-reveal" data-aos="fade-up" data-aos-delay="{{ forloop.index | times: 100 }}">
          <button class="faq-question" onclick="this.parentElement.classList.toggle('active'); var ans = this.nextElementSibling; if(ans.style.maxHeight){ans.style.maxHeight=null}else{ans.style.maxHeight=ans.scrollHeight+'px'}">
            {{ block.settings.question }}
            <svg viewBox="0 0 10 6" fill="none"><path d="M1 1l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
          </button>
          <div class="faq-answer">
            <div class="faq-answer-inner">{{ block.settings.answer }}</div>
          </div>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "FAQ Section",
  "blocks": [
    {
      "type": "faq",
      "name": "Question",
      "settings": [
        { "type": "text", "id": "question", "label": "Question", "default": "How do I care for my bamboo items?" },
        { "type": "textarea", "id": "answer", "label": "Answer", "default": "We recommend machine washing cold on a gentle cycle and hanging to dry for longevity." }
      ]
    }
  ],
  "presets": [
    {
      "name": "FAQ Section",
      "blocks": [
        { "type": "faq", "settings": { "question": "What is your return policy?" } },
        { "type": "faq", "settings": { "question": "Do you ship internationally?" } },
        { "type": "faq", "settings": { "question": "How do I find the right size?" } }
      ]
    }
  ]
}
{% endschema %}
