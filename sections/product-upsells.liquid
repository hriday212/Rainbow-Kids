<style>
  .product-upsells { padding: 100px 0; background: #fff; border-top: 1px solid #f4f4f4; }
  .upsell-header { margin-bottom: 50px; text-align: left; display: flex; justify-content: space-between; align-items: flex-end; }
  .upsell-title { font-family: var(--font-heading); font-size: 2.2rem; color: #1a1a1a; margin: 0; }
  .upsell-link { font-size: 0.75rem; font-weight: 800; text-transform: uppercase; letter-spacing: 0.15em; color: var(--color-primary); text-decoration: none; border-bottom: 2px solid var(--color-primary); padding-bottom: 4px; }

  .upsell-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 30px; }
  .upsell-card { text-decoration: none; display: block; }
  .upsell-card__img { aspect-ratio: 4/5; border-radius: 20px; overflow: hidden; background: #f9f9f9; margin-bottom: 15px; position: relative; }
  .upsell-card__img img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.6s var(--ease-smooth); }
  .upsell-card:hover .upsell-card__img img { transform: scale(1.05); }
  
  .upsell-card__title { font-family: var(--font-heading); font-size: 1.1rem; color: #1a1a1a; margin-bottom: 5px; }
  .upsell-card__price { font-weight: 700; color: var(--color-primary); font-size: 0.95rem; }

  @media (max-width: 1024px) { .upsell-grid { grid-template-columns: repeat(2, 1fr); gap: 20px; } .upsell-title { font-size: 1.8rem; } }
</style>

<section class="product-upsells">
  <div class="container">
    <div class="upsell-header">
      <div>
        <span style="font-size:0.7rem; font-weight:800; text-transform:uppercase; letter-spacing:0.2em; color:var(--color-primary); margin-bottom:10px; display:block;">Pair it with</span>
        <h2 class="upsell-title">{{ section.settings.title | default: "Complete the Look" }}</h2>
      </div>
      <a href="/collections/all" class="upsell-link">View All</a>
    </div>

    <div class="upsell-grid">
      {%- assign upsell_collection = section.settings.collection | default: collection -%}
      {%- if upsell_collection and upsell_collection.products.size > 0 -%}
        {%- for product in upsell_collection.products limit: 4 -%}
          <a href="{{ product.url }}" class="upsell-card">
            <div class="upsell-card__img">
              {%- if product.featured_image -%}
                <img src="{{ product.featured_image | image_url: width: 600 }}" alt="{{ product.title }}">
              {%- else -%}
                <div style="width:100%; height:100%; display:flex; align-items:center; justify-content:center; color:#ccc;">{{ 'product-1' | placeholder_svg_tag }}</div>
              {%- endif -%}
            </div>
            <h3 class="upsell-card__title">{{ product.title }}</h3>
            <p class="upsell-card__price">{{ product.price | money }}</p>
          </a>
        {%- endfor -%}
      {%- else -%}
        {%- comment -%} Fallback Demo Upsells {%- endcomment -%}
        {%- for i in (1..4) -%}
          <div class="upsell-card">
            <div class="upsell-card__img">
              <div style="width:100%; height:100%; display:flex; align-items:center; justify-content:center; background:#f4f4f4; color:#ccc;">{{ 'product-' | append: i | placeholder_svg_tag }}</div>
            </div>
            <h3 class="upsell-card__title">Matching Bamboo Accessory</h3>
            <p class="upsell-card__price">$24.00</p>
          </div>
        {%- endfor -%}
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Product Upsells",
  "settings": [
    { "type": "text", "id": "title", "label": "Heading", "default": "Complete the Look" },
    { "type": "collection", "id": "collection", "label": "Select Collection" }
  ],
  "presets": [{ "name": "Boutique Product Upsells" }]
}
{% endschema %}
