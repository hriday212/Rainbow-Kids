<style>
  .hero-slider { position: relative; height: 80vh; min-height: 600px; background: var(--color-background); overflow: hidden; }
  .hero-slide { position: absolute; inset: 0; display: flex; align-items: center; opacity: 0; transition: opacity 1s var(--ease-smooth); }
  .hero-slide.active { opacity: 1; z-index: 1; }
  
  .hero-bg { position: absolute; inset: 0; z-index: -1; }
  .hero-bg img { width: 100%; height: 100%; object-fit: cover; }
  .hero-overlay { position: absolute; inset: 0; background: linear-gradient(90deg, rgba(255,255,255,0.4) 0%, transparent 60%); }
  
  .hero-content { max-width: 650px; padding-left: 100px; }
  .hero-subtitle { font-size: 0.9rem; font-weight: 800; text-transform: uppercase; letter-spacing: 0.3em; color: var(--color-primary); margin-bottom: 20px; display: block; }
  .hero-title { font-family: var(--font-heading); font-size: clamp(3rem, 8vw, 5.5rem); color: #1a1a1a; line-height: 1; margin-bottom: 30px; }
  .hero-btn { display: inline-block; padding: 20px 45px; background: var(--color-primary); color: #fff; text-decoration: none; font-weight: 800; border-radius: 50px; text-transform: uppercase; letter-spacing: 0.1em; transition: all 0.3s; }
  .hero-btn:hover { transform: translateY(-5px); box-shadow: 0 15px 30px rgba(255,140,105,0.3); }

  @media (max-width: 768px) { .hero-content { padding-left: 20px; text-align: center; } .hero-overlay { background: rgba(255,255,255,0.4); } }
</style>

<section class="hero-slider">
  <div class="hero-slide active">
    <div class="hero-bg">
      <img src="https://images.unsplash.com/photo-1522771917710-2ee211117f77?q=80&w=2000" alt="Boutique Slider">
      <div class="hero-overlay"></div>
    </div>
    <div class="container">
      <div class="hero-content">
        <span class="hero-subtitle">Spring Collection 2026</span>
        <h1 class="hero-title">Softness defined.</h1>
        <p style="font-size:1.2rem; color:#444; margin-bottom:40px;">Discover the world's softest bamboo apparel for your little ones.</p>
        <a href="/collections/all" class="hero-btn">Shop the Collection</a>
      </div>
    </div>
  </div>
</section>

{% schema %}
{ "name": "Hero Slider", "settings": [] }
{% endschema %}
