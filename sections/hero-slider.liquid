<style>
  .hero-slider { position: relative; height: 80vh; min-height: 600px; background: var(--color-background); overflow: hidden; }
  .hero-slide { display: flex; align-items: center; position: relative; height: 100%; width: 100%; }
  
  .hero-bg { position: absolute; inset: 0; z-index: -1; }
  .hero-bg img { width: 100%; height: 100%; object-fit: cover; }
  .hero-overlay { position: absolute; inset: 0; background: linear-gradient(90deg, rgba(255,255,255,0.4) 0%, transparent 60%); }
  
  .hero-content { max-width: 650px; padding-left: 100px; z-index: 2; position: relative; }
  .hero-subtitle { font-size: 0.9rem; font-weight: 800; text-transform: uppercase; letter-spacing: 0.3em; color: var(--color-primary); margin-bottom: 20px; display: block; }
  .hero-title { font-family: var(--font-heading); font-size: clamp(3rem, 8vw, 5.5rem); color: #1a1a1a; line-height: 1.1; margin-bottom: 30px; }
  .hero-btn { display: inline-block; padding: 20px 45px; background: var(--color-primary); color: #fff; text-decoration: none; font-weight: 800; border-radius: 50px; text-transform: uppercase; letter-spacing: 0.1em; transition: all 0.3s; }

  @media (max-width: 768px) { .hero-content { padding-left: 20px; text-align: center; } .hero-slider { height: 60vh; } }
</style>

<section class="hero-slider">
  {%- for block in section.blocks -%}
    <div class="hero-slide {% if forloop.first %}active{% endif %}" {{ block.shopify_attributes }}>
      <div class="hero-bg">
        {% if block.settings.image != blank %}
          <img src="{{ block.settings.image | image_url: width: 2000 }}" alt="{{ block.settings.title }}">
        {% else %}
          <img src="https://images.unsplash.com/photo-1522771917710-2ee211117f77?q=80&w=2000" alt="Boutique Demo">
        {% endif %}
        <div class="hero-overlay"></div>
      </div>
      <div class="container">
        <div class="hero-content animate-reveal">
          <span class="hero-subtitle">{{ block.settings.subtitle }}</span>
          <h1 class="hero-title">{{ block.settings.title }}</h1>
          <p style="font-size:1.2rem; color:#444; margin-bottom:40px;">{{ block.settings.text }}</p>
          {% if block.settings.button_label != blank %}
            <a href="{{ block.settings.button_link }}" class="hero-btn">{{ block.settings.button_label }}</a>
          {% endif %}
        </div>
      </div>
    </div>
  {%- endfor -%}
</section>

{% schema %}
{
  "name": "Hero Slider",
  "max_blocks": 5,
  "settings": [],
  "blocks": [
    {
      "type": "slide",
      "name": "Slide",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Banner Image" },
        { "type": "text", "id": "subtitle", "label": "Subtitle", "default": "Spring Collection" },
        { "type": "text", "id": "title", "label": "Title", "default": "Softness defined." },
        { "type": "textarea", "id": "text", "label": "Text", "default": "Discover the world's softest bamboo apparel." },
        { "type": "text", "id": "button_label", "label": "Button Label", "default": "Shop All" },
        { "type": "url", "id": "button_link", "label": "Button Link" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Boutique Hero Slider",
      "blocks": [
        { "type": "slide" }
      ]
    }
  ]
}
{% endschema %}
