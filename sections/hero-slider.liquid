<style>
  .hero-slider { position: relative; height: 80vh; min-height: 600px; background: #f9f9f9; overflow: hidden; }
  
  .hero-slide { position: absolute; inset: 0; display: flex; align-items: center; justify-content: center; opacity: 0; visibility: hidden; transition: opacity 0.8s var(--ease-smooth); z-index: 1; text-align: center; }
  .hero-slide.active { opacity: 1; visibility: visible; z-index: 2; }
  
  .hero-bg { position: absolute; inset: 0; z-index: -1; }
  .hero-bg img { width: 100%; height: 100%; object-fit: cover; }
  .hero-overlay { position: absolute; inset: 0; background: rgba(0,0,0,0.15); } /* Subtle dark overlay for readability */
  
  .hero-content { max-width: 800px; padding: 0 20px; position: relative; z-index: 3; display: flex; flex-direction: column; align-items: center; }
  .hero-subtitle { font-size: 0.9rem; font-weight: 800; text-transform: uppercase; letter-spacing: 0.3em; color: #fff; margin-bottom: 20px; display: block; text-shadow: 0 2px 10px rgba(0,0,0,0.2); }
  .hero-title { font-family: var(--font-heading); font-size: clamp(3rem, 8vw, 5.5rem); color: #fff; line-height: 1.1; margin-bottom: 30px; text-shadow: 0 2px 20px rgba(0,0,0,0.2); font-weight: 400; }
  .hero-text { font-size: 1.2rem; color: #fff; margin-bottom: 40px; text-shadow: 0 2px 10px rgba(0,0,0,0.2); max-width: 600px; }
  
  .hero-btn { display: inline-block; padding: 20px 45px; background: #fff; color: #1a1a1a; text-decoration: none; font-weight: 800; border-radius: 50px; text-transform: uppercase; letter-spacing: 0.2em; font-size: 0.75rem; transition: all 0.3s; box-shadow: 0 10px 30px rgba(0,0,0,0.1); }
  .hero-btn:hover { transform: translateY(-3px); box-shadow: 0 15px 40px rgba(0,0,0,0.2); background: var(--color-primary); color: #fff; }

  @media (max-width: 768px) { .hero-slider { height: 70vh; } .hero-title { font-size: 3rem; } }
</style>

<section class="hero-slider">
  {%- if section.blocks.size > 0 -%}
    {%- for block in section.blocks -%}
      <div class="hero-slide {% if forloop.first %}active{% endif %}" {{ block.shopify_attributes }}>
        <div class="hero-bg">
          {% if block.settings.image != blank %}
            <img src="{{ block.settings.image | image_url: width: 2000 }}" alt="{{ block.settings.title }}">
          {% else %}
            <img src="https://images.unsplash.com/photo-1522771917710-2ee211117f77?q=80&w=2000" alt="Boutique Demo">
          {% endif %}
          <div class="hero-overlay"></div>
        </div>
        <div class="hero-content">
          <span class="hero-subtitle reveal-text">{{ block.settings.subtitle }}</span>
          <h1 class="hero-title reveal-text">{{ block.settings.title }}</h1>
          <p class="hero-text reveal-text">{{ block.settings.text }}</p>
          {% if block.settings.button_label != blank %}
            <a href="{{ block.settings.button_link }}" class="hero-btn">{{ block.settings.button_label }}</a>
          {% endif %}
        </div>
      </div>
    {%- endfor -%}
  {%- endif -%}
</section>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const slides = document.querySelectorAll('.hero-slide');
    if (slides.length <= 1) return;

    let currentSlide = 0;
    
    function showSlide(index) {
      slides.forEach(slide => {
        slide.classList.remove('active');
        slide.querySelectorAll('.reveal-text').forEach(el => el.classList.remove('is-visible'));
      });
      
      slides[index].classList.add('active');
      // Trigger reveal for the new slide
      setTimeout(() => {
        slides[index].querySelectorAll('.reveal-text').forEach(el => el.classList.add('is-visible'));
      }, 300);
    }

    setInterval(() => {
      currentSlide = (currentSlide + 1) % slides.length;
      showSlide(currentSlide);
    }, 6000); // 6 Seconds per slide
  });
</script>

{% schema %}
{
  "name": "Hero Slider",
  "max_blocks": 5,
  "settings": [],
  "blocks": [
    {
      "type": "slide",
      "name": "Slide",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Banner Image" },
        { "type": "text", "id": "subtitle", "label": "Subtitle", "default": "Spring Collection" },
        { "type": "text", "id": "title", "label": "Title", "default": "Softness defined." },
        { "type": "textarea", "id": "text", "label": "Text", "default": "Discover the world's softest bamboo apparel." },
        { "type": "text", "id": "button_label", "label": "Button Label", "default": "Shop All" },
        { "type": "url", "id": "button_link", "label": "Button Link" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Boutique Hero Slider",
      "blocks": [
        { "type": "slide" }
      ]
    }
  ]
}
{% endschema %}
