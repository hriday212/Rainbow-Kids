<style>
  .categories-grid { padding: 80px 0; background: #fff; }
  .categories-grid__header { text-align: center; margin-bottom: 50px; }
  .categories-grid__title { font-family: var(--font-heading); font-size: 3rem; color: #1a1a1a; }
  
  .categories-list { display: flex; justify-content: center; gap: 40px; flex-wrap: wrap; }
  .category-item { text-align: center; text-decoration: none; width: 140px; }
  
  .category-img-wrap { width: 140px; height: 140px; border-radius: 50%; overflow: hidden; background: var(--color-background); margin-bottom: 15px; border: 4px solid #fff; box-shadow: 0 10px 30px rgba(0,0,0,0.05); transition: all 0.3s var(--ease-smooth); }
  .category-img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.5s; }
  
  .category-item:hover .category-img-wrap { transform: translateY(-10px); box-shadow: 0 20px 40px rgba(0,0,0,0.1); border-color: var(--color-primary); }
  .category-item:hover .category-img { transform: scale(1.1); }
  
  .category-title { font-size: 0.85rem; font-weight: 800; text-transform: uppercase; letter-spacing: 0.1em; color: #1a1a1a; display: block; }

  @media (max-width: 768px) { .categories-list { gap: 20px; } .category-item { width: 100px; } .category-img-wrap { width: 100px; height: 100px; } }
</style>

<section class="categories-grid">
  <div class="container">
    <div class="categories-grid__header">
      <h2 class="categories-grid__title">{{ section.settings.title | default: "Shop by Category" }}</h2>
    </div>

    <div class="categories-list">
      {%- if section.blocks.size > 0 -%}
        {%- for block in section.blocks -%}
          <a href="{{ block.settings.link | default: '#' }}" class="category-item animate-reveal">
            <div class="category-img-wrap">
              {% if block.settings.image != blank %}
                <img src="{{ block.settings.image | image_url: width: 400 }}" class="category-img">
              {% else %}
                <img src="https://images.unsplash.com/photo-1522771917710-2ee211117f77?q=80&w=400" class="category-img">
              {% endif %}
            </div>
            <span class="category-title">{{ block.settings.title }}</span>
          </a>
        {%- endfor -%}
      {%- else -%}
        {% comment %} Demo Categories {% endcomment %}
        {%- assign demo_titles = "Sleep Bags,Pajamas,Bodysuits,Newborn,Baby,Toddler" | split: "," -%}
        {%- assign demo_links = "/pages/sleep-bags,/pages/pajamas,/pages/bodysuits,/pages/newborn,/pages/baby,/pages/toddler" | split: "," -%}
        {%- for title in demo_titles -%}
          <a href="{{ demo_links[forloop.index0] }}" class="category-item">
            <div class="category-img-wrap">
              <img src="https://images.unsplash.com/photo-1515488403636-ee00ca9ff67b?q=80&w=400" class="category-img">
            </div>
            <span class="category-title">{{ title }}</span>
          </a>
        {%- endfor -%}
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Categories Grid",
  "settings": [
    { "type": "text", "id": "title", "label": "Heading", "default": "Shop by Category" }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Category",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Icon Image" },
        { "type": "text", "id": "title", "label": "Title" },
        { "type": "url", "id": "link", "label": "Link" }
      ]
    }
  ],
  "presets": [
    { "name": "Boutique Categories Grid" }
  ]
}
{% endschema %}
