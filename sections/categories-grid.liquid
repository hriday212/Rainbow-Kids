<style>
  .categories-section { padding: 80px 0; background: #fff; }
  .categories-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 20px; }
  
  .category-card { position: relative; aspect-ratio: 1/1.4; border-radius: 20px; overflow: hidden; text-decoration: none; display: flex; align-items: flex-end; padding: 30px; }
  .category-card__img { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; transition: transform 1.2s cubic-bezier(0.19, 1, 0.22, 1); z-index: 1; }
  .category-card:hover .category-card__img { transform: scale(1.08); }
  
  .category-card__overlay { position: absolute; inset: 0; background: linear-gradient(transparent, rgba(0,0,0,0.5)); z-index: 2; }
  
  .category-card__info { position: relative; z-index: 3; color: #fff; }
  .category-card__title { font-family: var(--font-heading); font-size: 1.8rem; margin: 0; font-weight: 400; }
  .category-card__link { font-size: 0.7rem; font-weight: 800; text-transform: uppercase; letter-spacing: 0.15em; margin-top: 10px; display: block; }

  @media (max-width: 1024px) { .categories-grid { grid-template-columns: 1fr 1fr; } }
</style>

<section class="categories-section">
  <div class="container">
    <div class="categories-grid">
      {% for block in section.blocks %}
        <a href="{{ block.settings.link | default: '#' }}" class="category-card animate-reveal" data-aos="fade-up" data-aos-delay="{{ forloop.index | times: 100 }}">
          {% if block.settings.image != blank %}
            <img src="{{ block.settings.image | image_url: width: 800 }}" class="category-card__img" alt="{{ block.settings.title }}">
          {% else %}
            <img src="{{ 'https://images.unsplash.com/photo-1522771917710-2ee211117f77?q=80&w=800' }}" class="category-card__img" alt="Demo">
          {% endif %}
          <div class="category-card__overlay"></div>
          <div class="category-card__info">
            <h3 class="category-card__title">{{ block.settings.title }}</h3>
            <span class="category-card__link">Shop Now</span>
          </div>
        </a>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Categories Grid",
  "max_blocks": 4,
  "blocks": [
    {
      "type": "category",
      "name": "Category",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Category Image" },
        { "type": "text", "id": "title", "label": "Category Title", "default": "Sleep Bags" },
        { "type": "url", "id": "link", "label": "Category Link" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Boutique Categories Grid",
      "blocks": [
        { "type": "category", "settings": { "title": "Sleep Bags" } },
        { "type": "category", "settings": { "title": "Pajamas" } },
        { "type": "category", "settings": { "title": "Bodysuits" } },
        { "type": "category", "settings": { "title": "Bundles" } }
      ]
    }
  ]
}
{% endschema %}
