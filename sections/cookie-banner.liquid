<style>
  #cookie-banner {
    position: fixed;
    bottom: 30px;
    left: 30px;
    width: 380px;
    background: #fff;
    padding: 30px;
    border-radius: 24px;
    box-shadow: 0 20px 60px rgba(0,0,0,0.1);
    z-index: 10000;
    display: block; /* Forced visible for editor audit */
    border: 1px solid rgba(0,0,0,0.05);
  }

  .cookie-title { font-family: var(--font-heading); font-size: 1.4rem; margin-bottom: 10px; color: #1a1a1a; }
  .cookie-text { font-size: 0.9rem; color: #666; line-height: 1.6; margin-bottom: 25px; }
  
  .cookie-btns { display: flex; gap: 10px; }
  .cookie-btn { flex: 1; padding: 12px; border-radius: 12px; font-weight: 800; text-transform: uppercase; font-size: 0.7rem; letter-spacing: 0.1em; cursor: pointer; transition: all 0.3s; border: none; }
  
  .btn--accept { background: var(--color-primary); color: #fff; }
  .btn--decline { background: #f4f4f4; color: #999; }

  @media (max-width: 600px) { #cookie-banner { left: 10px; right: 10px; width: auto; bottom: 10px; } }
</style>

<div id="cookie-banner">
  <h3 class="cookie-title">Sweeten the deal? 🍪</h3>
  <p class="cookie-text">We use cookies to ensure you get the best experience on our boutique. By continuing, you agree to our privacy policy.</p>
  <div class="cookie-btns">
    <button class="cookie-btn btn--accept" id="AcceptCookies">Accept</button>
    <button class="cookie-btn btn--decline" id="DeclineCookies">Decline</button>
  </div>
</div>

{% schema %}
{ "name": "Cookie Banner", "settings": [] }
{% endschema %}
