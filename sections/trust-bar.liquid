<style>
  .trust-bar { padding: 40px 0; background: #fff; border-top: 1px solid rgba(0,0,0,0.05); border-bottom: 1px solid rgba(0,0,0,0.05); }
  .trust-bar__grid { display: flex; justify-content: space-between; align-items: center; gap: 20px; }
  .trust-item { display: flex; flex-direction: column; align-items: center; gap: 8px; text-align: center; flex: 1; }
  .trust-item__icon { font-size: 1.5rem; }
  .trust-item__title { font-size: 0.85rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em; color: var(--color-text-dark); }
  .trust-item__text { font-size: 0.75rem; color: var(--color-text-light); }

  @media (max-width: 768px) {
    .trust-bar__grid { flex-wrap: wrap; display: grid; grid-template-columns: 1fr 1fr; gap: 30px; }
  }
</style>

<section class="trust-bar">
  <div class="container">
    <div class="trust-bar__grid">
      <div class="trust-item">
        <span class="trust-item__icon">🚚</span>
        <span class="trust-item__title">Free Shipping</span>
        <span class="trust-item__text">On orders over $85</span>
      </div>
      <div class="trust-item">
        <span class="trust-item__icon">↩️</span>
        <span class="trust-item__title">Easy Returns</span>
        <span class="trust-item__text">30-day hassle-free</span>
      </div>
      <div class="trust-item">
        <span class="trust-item__icon">🌿</span>
        <span class="trust-item__title">Eco-Friendly</span>
        <span class="trust-item__text">Sustainable Bamboo</span>
      </div>
      <div class="trust-item">
        <span class="trust-item__icon">🔒</span>
        <span class="trust-item__title">Secure Checkout</span>
        <span class="trust-item__text">SSL Encrypted</span>
      </div>
    </div>
  </div>
</section>

{% schema %}
{ "name": "Trust Bar" }
{% endschema %}
