<style>
  .trust-bar { padding: 60px 0; background: #fff; border-top: 1px solid #f4f4f4; border-bottom: 1px solid #f4f4f4; }
  .trust-grid { display: flex; justify-content: center; gap: 60px; flex-wrap: wrap; }
  
  .trust-item { text-align: center; max-width: 200px; }
  .trust-icon { font-size: 2.5rem; margin-bottom: 15px; display: block; }
  .trust-text { font-size: 0.75rem; font-weight: 800; text-transform: uppercase; letter-spacing: 0.15em; color: #1a1a1a; display: block; margin-bottom: 8px; }
  .trust-subtext { font-size: 0.85rem; color: #888; }

  @media (max-width: 768px) { .trust-grid { gap: 40px 20px; } .trust-item { flex: 0 0 140px; } }
</style>

<section class="trust-bar">
  <div class="container">
    <div class="trust-grid">
      {%- if section.blocks.size > 0 -%}
        {%- for block in section.blocks -%}
          <div class="trust-item animate-reveal" {{ block.shopify_attributes }}>
            <span class="trust-icon">{{ block.settings.icon | default: "🤍" }}</span>
            <span class="trust-text">{{ block.settings.title }}</span>
            <span class="trust-subtext">{{ block.settings.subtitle }}</span>
          </div>
        {%- endfor -%}
      {%- else -%}
        {% comment %} Demo Trust Items {% endcomment %}
        <div class="trust-item">
          <span class="trust-icon">🚚</span>
          <span class="trust-text">Fast Shipping</span>
          <span class="trust-subtext">Free over $85</span>
        </div>
        <div class="trust-item">
          <span class="trust-icon">🌿</span>
          <span class="trust-text">Eco-Friendly</span>
          <span class="trust-subtext">100% Bamboo</span>
        </div>
        <div class="trust-item">
          <span class="trust-icon">🛡️</span>
          <span class="trust-text">Secure Shop</span>
          <span class="trust-subtext">Buyer protection</span>
        </div>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Trust Bar",
  "settings": [],
  "blocks": [
    {
      "type": "trust_item",
      "name": "Trust Item",
      "settings": [
        { "type": "text", "id": "icon", "label": "Emoji Icon", "default": "🚚" },
        { "type": "text", "id": "title", "label": "Title", "default": "Fast Shipping" },
        { "type": "text", "id": "subtitle", "label": "Subtitle", "default": "Free over $85" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Boutique Trust Bar",
      "blocks": [
        { "type": "trust_item", "settings": { "icon": "🚚", "title": "Fast Shipping" } },
        { "type": "trust_item", "settings": { "icon": "🌿", "title": "Eco-Friendly" } },
        { "type": "trust_item", "settings": { "icon": "🛡️", "title": "Secure Shop" } }
      ]
    }
  ]
}
{% endschema %}
