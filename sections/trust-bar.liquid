<style>
  .trust-bar { padding: 50px 0; background: #fff; border-top: 1px solid #f4f4f4; border-bottom: 1px solid #f4f4f4; }
  .trust-bar__grid { display: flex; justify-content: space-around; align-items: flex-start; gap: 40px; flex-wrap: wrap; }
  .trust-item { display: flex; flex-direction: column; align-items: center; text-align: center; gap: 18px; flex: 1; min-width: 200px; opacity: 1; visibility: visible; }
  .trust-item__icon { width: 64px; height: 64px; border-radius: 50%; background: #fdf8f6; display: flex; align-items: center; justify-content: center; box-shadow: 0 5px 15px rgba(0,0,0,0.03); color: var(--color-primary); }
  .trust-item__icon svg { width: 28px; height: 28px; }
  .trust-item__title { font-weight: 800; font-size: 0.9rem; text-transform: uppercase; letter-spacing: 0.12em; color: #1a1a1a; margin: 0; }
  .trust-item__text { font-size: 0.85rem; color: #888; line-height: 1.6; margin: 0; max-width: 220px; }
  @media (max-width: 768px) { .trust-bar__grid { gap: 30px; } .trust-item { min-width: 150px; } }
</style>

<section class="trust-bar">
  <div class="container">
    <div class="trust-bar__grid">
      {%- comment -%} Item 1: Organic {%- endcomment -%}
      <div class="trust-item">
        <div class="trust-item__icon">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 21a9.004 9.004 0 0 0 8.716-6.747M12 21a9.004 9.004 0 0 1-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 0 1 7.843 4.582M12 3a8.997 8.997 0 0 0-7.843 4.582m15.686 0A11.953 11.953 0 0 1 12 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0 1 21 12c0 .778-.099 1.533-.284 2.253m0 0A17.919 17.919 0 0 1 12 16.5c-3.162 0-6.133-.815-8.716-2.247m2.247-2.247a11.95 11.95 0 0 1-2.247-2.253" /></svg>
        </div>
        <p class="trust-item__title">100% Organic</p>
        <p class="trust-item__text">Certified OEKO-TEX bamboo fabric for sensitive skin.</p>
      </div>

      {%- comment -%} Item 2: Shipping {%- endcomment -%}
      <div class="trust-item">
        <div class="trust-item__icon">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M8.25 18.75a1.5 1.5 0 0 1-3 0m3 0a1.5 1.5 0 0 0-3 0m3 0h6m-9 0H3.375a1.125 1.125 0 0 1-1.125-1.125V14.25m17.25 4.5a1.5 1.5 0 0 1-3 0m3 0a1.5 1.5 0 0 0-3 0m3 0h1.125a1.125 1.125 0 0 0 1.125-1.125V4.605a1.125 1.125 0 0 0-1.125-1.125H9.75a1.125 1.125 0 0 0-1.125 1.125V14.25m12 0h1.125a1.125 1.125 0 0 0 1.125-1.125V9.75m-4.5 4.5H4.875c-.621 0-1.125-.504-1.125-1.125v-6.75c0-.621.504-1.125 1.125-1.125h12.75c.621 0 1.125.504 1.125 1.125v6.75c0 .621-.504 1.125-1.125 1.125Z" /></svg>
        </div>
        <p class="trust-item__title">Free Shipping</p>
        <p class="trust-item__text">Complimentary shipping on all orders over $85.</p>
      </div>

      {%- comment -%} Item 3: Safety {%- endcomment -%}
      <div class="trust-item">
        <div class="trust-item__icon">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75m-3-7.036A11.959 11.959 0 0 1 3.598 6 11.99 11.99 0 0 0 3 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285Z" /></svg>
        </div>
        <p class="trust-item__title">Safe & Tested</p>
        <p class="trust-item__text">Every garment rigorously tested for baby safety.</p>
      </div>

      {%- comment -%} Item 4: Love {%- endcomment -%}
      <div class="trust-item">
        <div class="trust-item__icon">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.014-4.5-4.5-4.5-1.485 0-2.771.72-3.56 1.83a4.502 4.502 0 0 0-7.12 0C5.021 5.58 3.75 6.865 3.75 8.25c0 4.545 7.625 10.5 8.25 10.5.625 0 8.25-5.955 8.25-10.5Z" /></svg>
        </div>
        <p class="trust-item__title">Made with Love</p>
        <p class="trust-item__text">Designed by parents, for the tiniest dreamers.</p>
      </div>
    </div>
  </div>
</section>

