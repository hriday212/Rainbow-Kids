<style>
  .trust-bar { padding: 60px 0; background: #fff; border-top: 1px solid #f4f4f4; border-bottom: 1px solid #f4f4f4; }
  .trust-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 40px; }
  
  .trust-item { text-align: center; }
  .trust-icon { font-size: 2.5rem; margin-bottom: 15px; display: block; }
  .trust-text { font-size: 0.75rem; font-weight: 800; text-transform: uppercase; letter-spacing: 0.15em; color: #1a1a1a; display: block; margin-bottom: 8px; }
  .trust-subtext { font-size: 0.85rem; color: #888; }

  @media (max-width: 768px) { .trust-grid { grid-template-columns: 1fr 1fr; gap: 40px 20px; } }
</style>

<section class="trust-bar">
  <div class="container">
    <div class="trust-grid">
      <div class="trust-item animate-reveal">
        <span class="trust-icon">🚚</span>
        <span class="trust-text">Fast Shipping</span>
        <span class="trust-subtext">Free over $85</span>
      </div>
      <div class="trust-item animate-reveal">
        <span class="trust-icon">🌿</span>
        <span class="trust-text">Eco-Friendly</span>
        <span class="trust-subtext">100% Bamboo</span>
      </div>
      <div class="trust-item animate-reveal">
        <span class="trust-icon">🛡️</span>
        <span class="trust-text">Secure Shop</span>
        <span class="trust-subtext">Buyer protection</span>
      </div>
      <div class="trust-item animate-reveal">
        <span class="trust-icon">🤍</span>
        <span class="trust-text">Family Owned</span>
        <span class="trust-subtext">Made with love</span>
      </div>
    </div>
  </div>
</section>

{% schema %}
{ "name": "Boutique Trust Bar", "settings": [] }
{% endschema %}
