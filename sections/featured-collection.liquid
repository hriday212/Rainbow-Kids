<style>
  .featured-coll { padding: 80px 0; background: var(--color-background); }
  .featured-coll__header { text-align: center; margin-bottom: 48px; }
  
  .product-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 24px; }
  
  /* Shared with collection-list */
  .product-card { position: relative; display: flex; flex-direction: column; gap: 16px; }
  .product-card__media { position: relative; aspect-ratio: 1/1; border-radius: var(--radius-soft); overflow: hidden; background: #f4f4f4; display: block; }
  .product-card__img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.6s var(--ease-smooth); }
  .product-card:hover .product-card__img { transform: scale(1.06); }
  
  .product-card__badge { position: absolute; top: 12px; left: 12px; background: var(--color-primary); color: var(--color-text-dark); font-size: 0.7rem; font-weight: 700; text-transform: uppercase; padding: 4px 10px; border-radius: var(--radius-pill); z-index: 2; }
  .product-card__badge--sold { background: #eee; color: #999; }
  
  .product-card__info { display: flex; flex-direction: column; gap: 4px; }
  .product-card__title { font-size: 1rem; font-weight: 600; color: var(--color-text-dark); margin: 0; }
  .product-card__price { font-size: 0.9rem; color: var(--color-text-light); }
  .product-card__atc { margin-top: 8px; padding: 10px; border-radius: var(--radius-pill); border: 1px solid #ddd; background: #fff; font-size: 0.8rem; font-weight: 600; cursor: pointer; transition: all 0.2s; }
  .product-card__atc:hover { background: var(--color-text-dark); color: #fff; border-color: var(--color-text-dark); }

  @media (max-width: 1024px) { .product-grid { grid-template-columns: repeat(2, 1fr); } }
</style>

<section class="featured-coll animate-reveal">
  <div class="container">
    <div class="featured-coll__header">
      {%- if section.settings.tag != blank -%}<span class="section-tag">{{ section.settings.tag }}</span>{%- endif -%}
      <h2 style="font-size: 2.5rem;">{{ section.settings.title | default: 'Shop Our Favorites' }}</h2>
    </div>

    <div class="product-grid">
      {%- assign collection = collections[section.settings.collection] -%}
      {%- if collection.products.size > 0 -%}
        {%- for product in collection.products limit: section.settings.limit -%}
          <div class="product-card">
            <a href="{{ product.url }}" class="product-card__media">
              {%- if product.available == false -%}
                <span class="product-card__badge product-card__badge--sold">Sold Out</span>
              {%- elsif product.compare_at_price > product.price -%}
                <span class="product-card__badge">Sale</span>
              {%- endif -%}
              <img src="{{ product.featured_image | image_url: width: 600 }}" class="product-card__img" alt="{{ product.title | escape }}" loading="lazy">
            </a>
            <div class="product-card__info">
              <h3 class="product-card__title">{{ product.title }}</h3>
              <span class="product-card__price">
                {%- if product.compare_at_price > product.price -%}
                  <s style="opacity:0.5;">{{ product.compare_at_price | money }}</s>&ensp;
                {%- endif -%}
                {{ product.price | money }}
              </span>
              <button class="product-card__atc" onclick="window.openCart()">Add to Bag</button>
            </div>
          </div>
        {%- endfor -%}
      {%- else -%}
        {%- comment -%} Placeholders if no collection is selected {%- endcomment -%}
        {%- for i in (1..4) -%}
          <div class="product-card">
            <div class="product-card__media" style="background: #eee; display: flex; align-items: center; justify-content: center;">
              {{ 'product-' | append: i | placeholder_svg_tag: 'placeholder-svg' }}
            </div>
            <div class="product-card__info">
              <h3 class="product-card__title">Example Product {{ i }}</h3>
              <span class="product-card__price">$35.00</span>
              <button class="product-card__atc">Add to Bag</button>
            </div>
          </div>
        {%- endfor -%}
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Featured Collection",
  "settings": [
    { "type": "text", "id": "tag", "label": "Eyebrow Label", "default": "Bestsellers" },
    { "type": "text", "id": "title", "label": "Heading", "default": "Shop Our Favorites" },
    { "type": "collection", "id": "collection", "label": "Collection" },
    { "type": "range", "id": "limit", "min": 4, "max": 12, "step": 4, "default": 4, "label": "Products to show" }
  ],
  "presets": [
    { "name": "Featured Collection" }
  ]
}
{% endschema %}
