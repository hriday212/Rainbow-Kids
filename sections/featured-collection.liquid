<style>
  .featured-collection { padding: 100px 0; background: #fff; }
  .featured-collection__header { text-align: center; margin-bottom: 60px; }
  .featured-collection__title { font-family: var(--font-heading); font-size: 3.5rem; color: #1a1a1a; margin-bottom: 20px; font-weight: 400; }
  
  .featured-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 40px 20px; }
  
  @media (max-width: 1024px) { .featured-grid { grid-template-columns: repeat(2, 1fr); } }
</style>

<section class="featured-collection">
  <div class="container">
    <div class="featured-collection__header animate-reveal">
      <h2 class="featured-collection__title">{{ section.settings.title | default: "Best Sellers" }}</h2>
      <a href="{{ section.settings.collection.url | default: '#' }}" class="boutique-link">Shop All</a>
    </div>

    <div class="featured-grid">
      {%- assign collection = section.settings.collection -%}
      {%- if collection != blank -%}
        {%- for product in collection.products limit: 8 -%}
          <div class="product-card" data-aos="fade-up" data-aos-delay="{{ forloop.index | times: 50 }}">
            <div class="product-card__image-wrap" style="aspect-ratio:1/1.2; overflow:hidden; border-radius:12px; background:#f9f9f9; margin-bottom:15px;">
              <img src="{{ product.featured_image | image_url: width: 600 }}" style="width:100%; height:100%; object-fit:cover;">
            </div>
            <h3 style="font-family:var(--font-heading); font-size:1.1rem; margin:0 0 5px;">{{ product.title }}</h3>
            <p style="font-weight:700; margin:0;">{{ product.price | money }}</p>
          </div>
        {%- endfor -%}
      {%- else -%}
        {%- for i in (1..4) -%}
          <div class="product-card">
            <div class="product-card__image-wrap" style="aspect-ratio:1/1.2; overflow:hidden; border-radius:12px; background:#f9f9f9; margin-bottom:15px;">
              <img src="https://images.unsplash.com/photo-1522771917710-2ee211117f77?q=80&w=600" style="width:100%; height:100%; object-fit:cover;">
            </div>
            <h3 style="font-family:var(--font-heading); font-size:1.1rem; margin:0 0 5px;">Bamboo Sleep Bag {{ i }}</h3>
            <p style="font-weight:700; margin:0;">$55.00</p>
          </div>
        {%- endfor -%}
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Featured Collection",
  "settings": [
    { "type": "text", "id": "title", "label": "Heading", "default": "Best Sellers" },
    { "type": "collection", "id": "collection", "label": "Collection" }
  ],
  "presets": [
    { "name": "Boutique Featured Collection" }
  ]
}
{% endschema %}
