<style>
  .featured-collection { padding: 100px 0; }
  .featured-collection--pink { background: var(--color-pink); }
  .featured-collection--blue { background: var(--color-blue); }
  .featured-collection--lavender { background: var(--color-lavender); }
  .featured-collection--peach { background: var(--color-background); }
  .featured-collection--white { background: #fff; }
  
  .fc-header { text-align: center; margin-bottom: 60px; }
  .fc-title { font-family: var(--font-heading); font-size: 3rem; color: #1a1a1a; margin-bottom: 10px; }
  .fc-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 30px; }
  
  .product-placeholder { background: #f4f4f4; width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; color: #ccc; }
  .product-placeholder svg { width: 100px; height: 100px; }

  @media (max-width: 1024px) { .fc-grid { grid-template-columns: 1fr 1fr; } }
</style>

<section class="featured-collection featured-collection--{{ section.settings.bg_color | default: 'white' }}">
  <div class="container">
    <div class="fc-header">
      <h2 class="fc-title">{{ section.settings.title | default: "Featured Collection" }}</h2>
      <a href="{{ section.settings.collection.url | default: '/collections/all' }}" class="boutique-link">View All</a>
    </div>

    <div class="fc-grid">
      {%- if section.settings.collection.products.size > 0 -%}
        {%- for product in section.settings.collection.products limit: 4 -%}
          <div class="product-card" >
            <div class="product-card__image-wrap" style="aspect-ratio:1/1.2; border-radius:12px; overflow:hidden; background:#fff; margin-bottom:15px;">
              <img src="{{ product.featured_image | image_url: width: 600 }}" style="width:100%; height:100%; object-fit:cover;">
            </div>
            <h3 style="font-family:var(--font-heading); font-size:1.1rem; margin:0 0 5px;">{{ product.title }}</h3>
            <p style="font-weight:700; color:var(--color-primary);">{{ product.price | money }}</p>
          </div>
        {%- endfor -%}
      {%- else -%}
        {%- for i in (1..4) -%}
          <div class="product-card">
            <div class="product-card__image-wrap" style="aspect-ratio:1/1.2; border-radius:12px; overflow:hidden; background:#fff; margin-bottom:15px;">
              <div class="product-placeholder">
                {{ 'product-' | append: i | placeholder_svg_tag: 'placeholder-svg' }}
              </div>
            </div>
            <h3 style="font-family:var(--font-heading); font-size:1.1rem; margin:0 0 5px;">Boutique Essential {{ i }}</h3>
            <p style="font-weight:700; color:var(--color-primary);">$45.00</p>
          </div>
        {%- endfor -%}
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Featured Collection",
  "settings": [
    { "type": "text", "id": "title", "label": "Heading", "default": "Featured Collection" },
    { "type": "collection", "id": "collection", "label": "Collection" },
    {
      "type": "select",
      "id": "bg_color",
      "label": "Background Color",
      "options": [
        { "value": "white", "label": "Pure White" },
        { "value": "pink", "label": "Boutique Pink" },
        { "value": "blue", "label": "Boutique Blue" },
        { "value": "lavender", "label": "Boutique Lavender" },
        { "value": "peach", "label": "Peach Cream" }
      ],
      "default": "white"
    }
  ],
  "presets": [
    { "name": "Boutique Collection Grid" }
  ]
}
{% endschema %}
