<style>
  .announcement-bar { background: var(--color-secondary); overflow: hidden; padding: 12px 0; border-bottom: 1px solid rgba(0,0,0,0.05); }
  .announcement-bar__scroller { display: flex; white-space: nowrap; animation: scroll 30s linear infinite; gap: 60px; }
  
  .announcement-bar__item { font-size: 0.75rem; font-weight: 800; text-transform: uppercase; letter-spacing: 0.15em; color: #1a1a1a; display: flex; align-items: center; gap: 10px; }
  .announcement-bar__dot { width: 4px; height: 4px; background: #1a1a1a; border-radius: 50%; opacity: 0.3; }

  @keyframes scroll {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }
</style>

<div class="announcement-bar">
  <div class="announcement-bar__scroller">
    {%- for i in (1..4) -%}
      {%- for block in section.blocks -%}
        <div class="announcement-bar__item">
          {{ block.settings.text }}
          <span class="announcement-bar__dot"></span>
        </div>
      {%- endfor -%}
    {%- endfor -%}
  </div>
</div>

{% schema %}
{
  "name": "Announcement Bar",
  "blocks": [
    {
      "type": "message",
      "name": "Message",
      "settings": [
        { "type": "text", "id": "text", "label": "Message", "default": "Free shipping on orders over $100" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Boutique Announcement Bar",
      "blocks": [
        { "type": "message", "settings": { "text": "Free shipping on orders over $100" } },
        { "type": "message", "settings": { "text": "Shop New Arrivals" } }
      ]
    }
  ]
}
{% endschema %}
