<style>
  .announcement-bar { background: var(--color-secondary); overflow: hidden; padding: 12px 0; border-bottom: 1px solid rgba(0,0,0,0.1); }
  .announcement-bar__scroller { display: flex; white-space: nowrap; animation: scroll 40s linear infinite; gap: 80px; }
  
  .announcement-bar__item { font-size: 0.8rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: #1a1a1a; display: flex; align-items: center; gap: 15px; }
  .announcement-bar__dot { font-size: 1.2rem; color: var(--color-primary); }

  @keyframes scroll {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }
</style>

<div class="announcement-bar">
  <div class="announcement-bar__scroller">
    {%- for i in (1..10) -%}
      <div class="announcement-bar__item">
        Free shipping on orders over $85 🌈
        <span class="announcement-bar__dot">•</span>
        Shop Our New Bamboo Essentials
        <span class="announcement-bar__dot">•</span>
        10% OFF your first order with code: RAINBOW10
        <span class="announcement-bar__dot">•</span>
      </div>
    {%- endfor -%}
  </div>
</div>

{% schema %}
{
  "name": "Announcement Bar",
  "settings": [],
  "presets": [
    { "name": "Fun Announcement Bar" }
  ]
}
{% endschema %}
