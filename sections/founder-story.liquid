<style>
  .founder-story { padding: 100px 0; background: #fdf8f6; overflow: hidden; }
  .founder-grid { display: grid; grid-template-columns: 1fr 1.2fr; gap: 80px; align-items: center; }
  
  .founder-image { position: relative; border-radius: 40px; overflow: hidden; aspect-ratio: 4/5; box-shadow: 0 40px 100px rgba(0,0,0,0.1); }
  .founder-image img { width: 100%; height: 100%; object-fit: cover; }
  .founder-placeholder { width: 100%; height: 100%; background: #f4f4f4; display: flex; align-items: center; justify-content: center; color: #ccc; }

  .founder-content { padding-right: 40px; opacity: 1 !important; visibility: visible !important; }
  .founder-subtitle { font-size: 0.75rem; font-weight: 800; text-transform: uppercase; letter-spacing: 0.2em; color: var(--color-primary); margin-bottom: 20px; display: block; }
  .founder-title { font-family: var(--font-heading); font-size: 3.5rem; color: #1a1a1a; line-height: 1.1; margin-bottom: 30px; }
  .founder-text { font-size: 1.15rem; color: #666; line-height: 1.8; margin-bottom: 40px; }
  
  .founder-btn { display: inline-block; padding: 20px 45px; background: #1a1a1a; color: #fff; text-decoration: none; border-radius: 50px; font-weight: 800; text-transform: uppercase; letter-spacing: 0.1em; font-size: 0.85rem; transition: all 0.3s; }
  .founder-btn:hover { transform: scale(1.05); box-shadow: 0 10px 30px rgba(0,0,0,0.15); }

  @media (max-width: 1024px) { 
    .founder-grid { grid-template-columns: 1fr; gap: 60px; } 
    .founder-content { padding-right: 0; text-align: center; }
    .founder-title { font-size: 2.5rem; }
  }
</style>

<section class="founder-story">
  <div class="container">
    <div class="founder-grid">
      <div class="founder-image">
        {%- if section.settings.image != blank -%}
          <img src="{{ section.settings.image | image_url: width: 1200 }}" alt="{{ section.settings.title }}">
        {%- else -%}
          <div class="founder-placeholder">{{ 'lifestyle-1' | placeholder_svg_tag }}</div>
        {%- endif -%}
      </div>

      <div class="founder-content">
        <span class="founder-subtitle">{{ section.settings.subtitle | default: "The Heart of the Hub" }}</span>
        <h2 class="founder-title">{{ section.settings.title | default: "Made by a Mom, Inspired by You." }}</h2>
        <div class="founder-text">
          {{ section.settings.text | default: "<p>It all started with a simple search for the perfect sleep bag. When I couldn't find the quality my baby deserved, I decided to build it myself. Rainbow Kids Hub is more than a store—it's a promise of softness, safety, and sweet dreams for every family.</p>" }}
        </div>
        <a href="{{ section.settings.link | default: '/pages/story' }}" class="founder-btn">{{ section.settings.link_label | default: "Read Our Story" }}</a>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Founder Story",
  "settings": [
    { "type": "image_picker", "id": "image", "label": "Founder Photo" },
    { "type": "text", "id": "subtitle", "label": "Subtitle", "default": "The Heart of the Hub" },
    { "type": "text", "id": "title", "label": "Heading", "default": "Made by a Mom, Inspired by You." },
    { "type": "richtext", "id": "text", "label": "Story Content" },
    { "type": "text", "id": "link_label", "label": "Button Label", "default": "Read Our Story" },
    { "type": "url", "id": "link", "label": "Button Link" }
  ],
  "presets": [{ "name": "Boutique Founder Story" }]
}
{% endschema %}
