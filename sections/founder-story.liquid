<style>
  .founder-story { padding: 120px 0; background: #fff; }
  .founder-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 80px; align-items: center; }
  .founder-image { position: relative; border-radius: 20px; overflow: hidden; aspect-ratio: 4/5; }
  .founder-image img { width: 100%; height: 100%; object-fit: cover; }
  .founder-content { display: flex; flex-direction: column; gap: 30px; }
  .founder-tag { font-size: 0.75rem; font-weight: 800; text-transform: uppercase; letter-spacing: 0.15em; color: #aaa; }
  .founder-title { font-family: var(--font-heading); font-size: 3.5rem; color: var(--color-text-dark); line-height: 1.1; margin: 0; }
  .founder-text { font-size: 1.1rem; color: #555; line-height: 1.8; font-style: italic; }
  .founder-signature { font-family: 'Bodoni Moda', serif; font-size: 1.8rem; margin-top: 20px; color: var(--color-text-dark); }
  @media (max-width: 1024px) { .founder-grid { grid-template-columns: 1fr; gap: 60px; } .founder-title { font-size: 2.8rem; } }
</style>
<section class="founder-story">
  <div class="container founder-grid">
    <div class="founder-image animate-reveal" data-aos="fade-right">
      <img src="https://images.unsplash.com/photo-1544005313-94ddf0286df2?q=80&w=800" alt="Our Founder">
    </div>
    <div class="founder-content animate-reveal" data-aos="fade-left">
      <span class="founder-tag">A Message from our founder</span>
      <h2 class="founder-title">Made for Moms, by a Mom.</h2>
      <div class="founder-text">
        <p>"Rainbow Kids was born from a simple need: I wanted the absolute best for my baby’s sensitive skin, without compromising on style or the planet."</p>
        <p>Today, we are more than just a store. We are a community of parents dedicated to comfort, safety, and a brighter future for our children.</p>
      </div>
      <div class="founder-signature">— With love, M.</div>
    </div>
  </div>
</section>
{% schema %}
{ "name": "Founder Story Section", "settings": [], "presets": [{ "name": "Founder Story Section" }] }
{% endschema %}
